function MyCustomUI:Notify(Data)
    local Text = Data.Text or "Notification"
    local Duration = Data.Duration or 3

    -- Create notification holder if not exists
    if not self.NotifHolder then
        self.NotifHolder = Cache.new("Frame")
        self.NotifHolder.Name = "NotificationHolder"
        self.NotifHolder.Size = UDim2.new(0, 320, 1, 0)
        self.NotifHolder.Position = UDim2.new(1, -330, 0, 20)
        self.NotifHolder.BackgroundTransparency = 1
        self.NotifHolder.ZIndex = 100
        self.NotifHolder.Parent = Services.CoreGui

        local HolderLayout = Cache.new("UIListLayout")
        HolderLayout.SortOrder = Enum.SortOrder.LayoutOrder
        HolderLayout.Padding = UDim.new(0, 10)
        HolderLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
        HolderLayout.VerticalAlignment = Enum.VerticalAlignment.Top
        HolderLayout.Parent = self.NotifHolder
    end

    -- Create notification
    local Notification = Cache.new("Frame")
    Notification.Name = "Notification"
    Notification.Size = UDim2.new(1, 0, 0, 50)
    Notification.BackgroundColor3 = self.CurrentTheme.Background
    Notification.BorderSizePixel = 0
    Notification.ZIndex = 101
    Notification.BackgroundTransparency = 1
    Notification.TextTransparency = 1
    Notification.Parent = self.NotifHolder

    self:AddCorner(Notification, self.CurrentTheme.CornerRadius)
    self:AddStroke(Notification, self.CurrentTheme.Border, 1)

    -- Notification text
    local NotifText = Cache.new("TextLabel")
    NotifText.Name = "Text"
    NotifText.Size = UDim2.new(1, -20, 1, 0)
    NotifText.Position = UDim2.new(0, 10, 0, 0)
    NotifText.BackgroundTransparency = 1
    NotifText.Text = Text
    NotifText.TextColor3 = self.CurrentTheme.Text
    NotifText.TextSize = 13
    NotifText.Font = Enum.Font.Gotham
    NotifText.TextWrapped = true
    NotifText.TextXAlignment = Enum.TextXAlignment.Left
    NotifText.ZIndex = 102
    NotifText.Parent = Notification

    -- Animate in
    Notification.Position = UDim2.new(1, 20, 0, 0)
    self:Tween(Notification, {
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 0,
        TextTransparency = 0
    }, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    -- Auto destroy
    task.delay(Duration, function()
        self:Tween(Notification, {
            Position = UDim2.new(1, 20, 0, 0),
            BackgroundTransparency = 1,
            TextTransparency = 1
        }, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In, function()
            Notification:Destroy()
        end)
    end)

    return Notification
end

