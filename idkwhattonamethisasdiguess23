local SPECIAL_RARITY = { Mythic = true, Exclusive = true }
local wh_url = cfgGet("Webhook_URL", "")
local wh_autoEnabled = false
local wh_autoTask = nil
local sessionGoldTotal = 0

local function safeRead(fn)
    local ok, v = pcall(fn)
    return (ok and v ~= nil) and tostring(v) or "N/A"
end

local function extractAssetId(imageLabel)
    local ok, img = pcall(function() return imageLabel.Image end)
    if not ok then return nil end
    local n = tostring(img):match("(%d+)$")
    return n and tonumber(n)
end

local function parseNumber(str)
    if not str then return 0 end
    local cleaned = tostring(str):gsub("[^%d]", "")
    return tonumber(cleaned) or 0
end

local function gatherRewardItems()
    local normal, special = {}, {}
    local ok, container = pcall(function()
        return game:GetService("Players").LocalPlayer
            .PlayerGui.Interface.Rewards.Main.Info.Main.Items
    end)
    if not ok or not container then return normal, special end

    for _, child in ipairs(container:GetChildren()) do
        local iconOk, icon = pcall(function() return child.Main.Inner.Icon end)
        local qtyOk, qty = pcall(function() return child.Main.Inner.Quantity.Text end)
        if not iconOk or not icon then continue end

        local assetId = extractAssetId(icon)
        if not assetId then continue end

        local entry = ITEM_DB[assetId]
        local name = entry and entry[1] or string.format("Unknown [%d]", assetId)
        local rarity = entry and entry[2] or "?"
        local amount = (qtyOk and qty) or ""
        local item = { name = name, rarity = rarity, qty = amount }

        if assetId == 15147178963 then
            sessionGoldTotal = sessionGoldTotal + parseNumber(amount)
        end

        if SPECIAL_RARITY[rarity] then
            table.insert(special, item)
        else
            table.insert(normal, item)
        end
    end
    return normal, special
end

local function fmtItems(list)
    if #list == 0 then return "None" end
    local lines = {}
    for _, v in ipairs(list) do
        local prefix = (v.qty ~= "" and v.qty ~= nil) and (v.qty .. "x ") or ""
        table.insert(lines, prefix .. v.name .. " (" .. v.rarity .. ")")
    end
    return table.concat(lines, "\n")
end

local function buildWebhookBody(ov)
    ov = ov or {}
    local lp = game:GetService("Players").LocalPlayer
    local gui = lp.PlayerGui.Interface
    local username = lp.Name
    local state = ov.state or safeRead(function() return gui.Rewards.Main.Info.State.Text end)
    local titans = ov.titans or safeRead(function() return gui.Rewards.Main.Info.Main.Stats.Kills.Amount.Text end)
    local timeTaken = ov.timeTaken or safeRead(function() return gui.Rewards.Main.Info.Main.Stats.Time_Taken.Amount.Text end)
    local level = ov.level or safeRead(function() return gui.Spectate.Inner.Main.Level.Text end)
    local streak = ov.streak or safeRead(function()
        return gui.Details.Prompt.Main.List.Template_arabic_mosl.Streak.Text
    end)
    local normal, special
    if ov.items then
        normal = ov.items
        special = ov.special or {}
    else
        normal, special = gatherRewardItems()
    end
    local displaySessionGold = ov.sessionGold ~= nil and ov.sessionGold or sessionGoldTotal
    local statsBlock = string.format(
        "Level: %s\nSession Gold: %s",
        level, tostring(displaySessionGold)
    )
    local infoBlock = string.format(
        "Time Taken: %s\nTitans Killed: %s\nStreak: %s",
        timeTaken, titans, streak
    )
    local embed = {
        title = "Lunaris Rewards Logger",
        color = 11027200,
        fields = {
            { name = "User:", value = "```\n" .. username .. "\n```", inline = true },
            { name = "Total Stats:", value = "```\n" .. statsBlock .. "\n```", inline = true },
            { name = "Info:", value = "```\n" .. infoBlock .. "\n```", inline = true },
            { name = "Rewards:", value = "```\n" .. fmtItems(normal) .. "\n```", inline = true },
            { name = "Special Rewards:", value = "```\n" .. fmtItems(special) .. "\n```", inline = true },
        },
        footer = { text = "Lunaris Hub  •  " .. state },
    }
    local tsOk, ts = pcall(function() return os.date("!%Y-%m-%dT%H:%M:%SZ") end)
    if tsOk and ts then embed.timestamp = ts end
    return game:GetService("HttpService"):JSONEncode({
        username = "Lunaris Hub",
        embeds = { embed },
    })
end

local function fireWebhook(url, body)
    if not url or url == "" then warn("Webhook: URL is empty") return end
    local fn = (syn and syn.request) or http_request
    if not fn then
        warn("Webhook: No HTTP function found")
        return
    end
    local ok, err = pcall(fn, {
        Url = url,
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body = body,
    })
    if not ok then
    end
end

