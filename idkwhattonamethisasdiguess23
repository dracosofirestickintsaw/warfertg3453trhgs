    end
end

local function stopNapeTween()
    napeTweenActive = false
end

local function setTitanAnchored(titan, state)
    if not titan or not titan.Parent then return end
    for _, part in ipairs(titan:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Anchored = state
        end
    end
end

local function disableNapeJoints(nape, state)
    if not nape then return end
    for _, c in ipairs(nape:GetChildren()) do
        if c:IsA("WeldConstraint") or c:IsA("Weld") or c:IsA("Motor6D") then
            c.Enabled = not state
        end
    end
    if nape.Parent then
        for _, c in ipairs(nape.Parent:GetChildren()) do
            if c:IsA("WeldConstraint") or c:IsA("Weld") or c:IsA("Motor6D") then
                if (c:IsA("WeldConstraint") and (c.Part0 == nape or c.Part1 == nape))
                    or (not c:IsA("WeldConstraint") and (c.Part0 == nape or c.Part1 == nape)) then
                    c.Enabled = not state
                end
            end
        end
    end
end

local function startNapeOrbit(nape, hrp, titan)
    napeTweenActive = true
    task.spawn(function()
        local TweenService = game:GetService("TweenService")
        local swingDistance = 12
        local swingHeight = 0
        disableNapeJoints(nape, true)
        while napeTweenActive and nape and nape.Parent and hrp and hrp.Parent do
            nape.Size = Vector3.new(8, 7, 8)
            nape.CFrame = hrp.CFrame * CFrame.new(swingDistance, swingHeight, 0)
            local tweenLeft = TweenService:Create(nape, TweenInfo.new(0.18, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { CFrame = hrp.CFrame * CFrame.new(-swingDistance, swingHeight, 0) })
            tweenLeft:Play()
            tweenLeft.Completed:Wait()
            if not napeTweenActive then break end
            nape.CFrame = hrp.CFrame
            nape.Size = Vector3.new(150, 150, 150)
            task.wait(0.1)
            if not napeTweenActive then break end
            nape.Size = Vector3.new(8, 7, 8)
            nape.CFrame = hrp.CFrame * CFrame.new(-swingDistance, swingHeight, 0)
            local tweenRight = TweenService:Create(nape, TweenInfo.new(0.18, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { CFrame = hrp.CFrame * CFrame.new(swingDistance, swingHeight, 0) })
            tweenRight:Play()
            tweenRight.Completed:Wait()
            if not napeTweenActive then break end
            nape.CFrame = hrp.CFrame
            nape.Size = Vector3.new(150, 150, 150)
            task.wait(0.1)
            if not napeTweenActive then break end
        end
        disableNapeJoints(nape, false)
        setTitanAnchored(titan, false)
        if nape and nape.Parent then
            nape.Size = Vector3.new(8, 7, 8)
        end
    end)
end

