local function onAutoFarm(value)
    autoFarmEnabled = value
    if not value then
        stopNapeTween()
        stopClickSpam()
        if activeTween then activeTween:Cancel(); activeTween = nil end
        isTeleporting = false
        persistFreezeActive = false
        persistFreezeTarget = nil
        if persistFreezeConn then persistFreezeConn:Disconnect(); persistFreezeConn = nil end
        return
    end
    persistFreezeConn = game:GetService("RunService").Heartbeat:Connect(function()
        if not persistFreezeActive then return end
        local plr = game:GetService("Players").LocalPlayer
        local char = plr and plr.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local partTele = char:FindFirstChild("PartTele")
        if partTele then
            root.CFrame = partTele.CFrame
        elseif persistFreezeTarget then
            root.CFrame = persistFreezeTarget
        end
    end)
    task.spawn(function()
        local farmStartTime = workspace.DistributedGameTime
        local lastNotifyTime = 0
        local killingRemaining = false
        while autoFarmEnabled do
            local ok, err = pcall(function()
                local plr = game:GetService("Players").LocalPlayer
                if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
                    plr.CharacterAdded:Wait()
                    plr.Character:WaitForChild("HumanoidRootPart", 10)
                end
                local char = plr.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if not root then return end
                checkSideEffects()
                local titanCount = 0
                local titans = workspace:FindFirstChild("Titans")
                if titans then
                    for _, t in ipairs(titans:GetChildren()) do
                        if titanIsAlive(t) then titanCount = titanCount + 1 end
                    end
                end
                local titans2 = workspace:FindFirstChild("Titans")
                local defendEren = workspace:FindFirstChild("Unclimbable")
                    and workspace.Unclimbable:FindFirstChild("Objective")
                    and workspace.Unclimbable.Objective:FindFirstChild("Defend_Eren") ~= nil
                local skipWait = defendEren or (titans2 and (
                    titans2:FindFirstChild("Armored_Titan") ~= nil
                    or titans2:FindFirstChild("Female_Titan") ~= nil
                    or titans2:FindFirstChild("Colossal_Titan") ~= nil
                    or titans2:FindFirstChild("Attack_Titan") ~= nil
                ))
                if titanCount > 3 then
                    killingRemaining = false
                    farmStartTime = workspace.DistributedGameTime
                end
                if not skipWait and titanCount <= 3 and not killingRemaining and (workspace.DistributedGameTime - farmStartTime) < 20 then
                    local curRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                    if curRoot then
                        curRoot.Anchored = true
                        persistFreezeTarget = curRoot.CFrame
                    end
                    persistFreezeActive = true
                    if workspace.DistributedGameTime - lastNotifyTime >= 2 then
                        Library:Notify("Auto Farm", "Waiting till Anti Detection...", 2)
                        lastNotifyTime = workspace.DistributedGameTime
                    end
                    task.wait(0.5)
                    return
                end
                local curRoot2 = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if curRoot2 then curRoot2.Anchored = false end
                if titanCount <= 3 and (workspace.DistributedGameTime - farmStartTime) >= 20 then
                    killingRemaining = true
                end
                local titan = getClosestTitan(root)
                if not titan then return end
                local head = titan:FindFirstChild("Head")
                if not head then return end
                if not isSpecialTitan(titan) then setTitanAnchored(titan, true) end
                local aboveHeadCF = CFrame.new(head.Position + Vector3.new(0, 300, 0))
                persistFreezeTarget = aboveHeadCF
                topos(aboveHeadCF)
                local arrivalTimeout = tick()
                while autoFarmEnabled do
                    local curRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                    if not curRoot then break end
                    if (curRoot.Position - aboveHeadCF.Position).Magnitude < 15 then break end
                    if tick() - arrivalTimeout > 6 then break end
                    wait(0.05)
                end
                if activeTween then activeTween:Cancel(); activeTween = nil end
                isTeleporting = false
                if plr.Character and plr.Character:FindFirstChild("PartTele") then
                    plr.Character.PartTele:Destroy()
                end
                if not autoFarmEnabled then return end
                local liveHead = titan:FindFirstChild("Head")
                if not liveHead then return end
                local frozenCF = CFrame.new(liveHead.Position + Vector3.new(0, 300, 0))
                local curRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if not curRoot then return end
                curRoot.CFrame = frozenCF
                persistFreezeTarget = frozenCF
                persistFreezeActive = true
                local nape = getNapeForTitan(titan)
                if not nape then
                    persistFreezeActive = false
                    return
                end
                stopNapeTween()
                nape.CFrame = curRoot.CFrame
                startNapeOrbit(nape, curRoot, titan)
                local farmRemote = game:GetService("ReplicatedStorage").Assets.Remotes.POST
                local killTimeout = tick()
                while autoFarmEnabled and titanIsAlive(titan) do
                    checkSideEffects()
                    if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
                        plr.CharacterAdded:Wait()
                        plr.Character:WaitForChild("HumanoidRootPart", 10)
                    end
                    local liveHead = titan:FindFirstChild("Head")
                    if liveHead then
                        frozenCF = CFrame.new(liveHead.Position + Vector3.new(0, 300, 0))
                        persistFreezeTarget = frozenCF
                        local curRootKill = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                        if curRootKill then curRootKill.CFrame = frozenCF end
                    end
                    pcall(function()
                        farmRemote:FireServer("Attacks", "Slash", true)
                    end)
                    pcall(function()
                        farmRemote:FireServer("Hitboxes", "Register", nape, math.random(1000, 1050), 0)
                    end)
                    if tick() - killTimeout > 60 then break end
                    task.wait(0.5)
                end
                stopNapeTween()
            end)
            if not ok then
            end
            task.wait(0.1)
        end
        persistFreezeActive = false
        persistFreezeTarget = nil
        if persistFreezeConn then persistFreezeConn:Disconnect(); persistFreezeConn = nil end
    end)
end

