local function onAutoLog(value)
    wh_autoEnabled = value
    if wh_autoTask then
        wh_autoTask = nil
    end
    if not value then return end
    local taskRef = {}
    wh_autoTask = taskRef
    task.spawn(function()
        local prevVisible = false
        while wh_autoEnabled and wh_autoTask == taskRef do
            local ok, vis = pcall(function()
                return game:GetService("Players").LocalPlayer
                    .PlayerGui.Interface.Rewards.Visible
            end)
            if ok then
                if vis and not prevVisible then
                    task.wait(0.6)
                    if wh_url ~= "" and wh_autoEnabled then
                        task.spawn(function()
                            local body = buildWebhookBody()
                            fireWebhook(wh_url, body)
                        end)
                    end
                end
                prevVisible = vis
            end
            task.wait(0.15)
        end
    end)
end

