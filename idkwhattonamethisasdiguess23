-- Create a tween with preset animations
function MyCustomUI:Tween(Object, Properties, Time, EasingStyle, EasingDirection, Callback)
    local TweenInfo = TweenInfo.new(
        Time or self.Animation.TweenTime,
        EasingStyle or self.Animation.EasingStyle,
        EasingDirection or self.Animation.EasingDirection
    )

    local Tween = Services.TweenService:Create(Object, TweenInfo, Properties)
    Tween:Play()

    if Callback then
        Tween.Completed:Connect(Callback)
    end

    return Tween
end

-- Fade in animation
function MyCustomUI:FadeIn(Object, Time, Callback)
    Time = Time or self.Animation.TweenTime

    -- Handle different object types
    if Object:IsA("TextLabel") or Object:IsA("TextButton") then
        Object.TextTransparency = 1
        self:Tween(Object, {TextTransparency = 0}, Time, nil, nil, Callback)
    end

    if Object:IsA("Frame") or Object:IsA("ImageLabel") then
        Object.BackgroundTransparency = 1
        self:Tween(Object, {BackgroundTransparency = 0}, Time, nil, nil, Callback)
    end

    if Object:IsA("UIStroke") then
        Object.Transparency = 1
        self:Tween(Object, {Transparency = 0}, Time, nil, nil, Callback)
    end
end

-- Fade out animation
function MyCustomUI:FadeOut(Object, Time, Callback)
    Time = Time or self.Animation.TweenTime

    if Object:IsA("TextLabel") or Object:IsA("TextButton") then
        self:Tween(Object, {TextTransparency = 1}, Time, nil, nil, Callback)
    end

    if Object:IsA("Frame") or Object:IsA("ImageLabel") then
        self:Tween(Object, {BackgroundTransparency = 1}, Time, nil, nil, Callback)
    end

    if Object:IsA("UIStroke") then
        self:Tween(Object, {Transparency = 1}, Time, nil, nil, Callback)
    end
end

