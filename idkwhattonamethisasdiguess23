local function onAutoFarmInstant(value)
    multiNapeEnabled = value

    if not value then
        multiNapeClickActive = false
        if multiNapeFreezeConn then multiNapeFreezeConn:Disconnect(); multiNapeFreezeConn = nil end
        multiNapeThreads = {}
        return
    end

    task.spawn(function()
        local plr = game:GetService("Players").LocalPlayer
        local remote = game:GetService("ReplicatedStorage").Assets.Remotes.POST
        local freezeTarget = nil

        multiNapeFreezeConn = game:GetService("RunService").Heartbeat:Connect(function()
            if not multiNapeEnabled then return end
            local c = plr.Character
            if not c then return end
            local r = c:FindFirstChild("HumanoidRootPart")
            if not r then return end
            local partTele = c:FindFirstChild("PartTele")
            if partTele and isTeleporting then
                r.CFrame = partTele.CFrame
            elseif freezeTarget then
                r.CFrame = freezeTarget
            end
        end)

        local farmStartTime = workspace.DistributedGameTime
        local lastNotifyTime = 0
        local killingRemaining = false
        while multiNapeEnabled do
            pcall(checkSideEffects)

            local char = plr.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(0.1); continue end

            local titans = workspace:FindFirstChild("Titans")
            if not titans then task.wait(0.5); continue end

            local titanCount = 0
            for _, t in ipairs(titans:GetChildren()) do
                if titanIsAlive(t) then titanCount = titanCount + 1 end
            end

            local defendEren2 = workspace:FindFirstChild("Unclimbable")
                and workspace.Unclimbable:FindFirstChild("Objective")
                and workspace.Unclimbable.Objective:FindFirstChild("Defend_Eren") ~= nil
            local skipWait = defendEren2 or (titans and (
                titans:FindFirstChild("Armored_Titan") ~= nil
                or titans:FindFirstChild("Female_Titan") ~= nil
                or titans:FindFirstChild("Colossal_Titan") ~= nil
                or titans:FindFirstChild("Attack_Titan") ~= nil
            ))
            if titanCount > 3 then
                killingRemaining = false
                farmStartTime = workspace.DistributedGameTime
            end
            if not skipWait and titanCount <= 3 and not killingRemaining and (workspace.DistributedGameTime - farmStartTime) < 20 then
                local curRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if curRoot then
                    curRoot.Anchored = true
                    freezeTarget = curRoot.CFrame
                end
                if workspace.DistributedGameTime - lastNotifyTime >= 2 then
                    Library:Notify("Auto Farm Instant", "Waiting till Anti Detection", 2)
                    lastNotifyTime = workspace.DistributedGameTime
                end
                task.wait(0.5)
                continue
            end
            local curRoot2 = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if curRoot2 then curRoot2.Anchored = false end
            if titanCount <= 3 and (workspace.DistributedGameTime - farmStartTime) >= 20 then
                killingRemaining = true
            end
            local closest = getClosestTitan(root)
            if not closest then task.wait(0.5); continue end

            local closestHead = closest:FindFirstChild("Head")
            local closestRoot = closest:FindFirstChild("HumanoidRootPart") or closest:FindFirstChildWhichIsA("BasePart")
            if not closestRoot or not closestHead then task.wait(0.1); continue end

            if not isSpecialTitan(closest) then setTitanAnchored(closest, true) end

            local aboveCF = CFrame.new(closestHead.Position + Vector3.new(0, 300, 0))

            local playerRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if playerRoot then playerRoot.Anchored = true end

            freezeTarget = aboveCF
            topos(aboveCF, nil, instantTweenSpeed)

            local arrivalTimeout = tick()
            while multiNapeEnabled do
                local curRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if not curRoot then break end
                if (curRoot.Position - aboveCF.Position).Magnitude < 15 then break end
                if tick() - arrivalTimeout > 10 then break end
                task.wait()
            end

            if activeTween then activeTween:Cancel(); activeTween = nil end
            isTeleporting = false
            if plr.Character:FindFirstChild("PartTele") then
                plr.Character.PartTele:Destroy()
            end

            local partTele = Instance.new("Part", plr.Character)
            partTele.Name = "PartTele"
            partTele.Anchored = true
            partTele.Transparency = 1
            partTele.CanCollide = false
            partTele.Size = Vector3.new(10, 1, 10)
            partTele.CFrame = aboveCF
            isTeleporting = true

            local headTrackConn = game:GetService("RunService").Heartbeat:Connect(function()
                if not multiNapeEnabled then return end
                local h = closest:FindFirstChild("Head")
                if h and partTele and partTele.Parent then
                    local newCF = CFrame.new(h.Position + Vector3.new(0, 300, 0))
                    partTele.CFrame = newCF
                    freezeTarget = newCF
                end
            end)

            local nearbyNapes = {}
            for _, titan in ipairs(titans:GetChildren()) do
                if not titanIsAlive(titan) then continue end
                local titanRoot = titan:FindFirstChild("HumanoidRootPart") or titan:FindFirstChildWhichIsA("BasePart")
                if titanRoot then
                    local dist2 = (closestRoot.Position - titanRoot.Position).Magnitude
                    if dist2 <= 1000 then
                        local nape = getNapeForTitan(titan)
                        if nape then table.insert(nearbyNapes, nape) end
                    end
                end
            end

            pcall(function()
                remote:FireServer("Attacks", "Slash", true)
            end)
            for _, nape in ipairs(nearbyNapes) do
                if not multiNapeEnabled then break end
                pcall(function()
                    remote:FireServer("Hitboxes", "Register", nape, math.random(1000, 1050), 0)
                end)
            end
            local closestNape = getNapeForTitan(closest)
            while multiNapeEnabled and titanIsAlive(closest) do
                pcall(checkSideEffects)
                pcall(function()
                    remote:FireServer("Attacks", "Slash", true)
                end)
                local curRootNow = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if curRootNow then
                    local titans2 = workspace:FindFirstChild("Titans")
                    if titans2 then
                        for _, t in ipairs(titans2:GetChildren()) do
                            if not titanIsAlive(t) then continue end
                            local tr = t:FindFirstChild("HumanoidRootPart") or t:FindFirstChildWhichIsA("BasePart")
                            if tr and (closestRoot.Position - tr.Position).Magnitude <= 1000 then
                                local tn = getNapeForTitan(t)
                                if tn then
                                    pcall(function()
                                        remote:FireServer("Hitboxes", "Register", tn, math.random(1000, 1050), 0)
                                    end)
                                end
                            end
                        end
                    end
                end
                task.wait(0.5)
            end

            headTrackConn:Disconnect()
            isTeleporting = false
            if plr.Character and plr.Character:FindFirstChild("PartTele") then
                plr.Character.PartTele:Destroy()
            end

            task.wait()
            freezeTarget = nil
            setTitanAnchored(closest, false)
            local playerRoot2 = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if playerRoot2 then playerRoot2.Anchored = false end
            task.wait()
        end

        freezeTarget = nil
        multiNapeClickActive = false
        if multiNapeFreezeConn then multiNapeFreezeConn:Disconnect(); multiNapeFreezeConn = nil end
    end)
end

