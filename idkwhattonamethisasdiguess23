function MyCustomUI:SaveConfig(Name)
    local Config = {}

    for Flag, Value in pairs(self.Flags) do
        Config[Flag] = Value
    end

    local FilePath = self.Config.ConfigFolder .. "/" .. Name .. ".json"

    local Success, Error = pcall(function()
        writefile(FilePath, Services.HttpService:JSONEncode(Config))
    end)

    if Success then
        self:Notify({Text = "Config saved: " .. Name, Duration = 2})
    else
        self:Notify({Text = "Failed to save config", Duration = 2})
    end

    return Success
end

function MyCustomUI:LoadConfig(Name)
    local FilePath = self.Config.ConfigFolder .. "/" .. Name .. ".json"

    if not isfile(FilePath) then
        self:Notify({Text = "Config not found: " .. Name, Duration = 2})
        return false
    end

    local Success, Data = pcall(function()
        return Services.HttpService:JSONDecode(readfile(FilePath))
    end)

    if Success and Data then
        for Flag, Value in pairs(Data) do
            self.Flags[Flag] = Value
            -- Update UI elements here if needed
        end

        self:Notify({Text = "Config loaded: " .. Name, Duration = 2})
        return true
    end

    self:Notify({Text = "Failed to load config", Duration = 2})
    return false
end

function MyCustomUI:GetConfigs()
    local Configs = {}

    if listfiles and listfiles(self.Config.ConfigFolder) then
        for _, File in ipairs(listfiles(self.Config.ConfigFolder)) do
            if File:match("%.json$") then
                local ConfigName = File:match("([^/]+)%.json$")
                Cache.insert(Configs, ConfigName)
            end
        end
    end

    return Configs
end

-- ============================================
-- PART 10: CLEANUP SYSTEM
-- ============================================

function MyCustomUI:Unload()
    -- Disconnect all tracked connections
    for _, Connection in ipairs(self.Connections) do
        if Connection.Connected then
            Connection:Disconnect()
        end
    end

    -- Destroy all windows
    for _, Window in ipairs(self.Windows) do
        if Window.Instance and Window.Instance.Parent then
            Window.Instance:Destroy()
        end
    end

    -- Destroy notification holder
    if self.NotifHolder and self.NotifHolder.Parent then
        self.NotifHolder:Destroy()
    end

    -- Clear all tables
    self.Windows = {}
    self.Pages = {}
    self.Flags = {}
    self.Connections = {}
end

