local autoSkillEnabled = false
local autoSkillConn = nil

local skillLeftPath = "Skill Cooldown"
local skillMiddlePath = "Damage"
local skillRightPath = "Damage Reduction"
local skillPriority = "Left"
local skillRanges = {
    Middle = {
        base   = { min = 1,  max = 13 },
        Damage    = { min = 26, max = 37 },
        Criticals = { min = 14, max = 25 },
    },
    Right = {
        base            = { min = 38, max = 45 },
        Health          = { min = 46, max = 57 },
        ["Damage Reduction"] = { min = 58, max = 69 },
    },
    Left = {
        base            = { min = 70, max = 80 },
        ["Health Regen"]    = { min = 81, max = 89 },
        ["Skill Cooldown"]  = { min = 90, max = 98 },
    },
}

local function getSkillsForPath(path, chosenOption)
    local range = skillRanges[path]
    if not range then return {} end
    local skills = {}
    for i = range.base.min, range.base.max do
        table.insert(skills, i)
    end
    local sub = range[chosenOption]
    if sub then
        for i = sub.min, sub.max do
            table.insert(skills, i)
        end
    end
    return skills
end

local function unlockSkill(skillId)
    pcall(function()
        game:GetService("ReplicatedStorage").Assets.Remotes.GET:InvokeServer(
            "S_Equipment",
            "Unlock",
            { tostring(skillId) }
        )
    end)
end

local function getPriorityOrder()
    if skillPriority == "Left" then
        return { "Left", "Middle", "Right" }
    elseif skillPriority == "Middle" then
        return { "Middle", "Left", "Right" }
    else
        return { "Right", "Middle", "Left" }
    end
end

local function getOptionForPath(path)
    if path == "Left" then return skillLeftPath
    elseif path == "Middle" then return skillMiddlePath
    else return skillRightPath end
end

local function onAutoSkillTree(value)
    autoSkillEnabled = value
    if autoSkillConn then
        autoSkillConn:Disconnect()
        autoSkillConn = nil
    end
    if not value then return end

    task.spawn(function()
        while autoSkillEnabled do
            local order = getPriorityOrder()
            for _, path in ipairs(order) do
                local option = getOptionForPath(path)
                local skills = getSkillsForPath(path, option)
                for _, skillId in ipairs(skills) do
                    if not autoSkillEnabled then return end
                    unlockSkill(skillId)
                end
            end
            task.wait(1)
        end
    end)
end

