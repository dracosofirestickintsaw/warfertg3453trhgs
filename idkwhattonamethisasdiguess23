    Window.PageContainer.Position = UDim2.new(0, 135, 0, 0)
    Window.PageContainer.BackgroundTransparency = 1
    Window.PageContainer.ZIndex = 1
    Window.PageContainer.Parent = Window.Content

    -- ============================================
    -- DRAGGING SYSTEM
    -- ============================================

    Window.Dragging = false
    Window.DragStart = nil
    Window.StartPos = nil

    local function StartDrag(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or
           Input.UserInputType == Enum.UserInputType.Touch then
            Window.Dragging = true
            Window.DragStart = Input.Position
            Window.StartPos = Window.Instance.Position
        end
    end

    local function UpdateDrag(Input)
        if Window.Dragging then
            local Delta = Input.Position - Window.DragStart
            Window.Instance.Position = UDim2.new(
                Window.StartPos.X.Scale, Window.StartPos.X.Offset + Delta.X,
                Window.StartPos.Y.Scale, Window.StartPos.Y.Offset + Delta.Y
            )
        end
    end

    local function EndDrag(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or
           Input.UserInputType == Enum.UserInputType.Touch then
            Window.Dragging = false
        end
    end

    Window.TitleBar.InputBegan:Connect(StartDrag)
    Window.TitleBar.InputEnded:Connect(EndDrag)
