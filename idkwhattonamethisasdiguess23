                    NameLabel.Size            = UDim2.new(1, -8, 0, 30)
                    NameLabel.Text            = Section.Name
                    NameLabel.TextColor3      = TextOff
                    NameLabel.TextSize        = 18
                    NameLabel.TextXAlignment  = Enum.TextXAlignment.Left
                    NameLabel.Parent          = SectionFrame

                    -- Inner content frame (auto-sizes with children)
                    local Content = Instance.new("Frame")
                    Content.BackgroundTransparency = 1
                    Content.Position               = UDim2.fromOffset(0, 33)
                    Content.Size                   = UDim2.new(1, 0, 0, 0)
                    Content.AutomaticSize          = Enum.AutomaticSize.Y
                    Content.Parent                 = SectionFrame

                    Section.Items.Content      = Content
                    Section.Items.SectionFrame = SectionFrame
                end

                return Section
            end

            table.insert(Tab.SubPages, SubPage)
            return SubPage
        end

        table.insert(Window.Tabs, Tab)
        return Tab
    end

    return Window
end

return Library
