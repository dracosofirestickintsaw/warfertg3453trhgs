function MyCustomUI:CreateSlider(Section, Data)
    local Name = Data.Name or "Slider"
    local Min = Data.Min or 0
    local Max = Data.Max or 100
    local Default = Data.Default or (Min + Max) / 2
    local Suffix = Data.Suffix or ""
    local Decimals = Data.Decimals or 0
    local Flag = Data.Flag
    local Callback = Data.Callback or function() end

    -- Generate flag if not provided
    if not Flag then
        Flag = "slider_" .. Cache.format("%.0f", tick())
    end

    local Slider = {}
    Slider.Name = Name
    Slider.Flag = Flag
    Slider.Min = Min
    Slider.Max = Max
    Slider.Value = Default
    Slider.Suffix = Suffix
    Slider.Decimals = Decimals
    Slider.Callback = Callback
    Slider.Dragging = false

    -- Container
    Slider.Container = Cache.new("Frame")
    Slider.Container.Name = Name
    Slider.Container.Size = UDim2.new(1, 0, 0, 55)
    Slider.Container.BackgroundTransparency = 1
    Slider.Container.ZIndex = 3
    Slider.Container.Parent = Section.Content

    -- Header
    Slider.Header = Cache.new("Frame")
    Slider.Header.Name = "Header"
    Slider.Header.Size = UDim2.new(1, 0, 0, 20)
    Slider.Header.BackgroundTransparency = 1
    Slider.Header.ZIndex = 4
    Slider.Header.Parent = Slider.Container

    -- Label
    Slider.Label = Cache.new("TextLabel")
    Slider.Label.Name = "Label"
    Slider.Label.Size = UDim2.new(1, -50, 1, 0)
    Slider.Label.BackgroundTransparency = 1
    Slider.Label.Text = Name
    Slider.Label.TextColor3 = self.CurrentTheme.Text
    Slider.Label.TextSize = 13
    Slider.Label.Font = Enum.Font.Gotham
    Slider.Label.TextXAlignment = Enum.TextXAlignment.Left
    Slider.Label.ZIndex = 5
    Slider.Label.Parent = Slider.Header

    -- Value display
    Slider.ValueLabel = Cache.new("TextLabel")
    Slider.ValueLabel.Name = "Value"
    Slider.ValueLabel.Size = UDim2.new(0, 45, 1, 0)
    Slider.ValueLabel.Position = UDim2.new(1, -47, 0, 0)
    Slider.ValueLabel.BackgroundTransparency = 1
    Slider.ValueLabel.Text = Cache.format("%." .. Decimals .. "f", Default) .. Suffix
    Slider.ValueLabel.TextColor3 = self.CurrentTheme.Accent
    Slider.ValueLabel.TextSize = 12
    Slider.ValueLabel.Font = Enum.Font.GothamBold
    Slider.ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
    Slider.ValueLabel.ZIndex = 5
    Slider.ValueLabel.Parent = Slider.Header

    -- Track
    Slider.Track = Cache.new("Frame")
    Slider.Track.Name = "Track"
    Slider.Track.Size = UDim2.new(1, 0, 0, 8)
    Slider.Track.Position = UDim2.new(0, 0, 0, 30)
    Slider.Track.BackgroundColor3 = self.CurrentTheme.SliderTrack
    Slider.Track.BorderSizePixel = 0
    Slider.Track.ZIndex = 4
    Slider.Track.Parent = Slider.Container

    self:AddCorner(Slider.Track, UDim.new(0, 4))

    -- Fill
    Slider.Fill = Cache.new("Frame")
    Slider.Fill.Name = "Fill"
    Slider.Fill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
    Slider.Fill.BackgroundColor3 = self.CurrentTheme.SliderFill
    Slider.Fill.BorderSizePixel = 0
    Slider.Fill.ZIndex = 5
    Slider.Fill.Parent = Slider.Track

    self:AddCorner(Slider.Fill, UDim.new(0, 4))

    -- Handle
    Slider.Handle = Cache.new("Frame")
    Slider.Handle.Name = "Handle"
    Slider.Handle.Size = UDim2.new(0, 16, 0, 16)
    Slider.Handle.Position = UDim2.new((Default - Min) / (Max - Min), -8, 0.5, 0)
    Slider.Handle.AnchorPoint = Vector2.new(0.5, 0.5)
    Slider.Handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Slider.Handle.BorderSizePixel = 0
    Slider.Handle.ZIndex = 6
    Slider.Handle.Parent = Slider.Track

    self:AddCorner(Slider.Handle, UDim.new(0, 4))
    self:AddStroke(Slider.Handle, self.CurrentTheme.Border, 1)

    -- Set method
    function Slider:Set(Value)
        Value = Cache.clamp(Value, Min, Max)
        self.Value = Value

        local Percent = (Value - Min) / (Max - Min)
        self.Fill.Size = UDim2.new(Percent, 0, 1, 0)
        self.Handle.Position = UDim2.new(Percent, 0, 0.5, 0)
        self.ValueLabel.Text = Cache.format("%." .. Decimals .. "f", Value) .. Suffix

        self.Callback(Value)
        self:OnChanged(Value)
    end

    Slider.OnChanged = function() end
    function Slider:OnChanged(Callback)
        self._OnChanged = Callback
    end

    -- Dragging logic
    local function UpdateSlider(Input)
        local RelativePos = (Input.Position.X - Slider.Track.AbsolutePosition.X) / Slider.Track.AbsoluteSize.X
        RelativePos = Cache.clamp(RelativePos, 0, 1)
        local NewValue = Min + (Max - Min) * RelativePos
        Slider:Set(NewValue)
    end

    Slider.Track.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or
           Input.UserInputType == Enum.UserInputType.Touch then
            Slider.Dragging = true
            UpdateSlider(Input)
        end
    end)

    Slider.Track.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or
           Input.UserInputType == Enum.UserInputType.Touch then
            Slider.Dragging = false
        end
    end)

    Services.UserInputService.InputChanged:Connect(function(Input)
        if Slider.Dragging and
           (Input.UserInputType == Enum.UserInputType.MouseMovement or
            Input.UserInputType == Enum.UserInputType.Touch) then
            UpdateSlider(Input)
        end
    end)

    -- Store in flags
    self.Flags[Flag] = Default
    Cache.insert(Section.Elements, Slider)

    return Slider
end

