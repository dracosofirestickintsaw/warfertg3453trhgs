            ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
            ContentLayout.Padding = UDim.new(0, 5)
            ContentLayout.Parent = Section.Content

            -- Track section
            Cache.insert(self.Elements, Section)

            return Section
        end

        -- Select first page by default
        if #self.Window.Pages == 0 then
            SelectPage()
        end

        Cache.insert(self.Pages, Page)
        Cache.insert(self.Window.Pages, Page)
        Cache.insert(MyCustomUI.Pages, Page)

        return Page
    end

    -- Add drag input for smooth dragging
    Window.TitleBar.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            local DragInput = Input
            Window.DragStart = Input.Position
            Window.StartPos = Window.Instance.Position
        end
    end)

    return Window
end

