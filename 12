    function Library:Tween(p, Info, Raw)
        local O = Raw or self.Instance
        if not O then
            return nil
        end
        Info = Info
            or TweenInfo.new(
                Library.Animation.Time,
                Enum.EasingStyle[Library.Animation.Style],
                Enum.EasingDirection[Library.Animation.Direction]
            )
        local t = TweenService:Create(O, Info, p)
        t:Play()
        return t
    end

    local function FadeOne(Object, Props, Visible)
        for _, Prop in ipairs(Props) do
            local ov = Object[Prop]
            if Visible then
                Object[Prop] = 1
                TweenService:Create(
                    Object,
                    TweenInfo.new(Library.Animation.Time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                    { [Prop] = ov }
                ):Play()
            else
                TweenService:Create(
                    Object,
                    TweenInfo.new(Library.Animation.Time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                    { [Prop] = 1 }
                ):Play()
            end
        end
    end

    function Library:FadeDescendants(Show, Finish)
        local root = self.Instance
        root.Visible = true
        local descendants = root:GetDescendants()
        table.insert(descendants, root)
        local lastTween
        for _, g in ipairs(descendants) do
            if g:IsA("TextLabel") or g:IsA("TextButton") or g:IsA("TextBox") then
                FadeOne(g, { "TextTransparency" }, Show)
                lastTween = nil
            elseif g:IsA("ImageLabel") or g:IsA("ImageButton") then
                FadeOne(g, { "ImageTransparency" }, Show)
            elseif g:IsA("GuiObject") then
                if g.BackgroundTransparency < 1 then
                    FadeOne(g, { "BackgroundTransparency" }, Show)
                end
            end
        end
        task.delay(Library.Animation.Time, function()
            if not Show then
                root.Visible = false
            end
            if Finish then
                Finish()
            end
        end)
    end

    function Library:Connect(signalName, Callback)
        local hold = {}
        Library:Thread(function()
            local inst = self.Instance
            if typeof(signalName) == "string" and inst and inst[signalName] then
                if IsMobile and (signalName == "MouseButton1Down" or signalName == "MouseButton1Click") then
                    local last = 0
                    local function fire(...)
                        local t = tick()
                        if t - last < 0.15 then
                            return
                        end
                        last = t
                        Callback(...)
                    end
                    local n1 = inst[signalName]:Connect(fire)
                    local n2 = inst.InputBegan:Connect(function(inpt)
                        if inpt.UserInputType == Enum.UserInputType.Touch or inpt.UserInputType == Enum.UserInputType.MouseButton1 then
                            fire(inpt)
                        end
                    end)
                    hold.Connection = {
                        Disconnect = function()
                            pcall(function()
                                n1:Disconnect()
                            end)
                            pcall(function()
                                n2:Disconnect()
                            end)
                        end,
                    }
                else
                    hold.Connection = inst[signalName]:Connect(Callback)
                end
            elseif typeof(signalName) ~= "string" then
                hold.Connection = signalName:Connect(Callback)
            end
        end)
        table.insert(Library.Connections, hold)
        return hold
    end

    function Library:Thread(fn)
        local cr = coroutine.create(fn)
        coroutine.resume(cr)
        table.insert(Library.Threads, cr)
    end

