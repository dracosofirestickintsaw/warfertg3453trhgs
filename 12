        RootSf.Instance.UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder

        SP.Scroll = RootSf
        SP._Lbl = Lb

        table.insert(Page.SubPages, SP)

        function SP:Sel()
            for _, O in ipairs(Page.SubPages) do
                O.Active = O == SP
                O.Scroll.Instance.Visible = O == SP
                if O._Lbl then
                    TweenService:Create(
                        O._Lbl,
                        TweenInfo.new(Library.Animation.Time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                        { TextColor3 = (O == SP) and C.Accent or C.Muted }
                    ):Play()
                end
            end
            Page.ActiveSub = SP
            W:_SubUnderline(Btn)
            W:_LayoutSub(Page)
        end

        Btn.MouseButton1Click:Connect(function()
            SP:Sel()
        end)

        function SP:Section(Prm)
            return Library.Section(SP, Prm)
        end

        if #Page.SubPages == 1 and Page.Active then
            task.defer(function()
                SP:Sel()
            end)
        end

        return setmetatable(SP, Library)
    end

    function Library.Section(Sub, Params)
        Params = Params or {}
        local SecName = Params.Name or Params.name or "section"
        local ScrollInst = Sub.Scroll.Instance

        local Hold = Instance.new("Frame")
        Hold.BackgroundTransparency = 1
        Hold.AutomaticSize = Enum.AutomaticSize.Y
        Hold.Size = UDim2.new(1, -22, 0, 0)
        Hold.Parent = ScrollInst

        local Top = Instance.new("Frame")
        Top.Size = UDim2.new(1, 0, 0, 43)
        Top.BackgroundColor3 = C.Top
        Top.BorderSizePixel = 0
        Top.Parent = Hold
        local ucx = Instance.new("UICorner")
        ucx.CornerRadius = UDim.new(0, 5)
        ucx.Parent = Top

        local St = Instance.new("TextLabel")
        St.BackgroundTransparency = 1
        St.Position = UDim2.fromOffset(13, 5)
        St.Size = UDim2.new(1, -20, 0, 32)
        St.FontFace = Library.Font
        St.TextSize = math.max(Library.FontSize + 6, 20)
        St.TextXAlignment = Enum.TextXAlignment.Left
        St.Text = string.lower(SecName)
