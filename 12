local function IsAssetId(iconName)
    return type(iconName) == "string" and (iconName:match("^rbxassetid://") or iconName:match("^%d+$"))
end

local function GetAssetImage(iconName)
    if type(iconName) == "string" and iconName:match("^%d+$") then
        return "rbxassetid://" .. iconName
    end
    return iconName
end

local function ApplyIcon(container, iconName, size, tint)
    if not iconName or iconName == "" then
        return
    end
    tint = tint or Color3.fromRGB(164, 139, 242)
    if IsAssetId(iconName) then
        local img = Instance.new("ImageLabel")
        img.BackgroundTransparency = 1
        img.Size = size or UDim2.fromScale(1, 1)
        img.AnchorPoint = Vector2.new(0.5, 0.5)
        img.Position = UDim2.fromScale(0.5, 0.5)
        img.Image = GetAssetImage(iconName)
        img.ImageColor3 = tint
        img.BorderSizePixel = 0
        img.Parent = container
        return
    end
    if Icons then
        local ok, pack = pcall(function()
            return Icons.Image({
                Icon = iconName,
                Size = size or UDim2.fromScale(1, 1),
                Colors = { tint },
            })
        end)
        if ok and pack and pack.IconFrame then
            local fr = pack.IconFrame
            fr.BackgroundTransparency = 1
            fr.AnchorPoint = Vector2.new(0.5, 0.5)
            fr.Position = UDim2.fromScale(0.5, 0.5)
            fr.BorderSizePixel = 0
            fr.Parent = container
        end
    end
end

