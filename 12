    function Library:Create(className, Props)
        local Wrap = {
            Instance = Instance.new(className),
        }

        if type(Props) ~= "table" then
            return setmetatable(Wrap, Library)
        end

        for Prop, Value in Props do
            if Prop == "FontFace" then
                Wrap.Instance.FontFace = Library.Font
            elseif Prop == "TextSize" then
                Wrap.Instance.TextSize = Library.FontSize
            elseif Prop == "Name" then
                Wrap.Instance.Name = "\0"
            elseif className == "TextButton" and Prop == "AutoButtonColor" then
                Wrap.Instance.AutoButtonColor = false
            elseif className == "TextButton" and Prop == "Text" then
                Wrap.Instance.Text = ""
            else
                Wrap.Instance[Prop] = Value
            end
        end

        return setmetatable(Wrap, Library)
    end

    function Library:IsMouseOverFrame()
        local o = self.Instance
        if not o.Visible then
            return false
        end
        local inset = GuiService:GetGuiInset()
        local gx, gy = Mouse.X, Mouse.Y - inset.Y
        local p, s = o.AbsolutePosition, o.AbsoluteSize
        return gx >= p.X and gx <= p.X + s.X and gy >= p.Y and gy <= p.Y + s.Y
    end

    function Library:MakeDraggable()
        local Gui = self.Instance
        local Dragging = false
        local DragStart
        local StartPosition
        local function Set(Input)
            local d = Input.Position - DragStart
            local nx = StartPosition.X.Offset + d.X
            local ny = StartPosition.Y.Offset + d.Y
            setmetatable({ Instance = Gui }, Library):Tween(
                { Position = UDim2.new(StartPosition.X.Scale, nx, StartPosition.Y.Scale, ny) },
                TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
            )
        end
        local InputChangedConn
        self:Connect("InputBegan", function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                DragStart = Input.Position
                StartPosition = Gui.Position
                if InputChangedConn then
                    return
                end
                InputChangedConn = Input.Changed:Connect(function()
                    if Input.UserInputState == Enum.UserInputState.End then
                        Dragging = false
                        InputChangedConn:Disconnect()
                        InputChangedConn = nil
                    end
                end)
            end
        end)

        Library:Connect(UserInputService.InputChanged, function(Input)
            if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                Set(Input)
            end
        end)
    end

