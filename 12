        local Inner = Instance.new("Frame")
        Inner.BackgroundTransparency = 1
        Inner.Position = UDim2.fromOffset(0, 48)
        Inner.Size = UDim2.new(1, 0, 0, 0)
        Inner.AutomaticSize = Enum.AutomaticSize.Y
        Inner.Parent = Hold

        local pl = Instance.new("UIListLayout")
        pl.Padding = UDim.new(0, 22)
        pl.HorizontalAlignment = Enum.HorizontalAlignment.Center
        pl.SortOrder = Enum.SortOrder.LayoutOrder
        pl.Parent = Inner

        local Sec = { Inner = Inner, Sub = Sub }

        function Sec:Toggle(P)
            P = P or {}
            local NM = P.Name or P.name or "toggle"
            local Flag = P.Flag or P.flag or NM
            local Def = P.Default ~= nil and P.Default or (P.default ~= nil and P.default or false)
            local CB = P.Callback or P.callback or function() end

            local Row = Instance.new("Frame")
            Row.BackgroundTransparency = 1
            Row.Size = UDim2.new(1, -26, 0, 22)
            Row.Parent = Inner

            local Hit = Instance.new("TextButton")
            Hit.Text = ""
            Hit.BackgroundTransparency = 1
            Hit.Size = UDim2.new(1, 0, 1, 0)
            Hit.Parent = Row

            local Box = Instance.new("Frame")
            Box.Size = UDim2.fromOffset(18, 18)
            Box.Position = UDim2.new(0, 0, 0.5, -9)
            Box.BorderSizePixel = 0
            Box.Parent = Row
            local boxRnd = Instance.new("UICorner")
            boxRnd.CornerRadius = UDim.new(0.1, 1)
            boxRnd.Parent = Box

            local Chk = Instance.new("ImageLabel")
            Chk.BackgroundTransparency = 1
            Chk.Image = "rbxassetid://10709790644"
            Chk.Size = UDim2.fromOffset(14, 14)
            Chk.Position = UDim2.new(0, 2, 0.5, -7)
            Chk.Visible = false
            Chk.Parent = Box

            local Lbl = Instance.new("TextLabel")
            Lbl.BackgroundTransparency = 1
            Lbl.FontFace = Library.Font
            Lbl.TextSize = Library.FontSize
            Lbl.Position = UDim2.fromOffset(26, 0)
            Lbl.Size = UDim2.new(1, -30, 1, 0)
            Lbl.Text = NM
            Lbl.TextXAlignment = Enum.TextXAlignment.Left
            Lbl.TextColor3 = C.Dim
            Lbl.Parent = Row

            local On = Def
            local function Sync()
                Library.Flags[Flag] = On
                Box.BackgroundColor3 = On and C.Accent or C.El
                Lbl.TextColor3 = On and Color3.new(1, 1, 1) or C.Dim
                Chk.Visible = On
                Library:SafeCall(CB, On)
            end

            Hit.MouseButton1Click:Connect(function()
                On = not On
                Sync()
            end)

            Library.OnHover(setmetatable({ Instance = Box }, Library), function()
                TweenService:Create(Box, TweenInfo.new(0.1), { BackgroundColor3 = hoverLift(On and C.Accent or C.El) })
            end, function()
                TweenService:Create(Box, TweenInfo.new(0.1), { BackgroundColor3 = On and C.Accent or C.El })
            end)

            Library.OnHover(setmetatable({ Instance = Hit }, Library), function()
                Lbl.TextColor3 = hoverLift(Lbl.TextColor3)
            end, function()
                Lbl.TextColor3 = On and Color3.new(1, 1, 1) or C.Dim
            end)

            Sync()
            Sub.Page:RegisterSearch(Row, NM)
        end

        function Sec:Slider(P)
            P = P or {}
            local NM = P.Name or P.name or "slider"
            local Flag = P.Flag or P.flag or NM
            local Mn = P.Min or P.min or 0
            local Mx = P.Max or P.max or 100
            local Def = P.Default or P.default or Mn
            local CB = P.Callback or P.callback or function() end

            local Hf = Instance.new("Frame")
            Hf.BackgroundTransparency = 1
            Hf.Size = UDim2.new(1, -26, 0, 44)
            Hf.Parent = Inner

            local Lbl = Instance.new("TextLabel")
            Lbl.Text = NM
            Lbl.BackgroundTransparency = 1
            Lbl.FontFace = Library.Font
            Lbl.TextSize = Library.FontSize
            Lbl.TextColor3 = C.Dim
            Lbl.Size = UDim2.new(1, 0, 0, 20)
            Lbl.TextXAlignment = Enum.TextXAlignment.Left
            Lbl.Parent = Hf

            local Pd = Instance.new("TextButton")
            Pd.Text = ""
            Pd.BackgroundTransparency = 1
            Pd.Position = UDim2.fromOffset(0, 22)
            Pd.Size = UDim2.new(1, 0, 0, 18)
            Pd.Parent = Hf

            local Bg = Instance.new("Frame")
            Bg.AnchorPoint = Vector2.new(0, 1)
            Bg.Position = UDim2.new(0, 0, 1, 0)
            Bg.Size = UDim2.new(1, 0, 0, 3)
            Bg.BackgroundColor3 = C.SlideTrack
            Bg.BorderSizePixel = 0
            Bg.Parent = Pd
            Instance.new("UICorner").Parent = Bg

            local Mid = Instance.new("Frame")
            Mid.AnchorPoint = Vector2.new(0, 1)
            Mid.Position = UDim2.new(0, 0, 1, 0)
            Mid.Size = UDim2.new(0.3, 0, 0, 3)
            Mid.BackgroundColor3 = C.SlideMid
            Mid.BorderSizePixel = 0
            Mid.Parent = Pd
            Instance.new("UICorner").Parent = Mid

            local Fill = Instance.new("Frame")
            Fill.BackgroundColor3 = C.Accent
            Fill.BorderSizePixel = 0
            Fill.Size = UDim2.new(1, 0, 1, 0)
            Fill.Parent = Mid
            Instance.new("UICorner").Parent = Fill

            local Drag = false
            local function SetA(a)
                a = math.clamp(a, 0, 1)
                Mid.Size = UDim2.new(a, 0, 0, 3)
                local v = roundNum(Mn + (Mx - Mn) * a)
                Library.Flags[Flag] = v
                Lbl.TextColor3 = a > 0.02 and Color3.new(1, 1, 1) or C.Dim
                Library:SafeCall(CB, v)
            end

            SetA((Def - Mn) / math.max(Mx - Mn, 1e-6))

            Pd.MouseButton1Down:Connect(function()
                Drag = true
            end)
            Library:Connect(UserInputService.InputEnded, function(I)
                if I.UserInputType == Enum.UserInputType.MouseButton1 then
                    Drag = false
                end
            end)
            Library:Connect(UserInputService.InputChanged, function(I)
                if not Drag or I.UserInputType ~= Enum.UserInputType.MouseMovement then
                    return
                end
                local ap = Pd.AbsolutePosition
                SetA((Mouse.X - ap.X) / math.max(Pd.AbsoluteSize.X, 1))
            end)

            Library.OnHover(setmetatable({ Instance = Pd }, Library), function()
                Bg.BackgroundColor3 = hoverLift(C.SlideTrack)
            end, function()
                Bg.BackgroundColor3 = C.SlideTrack
            end)

            Sub.Page:RegisterSearch(Hf, NM)
        end

        function Sec:Dropdown(P)
            P = P or {}
            local NM = P.Name or P.name or "dropdown"
            local Flag = P.Flag or P.flag or NM
            local List = P.Items or P.items or {}
            local Multi = P.Multi == true or P.multi == true
            local Def = P.Default or P.default
            local CB = P.Callback or P.callback or function() end

            local Wrap = Instance.new("Frame")
            Wrap.BackgroundTransparency = 1
            Wrap.ClipsDescendants = true
            Wrap.AutomaticSize = Enum.AutomaticSize.Y
            Wrap.Size = UDim2.new(1, -26, 0, 0)
            Wrap.Parent = Inner

            local Tit = Instance.new("TextLabel")
            Tit.Text = NM
            Tit.BackgroundTransparency = 1
            Tit.FontFace = Library.Font
            Tit.TextSize = Library.FontSize
            Tit.TextColor3 = C.Dim
            Tit.Size = UDim2.new(1, 0, 0, 22)
            Tit.TextXAlignment = Enum.TextXAlignment.Left
            Tit.Parent = Wrap

            local Btn = Instance.new("TextButton")
            Btn.Text = ""
            Btn.AutoButtonColor = false
            Btn.BackgroundColor3 = C.El
            Btn.Size = UDim2.new(1, -4, 0, 25)
            Btn.AnchorPoint = Vector2.new(0, 1)
            Btn.Position = UDim2.new(0, 0, 1, 0)
            Btn.Parent = Wrap
            local uc = Instance.new("UICorner")
            uc.CornerRadius = UDim.new(0.1, 1)
            uc.Parent = Btn

            local Vt = Instance.new("TextLabel")
            Vt.BackgroundTransparency = 1
            Vt.Position = UDim2.fromOffset(12, 0)
            Vt.Size = UDim2.new(1, -36, 1, 0)
            Vt.FontFace = Library.Font
            Vt.TextSize = Library.FontSize
            Vt.TextXAlignment = Enum.TextXAlignment.Left
            Vt.Text = ""
            Vt.TextColor3 = C.Dim
            Vt.Parent = Btn

            local Arrow = Instance.new("ImageLabel")
            Arrow.BackgroundTransparency = 1
            Arrow.Image = "rbxassetid://108899987138167"
            Arrow.ImageColor3 = C.Accent
            Arrow.Size = UDim2.fromOffset(15, 15)
            Arrow.AnchorPoint = Vector2.new(1, 0.5)
            Arrow.Position = UDim2.new(1, -8, 0.5, 0)
            Arrow.Parent = Btn

            local OpenF = Instance.new("Frame")
            OpenF.BackgroundColor3 = C.El
            OpenF.BorderSizePixel = 0
            OpenF.ClipsDescendants = true
            OpenF.Size = UDim2.new(1, -4, 0, 0)
            OpenF.Visible = false
            OpenF.Parent = Wrap
            local openRnd = Instance.new("UICorner")
            openRnd.CornerRadius = UDim.new(0.05, 1)
            openRnd.Parent = OpenF

            Instance.new("UIListLayout").Parent = OpenF

            local selM = {}
            local sel1
            if Multi then
                for _ in ipairs(List) do
                    table.insert(selM, false)
                end
                Vt.Text = ""
            elseif Def then
                sel1 = Def
                Vt.Text = tostring(Def)
            elseif #List > 0 then
                sel1 = List[1]
                Vt.Text = tostring(List[1])
            end

            Library.Flags[Flag] = Multi and {} or sel1

            local Open = false
            local Deb = false
            local outsideConn

            local function Close()
                if not Open then
                    return
                end
                Open = false
                Deb = true
                TweenService:Create(Arrow, TweenInfo.new(Library.Animation.Time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Rotation = 0,
                }):Play()
                TweenService:Create(OpenF, TweenInfo.new(Library.Animation.Time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Size = UDim2.new(1, -4, 0, 0),
                }):Play()
                if outsideConn then
                    outsideConn:Disconnect()
                    outsideConn = nil
                end
                task.delay(Library.Animation.Time, function()
                    OpenF.Visible = false
                    Deb = false
                end)
            end

            local function OpenIt()
                if Deb then
                    return
                end
                if outsideConn then
                    outsideConn:Disconnect()
                    outsideConn = nil
                end
                Open = true
                Deb = true
                local h = math.min(#List * 25 + 8, 150)
                OpenF.Visible = true
                OpenF.Size = UDim2.new(1, -4, 0, 0)
                TweenService:Create(Arrow, TweenInfo.new(Library.Animation.Time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Rotation = 180,
                }):Play()
                TweenService:Create(OpenF, TweenInfo.new(Library.Animation.Time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Size = UDim2.new(1, -4, 0, h),
                }):Play()
                task.delay(Library.Animation.Time, function()
                    Deb = false
                end)

                outsideConn = UserInputService.InputBegan:Connect(function(In)
                    if In.UserInputType ~= Enum.UserInputType.MouseButton1 and In.UserInputType ~= Enum.UserInputType.Touch then
                        return
                    end
                    task.defer(function()
                        local w = setmetatable({ Instance = Wrap }, Library)
                        local o = setmetatable({ Instance = OpenF }, Library)
                        if not w:IsMouseOverFrame() and not o:IsMouseOverFrame() then
                            Close()
                        end
                    end)
                end)
            end

            Btn.MouseButton1Click:Connect(function()
                if Open then
                    Close()
                else
                    OpenIt()
                end
            end)

            Library.OnHover(setmetatable({ Instance = Btn }, Library), function()
                TweenService:Create(Btn, TweenInfo.new(0.1), { BackgroundColor3 = hoverLift(C.El) })
            end, function()
                TweenService:Create(Btn, TweenInfo.new(0.1), { BackgroundColor3 = C.El })
            end)

            for _, opt in ipairs(List) do
                local Op = Instance.new("TextButton")
                Op.Text = tostring(opt)
                Op.FontFace = Library.Font
                Op.TextSize = Library.FontSize
                Op.BackgroundColor3 = C.El
                Op.BorderSizePixel = 0
                Op.Size = UDim2.new(1, 0, 0, 25)
                Op.AutoButtonColor = false
                Op.TextColor3 = C.Dim
                Op.Parent = OpenF

                Op.MouseButton1Click:Connect(function()
                    if Multi then
                        local ix = table.find(List, opt)
                        selM[ix] = not selM[ix]
                        local acc = {}
                        for i, v in ipairs(List) do
                            if selM[i] then
                                table.insert(acc, tostring(v))
                            end
                        end
                        Vt.Text = table.concat(acc, ", ")
                        Vt.TextColor3 = #acc > 0 and Color3.new(1, 1, 1) or C.Dim
                        Library.Flags[Flag] = acc
                        Library:SafeCall(CB, acc)
                    else
                        sel1 = opt
                        Vt.Text = tostring(opt)
                        Vt.TextColor3 = Color3.new(1, 1, 1)
                        Library.Flags[Flag] = opt
                        Library:SafeCall(CB, opt)
                        Close()
                    end
                end)

                Library.OnHover(setmetatable({ Instance = Op }, Library), function()
                    TweenService:Create(Op, TweenInfo.new(0.1), { BackgroundColor3 = hoverLift(C.El) })
                end, function()
                    TweenService:Create(Op, TweenInfo.new(0.1), { BackgroundColor3 = C.El })
                end)
            end

            Sub.Page:RegisterSearch(Wrap, NM)
        end

        return Sec
    end
end

