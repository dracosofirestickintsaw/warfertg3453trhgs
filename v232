    })

    -- ── Spring-physics drag (faster response) ─────────────────────────────────
    do
        local STIFFNESS = 280  -- Increased for faster response
        local DAMPING   = 28   -- Adjusted accordingly

        local springX, springY = 0, 0
        local velX,    velY    = 0, 0
        local targetX, targetY = 0, 0

        local dragging   = false
        local startMouse = Vector3.zero
        local startTX, startTY = 0, 0

        local cs = Window._connStore

        cs:Add(RunService.RenderStepped:Connect(function(dt)
            dt = math.min(dt, 0.05)
            local ax = STIFFNESS * (targetX - springX) - DAMPING * velX
            local ay = STIFFNESS * (targetY - springY) - DAMPING * velY
            velX = velX + ax * dt;  velY = velY + ay * dt
            springX = springX + velX * dt;  springY = springY + velY * dt
            Main.Position = UDim2.new(0.5, springX, 0.5, springY)
        end))

        cs:Add(Main.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
            local mp = input.Position
            if mp.Y <= Main.AbsolutePosition.Y + 62 then
                dragging   = true
                startMouse = mp
                startTX    = targetX
                startTY    = targetY
            end
        end))

        cs:Add(UserInputService.InputChanged:Connect(function(input)
            if not dragging then return end
            if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
            local vp    = Camera.ViewportSize
            local delta = input.Position - startMouse
            local hw    = Main.AbsoluteSize.X / 2
            local hh    = Main.AbsoluteSize.Y / 2
            targetX = math.clamp(startTX + delta.X, hw - vp.X/2, vp.X/2 - hw)
            targetY = math.clamp(startTY + delta.Y, hh - vp.Y/2, vp.Y/2 - hh)
        end))

        cs:Add(UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end))
    end

    -- Keybind toggle
    Window._connStore:Add(UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == toggleKey then
            Window.IsOpen = not Window.IsOpen
            Main.Visible  = Window.IsOpen
        end
    end))

