                    searchBox = New("Frame", {
                        BorderSizePixel = 0,
                        BackgroundColor3 = T.ElementDark,
                        Size = UDim2.new(1, -8, 0, 25),
                        Position = UDim2.new(0, 4, 0, 4),
                        Parent = OptionsList,
                    })
