                InputBG.Size             = UDim2.new(0.58, 0, 0, 27)
                InputBG.AnchorPoint      = Vector2.new(1, 0.5)
                InputBG.Position         = UDim2.new(1, 0, 0.5, 0)
                InputBG.BorderSizePixel  = 0
                Corner(InputBG, 6)
                Pad(InputBG, nil, nil, 8, 8)

                local Box = Instance.new("TextBox", InputBG)
                Box.BackgroundTransparency = 1
                Box.PlaceholderText        = placeholder
                Box.PlaceholderColor3      = Color3.fromRGB(122, 121, 132)
                Box.Text                   = default
                Box.TextColor3             = Library.Theme.TextPrimary
                Box.TextSize               = 13
                Box.Font                   = Enum.Font.Gotham
                Box.Size                   = UDim2.new(1, 0, 1, 0)
                Box.TextXAlignment         = Enum.TextXAlignment.Left
                Box.BorderSizePixel        = 0
                Box.ClearTextOnFocus       = false
                Box.ZIndex                 = 5

                local lastGood = default
                Connect(Box:GetPropertyChangedSignal("Text"), function()
                    local v = Box.Text
                    if numeric and v ~= "" and v ~= "-" and not tonumber(v) then
                        Box.Text = lastGood; return
                    end
                    lastGood            = v
                    Library.Flags[flag] = v
                    pcall(callback, v)
                end)

                Library.Flags[flag]   = default
                Library.SetFlags[flag] = function(v) Box.Text = tostring(v) end

                return {
                    Set   = function(_, v) Box.Text = tostring(v) end,
                    Value = function()     return Box.Text end,
                }
            end

            return Section
        end -- Section

        return Page
    end -- Page

    --[[ ================================================================
         NOTIFY
         ================================================================ ]]
    function Window:Notify(cfg2)
        cfg2 = cfg2 or {}
        local title    = cfg2.Title       or "Notification"
        local desc     = cfg2.Description or ""
        local duration = cfg2.Duration    or 4

        local holder = Gui:FindFirstChild("__NotifHolder")
        if not holder then
            holder      = Instance.new("Frame", Gui)
            holder.Name = "__NotifHolder"
            holder.BackgroundTransparency = 1
            holder.AnchorPoint = Vector2.new(1, 1)
            holder.Size        = UDim2.new(0, 300, 1, -20)
            holder.Position    = UDim2.new(1, -15, 1, -15)
            holder.BorderSizePixel = 0
            local hl = ListLayout(holder, 8, Enum.FillDirection.Vertical,
                Enum.HorizontalAlignment.Right, Enum.VerticalAlignment.Bottom)
            hl.SortOrder = Enum.SortOrder.LayoutOrder
        end

        local NF = Instance.new("Frame", holder)
        NF.BackgroundColor3       = Library.Theme.Navigation
        NF.BackgroundTransparency = 0.2
        NF.Size                   = UDim2.new(1, 0, 0, 0)
        NF.AutomaticSize          = Enum.AutomaticSize.Y
        NF.BorderSizePixel        = 0
        NF.ClipsDescendants       = false
        Corner(NF, 12)
        Stroke(NF, Library.Theme.Stroke, 1.3, 0.55)
        Pad(NF, 11, 15, 14, 14)

        local T = Label(NF, title, 14, Library.Theme.TextPrimary, Enum.Font.GothamBold)
        T.Size = UDim2.new(1, 0, 0, 20)

        local D = Label(NF, desc, 12, Library.Theme.TextSecondary,
            Enum.Font.Gotham, Enum.TextXAlignment.Left,
            { Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 0, 22),
              AutomaticSize = Enum.AutomaticSize.Y, TextWrapped = true })

        -- Progress bar
        local PBG = Instance.new("Frame", NF)
        PBG.BackgroundColor3 = Library.Theme.Stroke
        PBG.Size             = UDim2.new(1, 0, 0, 3)
        PBG.AnchorPoint      = Vector2.new(0, 1)
        PBG.Position         = UDim2.new(0, 0, 1, 8)
        PBG.BorderSizePixel  = 0
        Corner(PBG, 100)

        local PFill = Instance.new("Frame", PBG)
        PFill.BackgroundColor3 = Library.Theme.Accent
        PFill.Size             = UDim2.new(1, 0, 1, 0)
        PFill.BorderSizePixel  = 0
        Corner(PFill, 100)

        -- Fade in
        NF.BackgroundTransparency = 1
        T.TextTransparency        = 1
        D.TextTransparency        = 1

        local tin = TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
        TweenService:Create(NF,    tin, { BackgroundTransparency = 0.2 }):Play()
        TweenService:Create(T,     tin, { TextTransparency = 0 }):Play()
        TweenService:Create(D,     tin, { TextTransparency = 0 }):Play()
        TweenService:Create(PFill, TweenInfo.new(duration, Enum.EasingStyle.Linear),
            { Size = UDim2.new(0, 0, 1, 0) }):Play()

        task.delay(duration, function()
            local tout = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
            TweenService:Create(NF, tout, { BackgroundTransparency = 1 }):Play()
            TweenService:Create(T,  tout, { TextTransparency = 1 }):Play()
            TweenService:Create(D,  tout, { TextTransparency = 1 }):Play()
            task.wait(0.3)
            NF:Destroy()
        end)
    end

    --[[ ================================================================
         DESTROY / CLEANUP
         ================================================================ ]]
    function Window:Destroy()
        for _, conn in Library.Connections do
            pcall(function() conn:Disconnect() end)
        end
        for _, fn in Library.BlurCleanup do
            pcall(fn)
        end
        Library.Connections = {}
        Library.BlurCleanup = {}
        Gui:Destroy()
    end

    return Window
end

--[[ =====================================================================
     LOAD CONFIG  (basic flag-based serialization)
     ===================================================================== ]]
function Library:GetConfig()
    local t = {}
    for flag, val in Library.Flags do
        t[flag] = val
    end
    return game:GetService("HttpService"):JSONEncode(t)
end

function Library:LoadConfig(json)
    local ok, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(json)
    end)
    if not ok then warn("[Da7muLibrary] LoadConfig failed: " .. tostring(data)); return end
    for flag, val in data do
        local setter = Library.SetFlags[flag]
        if setter then pcall(setter, val) end
    end
end

--[[ =====================================================================
     EXPORT
     ===================================================================== ]]
return Library
