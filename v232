            sf.CanvasSize                = UDim2.new(0, 0, 0, 0)
            sf.Size                      = UDim2.new(xSize, -8, 1, 0)
            sf.Position                  = UDim2.new(xPos, 4, 0, 0)
            ListLayout(sf, 12)
            Pad(sf, 10, 14, 5, 5)
            return sf
        end

        local Side1 = MakeSideScroll(0,   0.5)
        local Side2 = MakeSideScroll(0.5, 0.5)

        local Page = {
