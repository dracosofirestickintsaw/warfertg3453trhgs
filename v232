             SECTION
             ============================================================ ]]
        function Page:Section(config3)
            config3 = config3 or {}
            local secName = config3.Name or "Section"
            local side    = math.clamp(config3.Side or 1, 1, 2)
            local parent  = Page.Sides[side]

            -- Section title label
            local SecTitle = Label(parent, secName:upper(), 11, Color3.fromRGB(81, 84, 92))
            SecTitle.Size         = UDim2.new(1, 0, 0, 18)
            SecTitle.LayoutOrder  = 1

            -- Section container
            local SecFrame = Instance.new("Frame", parent)
            SecFrame.BackgroundColor3       = Library.Theme.Section
            SecFrame.BackgroundTransparency = 0.6
            SecFrame.BorderSizePixel        = 0
            SecFrame.AutomaticSize          = Enum.AutomaticSize.Y
            SecFrame.Size                   = UDim2.new(1, 0, 0, 0)
            SecFrame.LayoutOrder            = 2
            Corner(SecFrame, 14)
            Stroke(SecFrame, Library.Theme.Stroke, 1.3, 0.41)

            ListLayout(SecFrame, 0)
            Pad(SecFrame, 8, 8, 0, 0)

            local elemCount = 0

            -- Internal helper: every element row
            local function Row(h)
                h = h or 42
                elemCount += 1
                local r = Instance.new("Frame", SecFrame)
                r.BackgroundTransparency = 1
                r.Size                   = UDim2.new(1, 0, 0, h)
                r.BorderSizePixel        = 0
                r.LayoutOrder            = elemCount

                -- Divider after first element
                if elemCount > 1 then
                    local div = Instance.new("Frame", r)
                    div.BackgroundColor3       = Library.Theme.Stroke
                    div.BackgroundTransparency = 0.7
                    div.Size                   = UDim2.new(1, -24, 0, 1)
                    div.Position               = UDim2.new(0, 12, 0, 0)
                    div.BorderSizePixel        = 0
                end

                Pad(r, 4, 4, 12, 12)
                return r
            end

            local Section = { Frame = SecFrame }

            --[[ ========================================================
                 TOGGLE
                 ======================================================== ]]
            function Section:Toggle(cfg4)
                cfg4 = cfg4 or {}
                local name     = cfg4.Name     or "Toggle"
                local flag     = cfg4.Flag     or name
                local default  = cfg4.Default  or false
                local callback = cfg4.Callback or function() end

                local r = Row(42)

                local TitleLbl = Label(r, name, 15, Library.Theme.TextSecondary)
                TitleLbl.Size     = UDim2.new(1, -60, 1, 0)
                TitleLbl.Position = UDim2.new(0, 0, 0, 0)

                -- Toggle pill
                local Pill = Instance.new("Frame", r)
                Pill.BackgroundColor3 = Library.Theme.ToggleInactive
                Pill.Size             = UDim2.new(0, 45, 0, 25)
                Pill.AnchorPoint      = Vector2.new(1, 0.5)
                Pill.Position         = UDim2.new(1, 0, 0.5, 0)
                Pill.BorderSizePixel  = 0
                Corner(Pill, 20)

                local Circle = Instance.new("Frame", Pill)
                Circle.BackgroundColor3 = Library.Theme.TextSecondary
                Circle.Size             = UDim2.new(0, 20, 0, 20)
                Circle.Position         = UDim2.new(0, 2, 0.5, -10)
                Circle.BorderSizePixel  = 0
                Corner(Circle, 100)

                local Clickable = Instance.new("TextButton", r)
                Clickable.BackgroundTransparency = 1
                Clickable.Size                   = UDim2.new(1, 0, 1, 0)
                Clickable.Text                   = ""
                Clickable.ZIndex                 = 5
                Clickable.BorderSizePixel        = 0
                Clickable.AutoButtonColor        = false

                local val = default

                local function SetVal(v)
                    val                 = v
                    Library.Flags[flag] = v

                    if v then
                        Tween(Pill,    { BackgroundColor3 = Library.Theme.ToggleActive },   TWEEN_MED)
                        Tween(Circle,  { Position = UDim2.new(0, 23, 0.5, -10),
                                         BackgroundColor3 = Color3.fromRGB(203, 203, 199) }, TWEEN_MED)
                        Tween(TitleLbl,{ TextColor3 = Library.Theme.TextPrimary }, TWEEN_MED)
                    else
                        Tween(Pill,    { BackgroundColor3 = Library.Theme.ToggleInactive }, TWEEN_MED)
                        Tween(Circle,  { Position = UDim2.new(0, 2, 0.5, -10),
                                         BackgroundColor3 = Library.Theme.TextSecondary },  TWEEN_MED)
                        Tween(TitleLbl,{ TextColor3 = Library.Theme.TextSecondary }, TWEEN_MED)
                    end

                    pcall(callback, v)
                end

                Connect(Clickable.MouseButton1Click, function() SetVal(not val) end)

                Library.SetFlags[flag] = SetVal
                SetVal(default)

                return {
                    Set   = function(_, v) SetVal(v) end,
                    Value = function()     return val end,
                }
            end

            --[[ ========================================================
                 SLIDER
                 ======================================================== ]]
            function Section:Slider(cfg4)
                cfg4 = cfg4 or {}
                local name     = cfg4.Name     or "Slider"
                local flag     = cfg4.Flag     or name
                local default  = cfg4.Default  or 0
                local min      = cfg4.Min      or 0
                local max      = cfg4.Max      or 100
                local decimals = cfg4.Decimals or 0
                local suffix   = cfg4.Suffix   or ""
                local callback = cfg4.Callback or function() end

                local r = Row(50)

                -- Title
                local TitleLbl = Label(r, name, 14, Library.Theme.TextPrimary)
                TitleLbl.Size     = UDim2.new(1, -52, 0, 20)
                TitleLbl.Position = UDim2.new(0, 0, 0, 0)

                -- Value badge
                local ValBG = Instance.new("Frame", r)
                ValBG.BackgroundColor3 = Library.Theme.ValueBg
                ValBG.Size             = UDim2.new(0, 44, 0, 22)
                ValBG.AnchorPoint      = Vector2.new(1, 0)
                ValBG.Position         = UDim2.new(1, 0, 0, -1)
                ValBG.BorderSizePixel  = 0
                Corner(ValBG, 6)

                local ValLbl = Label(ValBG, tostring(default), 13, Color3.fromRGB(105, 105, 112),
                    Enum.Font.Gotham, Enum.TextXAlignment.Center)
                ValLbl.Size    = UDim2.new(1, 0, 1, 0)
                ValLbl.ZIndex  = 2

                -- Track
                local Track = Instance.new("Frame", r)
                Track.BackgroundColor3 = Library.Theme.SliderTrack
                Track.AnchorPoint      = Vector2.new(0, 1)
                Track.Size             = UDim2.new(1, 0, 0, 6)
                Track.Position         = UDim2.new(0, 0, 1, 0)
                Track.BorderSizePixel  = 0
                Corner(Track, 100)

                -- Fill
                local Fill = Instance.new("Frame", Track)
                Fill.BackgroundColor3 = Library.Theme.Accent
                Fill.Size             = UDim2.new(0, 0, 1, 0)
                Fill.BorderSizePixel  = 0
                Corner(Fill, 100)

                -- Drag circle
                local Knob = Instance.new("Frame", Track)
                Knob.BackgroundColor3 = Color3.fromRGB(133, 133, 138)
                Knob.Size             = UDim2.new(0, 13, 0, 13)
                Knob.AnchorPoint      = Vector2.new(0.5, 0.5)
                Knob.Position         = UDim2.new(0, 0, 0.5, 0)
                Knob.BorderSizePixel  = 0
                Corner(Knob, 100)

                local Clickable = Instance.new("TextButton", r)
                Clickable.BackgroundTransparency = 1
                Clickable.Size                   = UDim2.new(1, 0, 1, 8)
                Clickable.Position               = UDim2.new(0, 0, 0, 0)
                Clickable.Text                   = ""
                Clickable.ZIndex                 = 5
                Clickable.BorderSizePixel        = 0
                Clickable.AutoButtonColor        = false

                local sliding = false
                local curVal  = default

                local function SetVal(v)
                    curVal              = RoundDecimal(math.clamp(v, min, max), decimals)
                    Library.Flags[flag] = curVal
                    local pct = (curVal - min) / (max - min)
                    Tween(Fill, { Size     = UDim2.new(pct, 0, 1, 0) })
                    Tween(Knob, { Position = UDim2.new(pct, 0, 0.5, 0) })
                    ValLbl.Text = tostring(curVal) .. suffix
                    pcall(callback, curVal)
                end

                local function FromMouse(x)
                    local rel = x - Track.AbsolutePosition.X
                    local pct = math.clamp(rel / Track.AbsoluteSize.X, 0, 1)
                    return min + (max - min) * pct
                end

                Connect(Clickable.InputBegan, function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = true
                        SetVal(FromMouse(inp.Position.X))
                    end
                end)
                Connect(UserInputService.InputChanged, function(inp)
                    if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
                        SetVal(FromMouse(inp.Position.X))
                    end
                end)
                Connect(UserInputService.InputEnded, function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = false
                    end
                end)

                Library.SetFlags[flag] = SetVal
                SetVal(default)

                return {
                    Set   = function(_, v) SetVal(v) end,
                    Value = function()     return curVal end,
                }
            end

            --[[ ========================================================
                 DROPDOWN
                 ======================================================== ]]
            function Section:Dropdown(cfg4)
                cfg4 = cfg4 or {}
                local name     = cfg4.Name     or "Dropdown"
                local flag     = cfg4.Flag     or name
                local items    = cfg4.Items    or {}
                local default  = cfg4.Default  or nil
                local multi    = cfg4.Multi    or false
                local callback = cfg4.Callback or function() end

                local r = Row(42)

                -- Title
                local TitleLbl = Label(r, name .. ":", 15, Library.Theme.TextPrimary)
                TitleLbl.Size     = UDim2.new(0.42, 0, 1, 0)
                TitleLbl.Position = UDim2.new(0, 0, 0, 0)

                -- Selected value frame
                local SelFrame = Instance.new("Frame", r)
                SelFrame.BackgroundColor3       = Library.Theme.ValueBg
                SelFrame.BackgroundTransparency = 0.4
                SelFrame.Size                   = UDim2.new(0.54, 0, 0, 27)
                SelFrame.AnchorPoint            = Vector2.new(1, 0.5)
                SelFrame.Position               = UDim2.new(1, -2, 0.5, 0)
                SelFrame.BorderSizePixel        = 0
                SelFrame.ClipsDescendants       = true
                Corner(SelFrame, 6)

                local SelText = Label(SelFrame, "Select...", 13, Color3.fromRGB(148, 147, 159),
                    Enum.Font.Gotham, Enum.TextXAlignment.Left,
                    { Size = UDim2.new(1, -22, 1, 0), Position = UDim2.new(0, 8, 0, 0),
                      TextTruncate = Enum.TextTruncate.AtEnd })

                local Arrow = Instance.new("ImageLabel", SelFrame)
                Arrow.BackgroundTransparency = 1
                Arrow.Image                  = "rbxassetid://84949494757640"
                Arrow.ImageColor3            = Library.Theme.TextPrimary
                Arrow.Size                   = UDim2.new(0, 10, 0, 10)
                Arrow.AnchorPoint            = Vector2.new(1, 0.5)
                Arrow.Position               = UDim2.new(1, -5, 0.5, 0)
                Arrow.BorderSizePixel        = 0
                Arrow.ZIndex                 = 2

                local Clickable = Instance.new("TextButton", r)
                Clickable.BackgroundTransparency = 1
                Clickable.Size                   = UDim2.new(1, 0, 1, 0)
                Clickable.Text                   = ""
                Clickable.ZIndex                 = 5
                Clickable.BorderSizePixel        = 0
                Clickable.AutoButtonColor        = false

                --[[ ── Popup ───────────────────────────────────────── ]]
                local Popup = Instance.new("Frame", Gui)
                Popup.BackgroundColor3 = Library.Theme.Popup
                Popup.Size             = UDim2.new(0, 185, 0, 210)
                Popup.Visible          = false
                Popup.ZIndex           = 20
                Popup.BorderSizePixel  = 0
                Corner(Popup, 14)
                local ps = Stroke(Popup, Color3.fromRGB(63, 63, 72), 1.3, 0.62)
                ps.ZIndex = 20

                local SearchBG = Instance.new("Frame", Popup)
                SearchBG.BackgroundColor3 = Color3.fromRGB(29, 28, 39)
                SearchBG.Size             = UDim2.new(1, -14, 0, 28)
                SearchBG.Position         = UDim2.new(0, 7, 0, 8)
                SearchBG.BorderSizePixel  = 0
                SearchBG.ZIndex           = 21
                Corner(SearchBG, 8)

                local SrchIco = Instance.new("ImageLabel", SearchBG)
                SrchIco.BackgroundTransparency = 1
                SrchIco.Image                  = "rbxassetid://10734943674"
                SrchIco.ImageColor3            = Library.Theme.TextSecondary
                SrchIco.Size                   = UDim2.new(0, 13, 0, 13)
                SrchIco.AnchorPoint            = Vector2.new(0, 0.5)
                SrchIco.Position               = UDim2.new(0, 8, 0.5, 0)
                SrchIco.BorderSizePixel        = 0
                SrchIco.ZIndex                 = 22

                local SrchBox = Instance.new("TextBox", SearchBG)
                SrchBox.BackgroundTransparency = 1
                SrchBox.PlaceholderText        = "Search..."
                SrchBox.PlaceholderColor3      = Color3.fromRGB(122, 121, 132)
                SrchBox.Text                   = ""
                SrchBox.TextColor3             = Library.Theme.TextPrimary
                SrchBox.TextSize               = 13
                SrchBox.Font                   = Enum.Font.Gotham
                SrchBox.Size                   = UDim2.new(1, -28, 1, 0)
                SrchBox.Position               = UDim2.new(0, 24, 0, 0)
                SrchBox.TextXAlignment         = Enum.TextXAlignment.Left
                SrchBox.BorderSizePixel        = 0
                SrchBox.ZIndex                 = 22
                SrchBox.ClearTextOnFocus       = false

                local OptScroll = Instance.new("ScrollingFrame", Popup)
                OptScroll.BackgroundTransparency = 1
                OptScroll.Size                   = UDim2.new(1, -14, 1, -48)
                OptScroll.Position               = UDim2.new(0, 7, 0, 44)
                OptScroll.BorderSizePixel        = 0
                OptScroll.ScrollBarThickness     = 3
                OptScroll.ScrollBarImageColor3   = Library.Theme.Accent
                OptScroll.AutomaticCanvasSize    = Enum.AutomaticSize.Y
                OptScroll.CanvasSize             = UDim2.new(0, 0, 0, 0)
                OptScroll.ZIndex                 = 21
                Corner(OptScroll, 8)
                ListLayout(OptScroll, 2)
                Pad(OptScroll, 4, 4, 0, 0)

                local isOpen     = false
                local selected   = multi and {} or nil
                local optButtons = {}

                local function UpdateSelText()
                    if multi then
                        if #selected == 0 then
                            SelText.Text      = "Select..."
                            SelText.TextColor3 = Color3.fromRGB(148, 147, 159)
                        else
                            SelText.Text      = table.concat(selected, ", ")
                            SelText.TextColor3 = Library.Theme.TextPrimary
                        end
                    else
                        if selected then
                            SelText.Text      = selected
                            SelText.TextColor3 = Library.Theme.TextPrimary
                        else
                            SelText.Text      = "Select..."
                            SelText.TextColor3 = Color3.fromRGB(148, 147, 159)
                        end
                    end
                end

                local function IsSel(v)
                    return multi and table.find(selected, v) ~= nil or selected == v
                end

                local function UpdateOptVisuals(optName, btn, lbl, chk)
                    if IsSel(optName) then
                        Tween(btn, { BackgroundTransparency = 0 })
                        lbl.TextColor3 = Color3.fromRGB(201, 201, 208)
                        if chk then chk.Visible = true end
                    else
                        Tween(btn, { BackgroundTransparency = 1 })
                        lbl.TextColor3 = Color3.fromRGB(148, 147, 159)
                        if chk then chk.Visible = false end
                    end
                end

                local function ClosePopup()
                    isOpen = false
                    Tween(Arrow, { Rotation = 0 })
                    Popup.Visible = false
                    SrchBox.Text  = ""
                    for _, ob in optButtons do ob.btn.Visible = true end
                end

                local function OpenPopup()
                    isOpen = true
                    local ap  = r.AbsolutePosition
                    local as  = r.AbsoluteSize
                    Popup.Position = UDim2.new(0, ap.X + as.X - 190, 0, ap.Y + as.Y + 4)
                    Popup.Visible  = true
                    Tween(Arrow, { Rotation = -90 })
                end

                local function AddOption(optName)
                    local btn = Instance.new("TextButton", OptScroll)
                    btn.BackgroundColor3       = Color3.fromRGB(42, 42, 49)
                    btn.BackgroundTransparency = 1
                    btn.Size                   = UDim2.new(1, 0, 0, 28)
                    btn.Text                   = ""
                    btn.BorderSizePixel        = 0
                    btn.AutoButtonColor        = false
                    btn.ZIndex                 = 22
                    Corner(btn, 7)

                    local lbl = Label(btn, optName, 13, Color3.fromRGB(148, 147, 159),
                        Enum.Font.Gotham, Enum.TextXAlignment.Left,
                        { Size = UDim2.new(1, -28, 1, 0), Position = UDim2.new(0, 10, 0, 0),
                          ZIndex = 23 })

                    local chk = Instance.new("ImageLabel", btn)
                    chk.BackgroundTransparency = 1
                    chk.Image                  = "rbxassetid://10709790644"
                    chk.ImageColor3            = Color3.fromRGB(247, 247, 255)
                    chk.Size                   = UDim2.new(0, 13, 0, 13)
                    chk.AnchorPoint            = Vector2.new(1, 0.5)
                    chk.Position               = UDim2.new(1, -8, 0.5, 0)
                    chk.Visible                = false
                    chk.BorderSizePixel        = 0
                    chk.ZIndex                 = 23

                    Connect(btn.MouseButton1Click, function()
                        if multi then
                            local idx = table.find(selected, optName)
                            if idx then table.remove(selected, idx) else table.insert(selected, optName) end
                        else
                            selected = optName
                            ClosePopup()
                        end
                        Library.Flags[flag] = selected
                        for _, ob in optButtons do UpdateOptVisuals(ob.name, ob.btn, ob.lbl, ob.chk) end
                        UpdateSelText()
                        pcall(callback, selected)
                    end)

                    Connect(btn.MouseEnter, function()
                        if not IsSel(optName) then Tween(btn, { BackgroundTransparency = 0.6 }) end
                    end)
                    Connect(btn.MouseLeave, function()
                        if not IsSel(optName) then Tween(btn, { BackgroundTransparency = 1 }) end
                    end)

                    table.insert(optButtons, { name = optName, btn = btn, lbl = lbl, chk = chk })
                    UpdateOptVisuals(optName, btn, lbl, chk)
                end

                -- Search filter
                Connect(SrchBox:GetPropertyChangedSignal("Text"), function()
                    local q = SrchBox.Text:lower()
                    for _, ob in optButtons do
                        ob.btn.Visible = q == "" or ob.name:lower():find(q, 1, true) ~= nil
                    end
                end)

                -- Outside click to close
                Connect(UserInputService.InputBegan, function(inp)
                    if inp.UserInputType ~= Enum.UserInputType.MouseButton1 or not isOpen then return end
                    local mp   = UserInputService:GetMouseLocation()
                    local pp   = Popup.AbsolutePosition
                    local ps2  = Popup.AbsoluteSize
                    local inPop = mp.X >= pp.X and mp.X <= pp.X + ps2.X
                               and mp.Y >= pp.Y and mp.Y <= pp.Y + ps2.Y
                    if not inPop then ClosePopup() end
                end)

                Connect(Clickable.MouseButton1Click, function()
                    if isOpen then ClosePopup() else OpenPopup() end
                end)

                -- Populate
                for _, item in items do AddOption(item) end

                -- Set default
                local function SetDropdown(v)
                    if multi then
                        selected = type(v) == "table" and v or { v }
                    else
                        selected = v
                    end
                    Library.Flags[flag] = selected
                    for _, ob in optButtons do UpdateOptVisuals(ob.name, ob.btn, ob.lbl, ob.chk) end
                    UpdateSelText()
                    pcall(callback, selected)
                end

                Library.SetFlags[flag] = SetDropdown
                if default then SetDropdown(default) end

                return {
                    Set     = function(_, v) SetDropdown(v) end,
                    Refresh = function(_, newItems)
                        for _, ob in optButtons do ob.btn:Destroy() end
                        optButtons = {}
                        selected   = multi and {} or nil
                        UpdateSelText()
                        for _, item in newItems do AddOption(item) end
                    end,
                    Value   = function() return selected end,
                }
            end

