--[[ =====================================================================
     INTERNAL HELPERS
     ===================================================================== ]]

local TWEEN_SHORT = TweenInfo.new(0.18, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local TWEEN_MED   = TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

local function Tween(instance, props, info)
    TweenService:Create(instance, info or TWEEN_SHORT, props):Play()
end

local function Connect(signal, callback)
    local conn = signal:Connect(callback)
    table.insert(Library.Connections, conn)
    return conn
end

local function Corner(parent, radius)
    local c = Instance.new("UICorner", parent)
    c.CornerRadius = UDim.new(0, radius or 8)
    return c
end

local function Stroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke", parent)
    s.Color        = color        or Color3.fromRGB(54, 54, 62)
    s.Thickness    = thickness    or 1.3
    s.Transparency = transparency or 0.41
    return s
end

local function Pad(parent, t, b, l, r)
    local p = Instance.new("UIPadding", parent)
    if t then p.PaddingTop    = UDim.new(0, t) end
    if b then p.PaddingBottom = UDim.new(0, b) end
    if l then p.PaddingLeft   = UDim.new(0, l) end
    if r then p.PaddingRight  = UDim.new(0, r) end
    return p
end

local function ListLayout(parent, padding, fillDir, hAlign, vAlign)
    local l = Instance.new("UIListLayout", parent)
    l.Padding             = UDim.new(0, padding or 0)
    l.SortOrder           = Enum.SortOrder.LayoutOrder
    l.FillDirection       = fillDir or Enum.FillDirection.Vertical
    if hAlign then l.HorizontalAlignment = hAlign end
    if vAlign then l.VerticalAlignment   = vAlign end
    return l
end

local function Label(parent, text, size, color, font, xAlign, props)
    local l = Instance.new("TextLabel", parent)
    l.BackgroundTransparency = 1
    l.Text              = text   or ""
    l.TextSize          = size   or 14
    l.TextColor3        = color  or Library.Theme.TextPrimary
    l.Font              = font   or Enum.Font.Gotham
    l.TextXAlignment    = xAlign or Enum.TextXAlignment.Left
    l.BorderSizePixel   = 0
    if props then
        for k, v in props do l[k] = v end
    end
    return l
end

local function RoundDecimal(n, places)
    local m = 10 ^ (places or 0)
    return math.floor(n * m + 0.5) / m
end

--[[ =====================================================================
     BLUR SYSTEM
     (Glass-part blur matching Da7mu's BlurController)
     ===================================================================== ]]

local function CreateBlur(frame)
    local PART_SIZE       = 0.01
    local PART_TRANS      = 1 - 1e-7
    local BLUR_PADDING    = Vector2.new(10, 10)
    local camera          = workspace.CurrentCamera

    -- Depth of field effect
    local dof = Instance.new("DepthOfFieldEffect", Lighting)
    dof.FarIntensity  = 0
    dof.NearIntensity = 0.25
    dof.FocusDistance = 0.25
    dof.InFocusRadius = 0

    -- Glass part
    local part = Instance.new("Part", camera)
    part.Size         = Vector3.one * PART_SIZE
    part.Anchored     = true
    part.CanCollide   = false
    part.CastShadow   = false
    part.Material     = Enum.Material.Glass
    part.Transparency = PART_TRANS

    local mesh = Instance.new("BlockMesh", part)

    local function RayPlane(planePos, planeNormal, origin, dir)
        local v   = origin - planePos
        local num = planeNormal:Dot(v)
        local den = planeNormal:Dot(dir)
        return origin + (-num / den) * dir
    end

    local uid = "Da7muBlur_" .. tostring(math.random(1, 9999999))
    RunService:BindToRenderStep(uid, Enum.RenderPriority.Camera.Value + 1, function()
        if not frame or not frame.Parent then return end
        if not frame.Visible then part.Transparency = 1; return end

        part.Transparency = PART_TRANS
        dof.FocusDistance = 0.25 - camera.NearPlaneZ

        local c0 = frame.AbsolutePosition + BLUR_PADDING
        local c1 = frame.AbsolutePosition + frame.AbsoluteSize - BLUR_PADDING

        local r0 = camera:ViewportPointToRay(c0.X, c0.Y, 1)
        local r1 = camera:ViewportPointToRay(c1.X, c1.Y, 1)

        local planeOri = camera.CFrame.Position + camera.CFrame.LookVector * (0.05 - camera.NearPlaneZ)
        local planeNrm = camera.CFrame.LookVector

        local p0 = camera.CFrame:PointToObjectSpace(RayPlane(planeOri, planeNrm, r0.Origin, r0.Direction))
        local p1 = camera.CFrame:PointToObjectSpace(RayPlane(planeOri, planeNrm, r1.Origin, r1.Direction))

        mesh.Offset = (p0 + p1) / 2
        mesh.Scale  = (p1 - p0) / PART_SIZE
        part.CFrame = camera.CFrame
    end)

    return function()
        RunService:UnbindFromRenderStep(uid)
        pcall(function() part:Destroy() end)
        pcall(function() dof:Destroy()  end)
    end
end

--[[ =====================================================================
     DRAGGING
     ===================================================================== ]]

local function MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging, start, origin = false, nil, nil

    Connect(handle.InputBegan, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            start    = inp.Position
            origin   = frame.Position
        end
    end)
    Connect(UserInputService.InputChanged, function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - start
            frame.Position = UDim2.new(
                origin.X.Scale, origin.X.Offset + d.X,
                origin.Y.Scale, origin.Y.Offset + d.Y
            )
        end
    end)
    Connect(UserInputService.InputEnded, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

