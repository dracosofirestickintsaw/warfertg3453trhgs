    local Sec = Page:Section({ Name = "Aimbot", Side = 1 })
    
    Sec:Toggle({ Name = "Enable",  Flag = "AimEnable",  Default = false, Callback = function(v) print(v) end })
    Sec:Slider({ Name = "FOV",     Flag = "AimFOV",     Default = 90,    Min = 1, Max = 360 })
    Sec:Dropdown({ Name = "Part",  Flag = "AimPart",    Items = {"Head","HumanoidRootPart"}, Default = "Head" })
