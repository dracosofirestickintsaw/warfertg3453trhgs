            TextSize = 27,
            FontFace = Font.new("rbxasset://fonts/families/Roboto.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal),
            TextColor3 = T.TextDim,
            BackgroundTransparency = 1,
            Text = "...",
            Size = UDim2.new(0, 30, 1, 0),
            Position = UDim2.new(1, -35, 0, 0),
            Parent = parentElement,
        })
        
        local isOpen = false
        
        dotButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                if isOpen then
                    dotFrame.Visible = false
                    isOpen = false
                else
                    local absPos = dotButton.AbsolutePosition
                    dotFrame.Position = UDim2.new(0, absPos.X - 250, 0, absPos.Y + 30)
