        })
        New("UICorner", { Parent = NavBtnFrame })

        local NavIcon = New("ImageLabel", {
            BorderSizePixel = 0, BackgroundTransparency = 1,
            ImageColor3 = T.TextSecondary,
            AnchorPoint = Vector2.new(0, 0.5),
            Image = pageIcon,
            Size = UDim2.new(0, 20, 0, 20),
            Position = UDim2.new(0, 10, 0.5, 0),
            Name = "Icon", Parent = NavBtnFrame,
        })

        local NavLabel = New("TextLabel", {
            BorderSizePixel = 0, TextSize = 17, FontFace = RFont,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1, TextColor3 = T.TextSecondary,
            Text = pageName,
            Position = UDim2.new(0, 36, 0, 0),
            Size     = UDim2.new(1, -36, 1, 0),
            Name = "Label", Parent = NavBtnFrame,
        })
        New("UIPadding", { PaddingLeft = UDim.new(0, 40), Parent = NavBtnFrame })

        local NavBtn = New("TextButton", {
            BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0),
            Text = "", AutoButtonColor = false, ZIndex = 5, Parent = NavBtnFrame,
        })

        Page.NavBtnFrame = NavBtnFrame
        Page.NavIcon     = NavIcon
        Page.NavLabel    = NavLabel
        Page.NavBtn      = NavBtn

        local function Activate()
            for _, p in ipairs(Window.Pages) do
                if p ~= Page and p.Active then
                    p.Active = false
                    p.Frame.Visible = false
                    Tween(p.NavBtnFrame, { BackgroundTransparency = 1, BackgroundColor3 = T.NavActive })
                    Tween(p.NavLabel,    { TextColor3 = T.TextSecondary })
                    Tween(p.NavIcon,     { ImageColor3 = T.TextSecondary })
                end
            end
            Page.Active = true
            PageFrame.Visible = true
            Tween(NavBtnFrame, { BackgroundTransparency = 0.3, BackgroundColor3 = T.NavActive })
            Tween(NavLabel,    { TextColor3 = T.TextPrimary })
            Tween(NavIcon,     { ImageColor3 = T.Accent })
            
            -- Animate sections popping up from below
            for _, section in ipairs(Page.Sections) do
                if section.Card then
                    section.Card.Position = UDim2.new(0, 0, 0, 20)
                    section.Card.BackgroundTransparency = 1
                    task.wait(0.03)
                    Tween(section.Card, { Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0.6 }, 0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                end
            end
        end

        Window._connStore:Add(NavBtn.MouseButton1Click:Connect(function()
            if not Page.Active then Activate() end
        end))
        Window._connStore:Add(NavBtn.MouseEnter:Connect(function()
            if not Page.Active then
                Tween(NavBtnFrame, { BackgroundTransparency = 0.5 })
                Tween(NavLabel,    { TextColor3 = T.TextPrimary })
            end
        end))
        Window._connStore:Add(NavBtn.MouseLeave:Connect(function()
            if not Page.Active then
                Tween(NavBtnFrame, { BackgroundTransparency = 1 })
                Tween(NavLabel,    { TextColor3 = T.TextSecondary })
            end
        end))

        if #Window.Pages == 0 then Activate() end
        table.insert(Window.Pages, Page)

