local function Tween(obj, props, duration, style, direction)
    TweenService:Create(
        obj,
        TweenInfo.new(
            duration  or 0.18,
            style     or Enum.EasingStyle.Quad,
            direction or Enum.EasingDirection.Out
        ),
        props
    ):Play()
end

local function New(class, props)
    local inst   = Instance.new(class)
    local parent = props.Parent
    props.Parent = nil
    for k, v in pairs(props) do inst[k] = v end
    if parent then inst.Parent = parent end
    return inst
end

local function SafeCall(fn, ...)
    local ok, err = pcall(fn, ...)
    if not ok then warn("[Da7muLibrary] callback error: " .. tostring(err)) end
end

local function Round(n, decimals)
    local mult = 10 ^ (decimals or 0)
    return math.floor(n * mult + 0.5) / mult
end

-- ── Connection store ────────────────────────────────────────────────────────
local function NewConnStore()
    local store = { _list = {} }
    function store:Add(c)
        table.insert(self._list, c)
        return c
    end
    function store:DisconnectAll()
        for _, c in ipairs(self._list) do
            if typeof(c) == "RBXScriptConnection" then c:Disconnect() end
        end
        self._list = {}
    end
    return store
end

-- ─────────────────────────────────────────────────────────────────────────────
--  Fixed Blur (resolved upward issue)
-- ─────────────────────────────────────────────────────────────────────────────
local function CreateBlur(frame, intensity)
    intensity = intensity or 0.45 -- Increased blur amount
    
    local BLUR_INSET = Vector2.new(10, 10)
    local PART_SIZE = 0.01
    local PART_TRANSPARENCY = 1 - 1e-7
    local bindName = "Da7muBlur_" .. tostring(math.random(1, 9999999))
    
    local dof = New("DepthOfFieldEffect", {
        FarIntensity = 0,
        NearIntensity = intensity,
        FocusDistance = 0.25,
        InFocusRadius = 0,
        Parent = Lighting,
    })
    
    local part = New("Part", {
        Size = Vector3.one * PART_SIZE,
        Anchored = true,
        CanCollide = false,
        CanTouch = false,
        CastShadow = false,
        Material = Enum.Material.Glass,
        Transparency = PART_TRANSPARENCY,
        Parent = Camera,
    })
    
    local mesh = New("BlockMesh", { Parent = part })
    
    local function rayPlaneIntersect(planePos, planeNormal, rayOrigin, rayDirection)
        local d = planeNormal:Dot(rayDirection)
        if math.abs(d) < 1e-6 then return rayOrigin end
        local t = planeNormal:Dot(planePos - rayOrigin) / d
        return rayOrigin + rayDirection * t
    end
    
    local function update()
        if not frame or not frame.Visible then
            part.Transparency = 1
            return
        end
        
        part.Transparency = PART_TRANSPARENCY
        
        -- Fixed: Proper corner calculations
        local topLeft = frame.AbsolutePosition + BLUR_INSET
        local bottomRight = frame.AbsolutePosition + frame.AbsoluteSize - BLUR_INSET
        
        local ray0 = Camera:ViewportPointToRay(topLeft.X, topLeft.Y, 1)
        local ray1 = Camera:ViewportPointToRay(bottomRight.X, bottomRight.Y, 1)
        
        local planeOrigin = Camera.CFrame.Position + Camera.CFrame.LookVector * (0.05 - Camera.NearPlaneZ)
        local planeNormal = Camera.CFrame.LookVector
        
        local p0 = rayPlaneIntersect(planeOrigin, planeNormal, ray0.Origin, ray0.Direction)
        local p1 = rayPlaneIntersect(planeOrigin, planeNormal, ray1.Origin, ray1.Direction)
        
        p0 = Camera.CFrame:PointToObjectSpace(p0)
        p1 = Camera.CFrame:PointToObjectSpace(p1)
        
        local size = p1 - p0
        local center = (p0 + p1) / 2
        
        mesh.Offset = center
        mesh.Scale = size / PART_SIZE
        
        dof.FocusDistance = 0.25 - Camera.NearPlaneZ
    end
    
    RunService:BindToRenderStep(bindName, Enum.RenderPriority.Camera.Value + 1, function()
        pcall(function()
            part.CFrame = Camera.CFrame
            update()
        end)
    end)
    
    return function()
        RunService:UnbindFromRenderStep(bindName)
        pcall(function() part:Destroy() end)
        pcall(function() dof:Destroy() end)
    end
end

