    Da7muLibrary — Converted to full library format
    Original design by Da7mu
    
    USAGE:
    
    local Library = loadstring(...)()
    
    local Window = Library:Window({
        Name     = "My Hub",
        Logo     = "rbxassetid://...",
        Version  = "v1.0",
        Username = game.Players.LocalPlayer.Name,
