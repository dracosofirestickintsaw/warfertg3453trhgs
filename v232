        local function MakeSideScroll(xPos, xSize)
            local sf = Instance.new("ScrollingFrame", PageFrame)
            sf.BackgroundTransparency    = 1
            sf.BorderSizePixel           = 0
            sf.ScrollBarImageTransparency = 0.85
            sf.ScrollBarThickness        = 2
            sf.ScrollBarImageColor3      = Library.Theme.Accent
