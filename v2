    -- Content container
    local ContentContainer = New("Frame", {
        BorderSizePixel = 0, BackgroundTransparency = 1,
        Position = UDim2.new(0,228,0,66), Size = UDim2.new(1,-234,1,-72),
        ClipsDescendants = false,   -- must stay false so dropdowns aren't clipped
        Name = "ContentContainer", Parent = Main,
    })

    -- ── Spring-physics drag ───────────────────────────────────────────────────
    --  The window's position is driven by a damped spring — the spring target
    --  jumps to wherever the mouse says, but the rendered position follows
    --  with inertia.  STIFFNESS controls snappiness; DAMPING controls overshoot.
    --  Current values are critically damped (no bounce) with a ~80ms settle time.
    do
        local STIFFNESS = 160
        local DAMPING   = 22

        -- All values are pixel offsets from (0.5, 0, 0.5, 0)
        local springX, springY = 0, 0
        local velX,    velY    = 0, 0
        local targetX, targetY = 0, 0

        local dragging   = false
        local startMouse = Vector3.zero
        local startTX, startTY = 0, 0

        local cs = Window._connStore

        cs:Add(RunService.RenderStepped:Connect(function(dt)
            dt = math.min(dt, 0.05)
            local ax = STIFFNESS * (targetX - springX) - DAMPING * velX
            local ay = STIFFNESS * (targetY - springY) - DAMPING * velY
            velX = velX + ax * dt;  velY = velY + ay * dt
            springX = springX + velX * dt;  springY = springY + velY * dt
            Main.Position = UDim2.new(0.5, springX, 0.5, springY)
        end))

        cs:Add(Main.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
            local mp = input.Position
            if mp.Y <= Main.AbsolutePosition.Y + 62 then
                dragging   = true
                startMouse = mp
                startTX    = targetX
                startTY    = targetY
            end
        end))

        cs:Add(UserInputService.InputChanged:Connect(function(input)
            if not dragging then return end
            if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
            local vp    = Camera.ViewportSize
            local delta = input.Position - startMouse
            local hw    = Main.AbsoluteSize.X / 2
            local hh    = Main.AbsoluteSize.Y / 2
            targetX = math.clamp(startTX + delta.X, hw - vp.X/2, vp.X/2 - hw)
            targetY = math.clamp(startTY + delta.Y, hh - vp.Y/2, vp.Y/2 - hh)
        end))

        cs:Add(UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false   -- spring continues settling to targetX/Y naturally
            end
        end))
    end

    -- Keybind toggle
    Window._connStore:Add(UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == toggleKey then
            Window.IsOpen = not Window.IsOpen
            Main.Visible  = Window.IsOpen
        end
    end))

    Window.Main             = Main
    Window.ButtonHolder     = ButtonHolder
    Window.ContentContainer = ContentContainer

    -- ── Notifications  (fade + scale in / fade + scale out) ──────────────────
    local NotifHolder = New("Frame", {
        BorderSizePixel = 0, BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1,1), Position = UDim2.new(1,-16,1,-16),
        Size = UDim2.new(0,300,1,-32), Name = "NotifHolder", Parent = ScreenGui,
    })
    New("UIListLayout", {
        Padding = UDim.new(0,8), FillDirection = Enum.FillDirection.Vertical,
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        SortOrder = Enum.SortOrder.LayoutOrder, Parent = NotifHolder,
    })

    function Window:Notify(config)
        config = config or {}
        local title    = config.Title       or "Notification"
        local desc     = config.Description or ""
        local duration = config.Duration    or 5

        -- Container (starts fully invisible)
        local NotifFrame = New("Frame", {
            BorderSizePixel        = 0,
            BackgroundColor3       = T.Nav,
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, 0, 0, 0),
            AutomaticSize          = Enum.AutomaticSize.Y,
            ClipsDescendants       = true,
            Name                   = "Notification",
            Parent                 = NotifHolder,
        })
        New("UICorner", { CornerRadius = UDim.new(0,8), Parent = NotifFrame })
        local notifStroke = New("UIStroke", {
            Color = T.Stroke, Thickness = 1.2, Transparency = 1, Parent = NotifFrame,
        })
        New("UIPadding", {
            PaddingTop = UDim.new(0,10), PaddingBottom = UDim.new(0,10),
            PaddingLeft = UDim.new(0,12), PaddingRight = UDim.new(0,12),
            Parent = NotifFrame,
        })

        -- UIScale drives the pop-in / pop-out
        local notifScale = New("UIScale", { Scale = 0.92, Parent = NotifFrame })

        local TitleLbl = New("TextLabel", {
            BorderSizePixel = 0, TextSize = 14, FontFace = RFont,
            BackgroundTransparency = 1, TextColor3 = T.TextPrimary,
            TextTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left, Text = title,
            Size = UDim2.new(1,0,0,18), Parent = NotifFrame,
        })
        local DescLbl = New("TextLabel", {
            BorderSizePixel = 0, TextSize = 12, FontFace = RFont,
            BackgroundTransparency = 1, TextColor3 = T.TextMuted,
            TextTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true, Text = desc,
            Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y,
            Position = UDim2.new(0,0,0,22), Parent = NotifFrame,
        })

        local ProgBg = New("Frame", {
            BorderSizePixel = 0, BackgroundColor3 = T.Track,
            Size = UDim2.new(1,0,0,3), AnchorPoint = Vector2.new(0,1),
            Position = UDim2.new(0,0,1,6), Parent = NotifFrame,
        })
        local ProgFill = New("Frame", {
            BorderSizePixel = 0, BackgroundColor3 = T.Accent,
            Size = UDim2.new(1,0,1,0), Parent = ProgBg,
        })
        New("UICorner", { Parent = ProgBg })
        New("UICorner", { Parent = ProgFill })

        -- ── Fade in ──────────────────────────────────────────────────────────
        local IN_T = 0.22
        Tween(NotifFrame,  { BackgroundTransparency = 0.1  }, IN_T)
        Tween(notifStroke, { Transparency = 0              }, IN_T)
        Tween(notifScale,  { Scale = 1.0                   }, IN_T,
              Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        Tween(TitleLbl,    { TextTransparency = 0          }, IN_T)
        Tween(DescLbl,     { TextTransparency = 0          }, IN_T)

        -- Progress drain
        TweenService:Create(ProgFill, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 1, 0),
        }):Play()

        -- ── Fade out ─────────────────────────────────────────────────────────
        task.delay(duration, function()
            local OUT_T = 0.2
            Tween(NotifFrame,  { BackgroundTransparency = 1 }, OUT_T)
            Tween(notifStroke, { Transparency = 1           }, OUT_T)
            Tween(notifScale,  { Scale = 0.92              }, OUT_T)
            Tween(TitleLbl,    { TextTransparency = 1       }, OUT_T)
            Tween(DescLbl,     { TextTransparency = 1       }, OUT_T)
            task.wait(OUT_T + 0.05)
            if NotifFrame and NotifFrame.Parent then
                NotifFrame:Destroy()
            end
        end)

        return NotifFrame
    end

    -- ── Destroy ───────────────────────────────────────────────────────────────
    function Window:Destroy()
