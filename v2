        New("UICorner", { Parent = NavBtnFrame })

        -- Icon — locked to the left edge, vertically centred
        local NavIcon = New("ImageLabel", {
            BorderSizePixel = 0, BackgroundTransparency = 1,
            ImageColor3 = T.TextSecondary,
            AnchorPoint = Vector2.new(0, 0.5),
            Image = pageIcon,
            Size = UDim2.new(0, 18, 0, 18),
            Position = UDim2.new(0, 10, 0.5, 0),   -- 10 px from left
            Name = "Icon", Parent = NavBtnFrame,
        })

        -- Text — starts at x=36 (10 left-pad + 18 icon + 8 gap)
        local NavLabel = New("TextLabel", {
            BorderSizePixel = 0, TextSize = 15, FontFace = RFont,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1, TextColor3 = T.TextSecondary,
            Text = pageName,
            Position = UDim2.new(0, 36, 0, 0),
            Size     = UDim2.new(1, -36, 1, 0),
            Name = "Label", Parent = NavBtnFrame,
        })

        -- Invisible click overlay
        local NavBtn = New("TextButton", {
            BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0),
            Text = "", AutoButtonColor = false, ZIndex = 5, Parent = NavBtnFrame,
        })

        Page.NavBtnFrame = NavBtnFrame
        Page.NavIcon     = NavIcon
        Page.NavLabel    = NavLabel
        Page.NavBtn      = NavBtn

        local function Activate()
            for _, p in ipairs(Window.Pages) do
                if p ~= Page and p.Active then
                    p.Active = false; p.Frame.Visible = false
                    Tween(p.NavBtnFrame, { BackgroundTransparency = 1   })
                    Tween(p.NavLabel,    { TextColor3 = T.TextSecondary  })
                    Tween(p.NavIcon,     { ImageColor3 = T.TextSecondary })
                end
            end
            Page.Active = true; PageFrame.Visible = true
            Tween(NavBtnFrame, { BackgroundTransparency = 0.05 })
            Tween(NavLabel,    { TextColor3  = T.TextPrimary  })
            Tween(NavIcon,     { ImageColor3 = T.Accent       })
        end

        Window._connStore:Add(NavBtn.MouseButton1Click:Connect(function()
            if not Page.Active then Activate() end
        end))
        Window._connStore:Add(NavBtn.MouseEnter:Connect(function()
            if not Page.Active then
                Tween(NavBtnFrame, { BackgroundTransparency = 0.3  })
                Tween(NavLabel,    { TextColor3 = T.TextPrimary    })
            end
        end))
        Window._connStore:Add(NavBtn.MouseLeave:Connect(function()
            if not Page.Active then
                Tween(NavBtnFrame, { BackgroundTransparency = 1     })
                Tween(NavLabel,    { TextColor3 = T.TextSecondary   })
            end
        end))

        if #Window.Pages == 0 then Activate() end
        table.insert(Window.Pages, Page)

        -- ── Section ───────────────────────────────────────────────────────────
        function Page:Section(config)
            config = config or {}
            local sectionName = config.Name or "Section"
            local side        = config.Side or 1
            local column      = (side == 2) and self.Side2 or self.Side1

            local Section = { Page = self }

            New("TextLabel", {
                BorderSizePixel = 0, TextSize = 11, FontFace = RFont,
                BackgroundTransparency = 1, TextColor3 = T.TextMuted,
                TextXAlignment = Enum.TextXAlignment.Left,
                Text = string.upper(sectionName),
                Size = UDim2.new(1,0,0,14), Parent = column,
            })

            local Card = New("Frame", {
                BorderSizePixel = 0, BackgroundColor3 = T.Section,
                BackgroundTransparency = 0.35,
                Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y,
                Name = sectionName, Parent = column,
            })
            New("UICorner", { CornerRadius = UDim.new(0,10), Parent = Card })
            New("UIStroke", {
                Transparency = 0.07, Thickness = 1.3, Color = T.Stroke, Parent = Card,
            })
            New("UIPadding", {
                PaddingTop = UDim.new(0,8), PaddingBottom = UDim.new(0,10),
                PaddingLeft = UDim.new(0,10), PaddingRight = UDim.new(0,10),
                Parent = Card,
            })
            New("UIListLayout", {
                Padding = UDim.new(0,2), SortOrder = Enum.SortOrder.LayoutOrder,
                Parent = Card,
            })

            Section.Card = Card

            -- ── Toggle ────────────────────────────────────────────────────────
            function Section:Toggle(config)
                config = config or {}
                local name     = config.Name     or "Toggle"
                local flag     = config.Flag     or name
                local default  = config.Default  or false
                local callback = config.Callback or function() end
                local value    = default

                local Row = New("Frame", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,30), Name = name, Parent = Card,
                })
                New("UIPadding", {
                    PaddingTop = UDim.new(0,2), PaddingBottom = UDim.new(0,2),
                    PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                    Parent = Row,
                })
                local Title = New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 15,
                    TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                    BackgroundTransparency = 1,
                    TextColor3 = default and T.TextPrimary or T.TextDim,
                    Text = name, Size = UDim2.new(1,-56,1,0), Parent = Row,
                })
                local Pill = New("Frame", {
                    BorderSizePixel = 0,
                    BackgroundColor3 = default and T.AccentDark or T.ToggleOff,
                    Size = UDim2.new(0,44,0,24), AnchorPoint = Vector2.new(1,0.5),
                    Position = UDim2.new(1,0,0.5,0), Parent = Row,
                })
                New("UICorner", { CornerRadius = UDim.new(0,20), Parent = Pill })
                local Circle = New("Frame", {
                    BorderSizePixel = 0,
                    BackgroundColor3 = default and T.ToggleCircleOn or T.TextDim,
                    Size = UDim2.new(0,19,0,19),
                    Position = default and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,2,0.5,-9),
                    Parent = Pill,
                })
                New("UICorner", { CornerRadius = UDim.new(0,100), Parent = Circle })
                local ClickBtn = New("TextButton", {
                    BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0),
                    Text = "", AutoButtonColor = false, ZIndex = 5, Parent = Row,
                })

                Library.Flags[flag] = value
                local Toggle = { Value = value, Flag = flag }

                local function Apply(v, animated)
                    value = v; Toggle.Value = v; Library.Flags[flag] = v
                    local pc = v and T.AccentDark    or T.ToggleOff
                    local cc = v and T.ToggleCircleOn or T.TextDim
                    local cp = v and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,2,0.5,-9)
                    local tc = v and T.TextPrimary or T.TextDim
                    if animated then
                        Tween(Pill,   { BackgroundColor3 = pc })
                        Tween(Circle, { BackgroundColor3 = cc, Position = cp })
                        Tween(Title,  { TextColor3 = tc })
                    else
                        Pill.BackgroundColor3   = pc
                        Circle.BackgroundColor3 = cc
                        Circle.Position         = cp
                        Title.TextColor3        = tc
                    end
                    SafeCall(callback, v)
                end

                Apply(value, false)
                Window._connStore:Add(ClickBtn.MouseButton1Click:Connect(function()
                    Apply(not value, true)
                end))

                function Toggle:Set(v) Apply(v, true) end
                function Toggle:Get() return value    end
                return Toggle
            end

            -- ── Slider ────────────────────────────────────────────────────────
            function Section:Slider(config)
                config = config or {}
                local name     = config.Name     or "Slider"
                local flag     = config.Flag     or name
                local minV     = config.Min      or 0
                local maxV     = config.Max      or 100
                local default  = config.Default  or minV
                local decimals = config.Decimals or 0
                local suffix   = config.Suffix   or ""
                local callback = config.Callback or function() end
                local value    = default

                local Container = New("Frame", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,46), Name = name, Parent = Card,
                })
                New("UIPadding", {
                    PaddingTop = UDim.new(0,2), PaddingBottom = UDim.new(0,2),
                    PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                    Parent = Container,
                })
                New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 15,
                    TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextPrimary,
                    Text = name, Size = UDim2.new(0.6,0,0,20),
                    Position = UDim2.new(0,0,0,2), Parent = Container,
                })
                local ValueBg = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.ElementDark,
                    Size = UDim2.new(0,50,0,22), AnchorPoint = Vector2.new(1,0),
                    Position = UDim2.new(1,0,0,1), Parent = Container,
                })
                New("UICorner", { Parent = ValueBg })
                local ValueLabel = New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 13, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextValue,
                    Text = tostring(value)..suffix,
                    Size = UDim2.new(1,0,1,0), Parent = ValueBg,
                })
                local TrackBack = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Track,
                    Size = UDim2.new(1,-58,0,6), AnchorPoint = Vector2.new(0,1),
                    Position = UDim2.new(0,0,1,-2), Parent = Container,
                })
                New("UICorner", { Parent = TrackBack })
                local Fill = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Accent,
                    Size = UDim2.new(0,0,1,0), Parent = TrackBack,
                })
                New("UICorner", { Parent = Fill })
                local DragCircle = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.SliderCircle,
                    Size = UDim2.new(0,13,0,13), AnchorPoint = Vector2.new(0.5,0.5),
                    Position = UDim2.new(0,0,0.5,0), ZIndex = 3, Parent = TrackBack,
                })
                New("UICorner", { CornerRadius = UDim.new(0,100), Parent = DragCircle })

                Library.Flags[flag] = value
                local Slider  = { Value = value, Flag = flag }
                local sliding = false

                local function SetValue(v, animated)
                    v = Round(math.clamp(v, minV, maxV), decimals)
                    value = v; Slider.Value = v; Library.Flags[flag] = v
                    local t = (maxV ~= minV) and ((v-minV)/(maxV-minV)) or 0
                    if animated then
                        Tween(Fill,       { Size = UDim2.new(t,0,1,0)          })
                        Tween(DragCircle, { Position = UDim2.new(t,0,0.5,0)    })
                    else
                        Fill.Size = UDim2.new(t,0,1,0)
                        DragCircle.Position = UDim2.new(t,0,0.5,0)
                    end
                    ValueLabel.Text = tostring(v)..suffix
                    SafeCall(callback, v)
                end

                local function ProcessInput(pos)
                    local w = TrackBack.AbsoluteSize.X
                    if w == 0 then return end
                    SetValue(minV + (maxV-minV) * math.clamp(
                        (pos.X - TrackBack.AbsolutePosition.X) / w, 0, 1), false)
                end

                Window._connStore:Add(TrackBack.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = true; ProcessInput(input.Position)
                    end
                end))
                Window._connStore:Add(UserInputService.InputChanged:Connect(function(input)
                    if not sliding then return end
                    if input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch then
                        ProcessInput(input.Position)
                    end
                end))
                Window._connStore:Add(UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = false
                    end
                end))

                SetValue(value, false)
                function Slider:Set(v) SetValue(v, true) end
                function Slider:Get() return value       end
                return Slider
            end

            -- ── Dropdown  (fade + scale in / out) ─────────────────────────────
            function Section:Dropdown(config)
                config = config or {}
                local name     = config.Name     or "Dropdown"
                local flag     = config.Flag     or name
                local items    = config.Items    or {}
                local default  = config.Default  or ""
                local multi    = config.Multi    or false
                local callback = config.Callback or function() end

                local value   = multi and {} or default
                local isOpen  = false
                local closing = false

                local Outer = New("Frame", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,32), ClipsDescendants = false,
                    Name = name, Parent = Card,
                })
                local Header = New("Frame", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,30), Parent = Outer,
                })
                New("UIPadding", {
                    PaddingTop = UDim.new(0,2), PaddingBottom = UDim.new(0,2),
                    PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                    Parent = Header,
                })
                New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 15,
                    TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextPrimary,
                    Text = name..":", Size = UDim2.new(0.45,0,1,0), Parent = Header,
                })
                local ValueBox = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.ElementDark,
                    BackgroundTransparency = 0.4,
                    Size = UDim2.new(0.47,-14,0,22),
                    AnchorPoint = Vector2.new(1,0.5), Position = UDim2.new(1,-14,0.5,0),
                    Parent = Header,
                })
                New("UICorner", { CornerRadius = UDim.new(0,5), Parent = ValueBox })
                local ValueLabel = New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 12, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextSecondary,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = multi and "" or default,
                    Size = UDim2.new(1,-8,1,0), Position = UDim2.new(0,4,0,0),
                    Parent = ValueBox,
                })
                local Arrow = New("ImageLabel", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    ImageColor3 = T.TextMuted, AnchorPoint = Vector2.new(1,0.5),
                    Image = "rbxassetid://84949494757640",
                    Size = UDim2.new(0,10,0,10), Position = UDim2.new(1,0,0.5,0),
                    Parent = Header,
                })

                -- Options panel — parented to ScreenGui to escape all clipping
                local OptionsList = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.ElementDark,
                    BackgroundTransparency = 1,   -- invisible until open
                    Size = UDim2.new(0,200,0,0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Visible = false, ZIndex = 100,
                    Name = name.."_Options", Parent = ScreenGui,
                })
                New("UICorner", { CornerRadius = UDim.new(0,6), Parent = OptionsList })
                local ddStroke = New("UIStroke", {
                    Color = T.Stroke, Thickness = 1, Transparency = 1,
                    Parent = OptionsList,
                })
                New("UIPadding", {
                    PaddingTop = UDim.new(0,4), PaddingBottom = UDim.new(0,4),
                    PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                    Parent = OptionsList,
                })
                New("UIListLayout", {
                    Padding = UDim.new(0,2), SortOrder = Enum.SortOrder.LayoutOrder,
                    Parent = OptionsList,
                })
                local ddScale = New("UIScale", { Scale = 0.96, Parent = OptionsList })

                local Dropdown = { Value = value, Flag = flag, Options = {} }
                Library.Flags[flag] = value

                local DD_IN  = 0.18
                local DD_OUT = 0.13

                local function HighlightOption(opt, selected)
                    Tween(opt.Btn,   { BackgroundTransparency = selected and 0 or 1,
                                       BackgroundColor3 = T.AccentDark })
                    Tween(opt.Label, { TextColor3 = selected and T.TextPrimary or T.TextSecondary })
                end

                local function UpdateValueLabel()
                    ValueLabel.Text = multi
                        and (#Dropdown.Value > 0 and table.concat(Dropdown.Value, ", ") or "")
                        or  tostring(Dropdown.Value or "")
                end

                local function RepositionList()
                    local ap = Header.AbsolutePosition
                    local as = Header.AbsoluteSize
                    OptionsList.Position = UDim2.new(0, ap.X, 0, ap.Y + as.Y + 4)
                    OptionsList.Size     = UDim2.new(0, as.X, 0, 0)
                end

                local function OpenDropdown()
                    if isOpen then return end
                    isOpen = true; closing = false
                    RepositionList()
                    -- Reset to invisible before showing
                    OptionsList.BackgroundTransparency = 1
                    ddStroke.Transparency = 1
                    ddScale.Scale = 0.96
                    for _, o in ipairs(Dropdown.Options) do
                        o.Label.TextTransparency = 1
                    end
                    OptionsList.Visible = true
                    -- Animate in
                    Tween(OptionsList, { BackgroundTransparency = 0 }, DD_IN)
                    Tween(ddStroke,    { Transparency = 0           }, DD_IN)
                    Tween(ddScale,     { Scale = 1.0               }, DD_IN,
                          Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                    for _, o in ipairs(Dropdown.Options) do
                        Tween(o.Label, { TextTransparency = 0 }, DD_IN)
                    end
                    Tween(Arrow, { Rotation = 180 }, DD_IN)
                end

                local function CloseDropdown()
                    if not isOpen then return end
                    isOpen = false; closing = true
                    Tween(OptionsList, { BackgroundTransparency = 1 }, DD_OUT)
                    Tween(ddStroke,    { Transparency = 1           }, DD_OUT)
                    Tween(ddScale,     { Scale = 0.96              }, DD_OUT)
                    for _, o in ipairs(Dropdown.Options) do
                        Tween(o.Label, { TextTransparency = 1 }, DD_OUT)
                    end
                    Tween(Arrow, { Rotation = 0 }, DD_OUT)
                    task.delay(DD_OUT + 0.02, function()
                        if closing then
                            OptionsList.Visible = false; closing = false
                        end
                    end)
                end

                local HeaderBtn = New("TextButton", {
                    BackgroundTransparency = 1, Size = UDim2.new(1,0,0,30),
                    Text = "", AutoButtonColor = false, ZIndex = 4, Parent = Header,
                })
                Window._connStore:Add(HeaderBtn.MouseButton1Click:Connect(function()
                    if isOpen then CloseDropdown() else OpenDropdown() end
                end))

                Window._connStore:Add(UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                    if not isOpen then return end
                    local mp = input.Position
                    local ap = OptionsList.AbsolutePosition
                    local as = OptionsList.AbsoluteSize
                    local inside = mp.X >= ap.X and mp.X <= ap.X+as.X
                              and  mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y
                    if not inside then CloseDropdown() end
                end))

                local function AddOption(item)
                    local optBtn = New("TextButton", {
                        BorderSizePixel = 0, BackgroundColor3 = T.AccentDark,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1,0,0,26), ZIndex = 101,
                        AutoButtonColor = false, Text = "",
                        Name = tostring(item), Parent = OptionsList,
                    })
                    New("UICorner", { CornerRadius = UDim.new(0,5), Parent = optBtn })
                    local optLabel = New("TextLabel", {
                        BorderSizePixel = 0, TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                        BackgroundTransparency = 1, TextColor3 = T.TextSecondary,
                        TextTransparency = 1,   -- hidden until dropdown opens
                        ZIndex = 102, Text = tostring(item),
                        Size = UDim2.new(1,-8,1,0), Position = UDim2.new(0,8,0,0),
                        Parent = optBtn,
                    })
                    local optData = { Value = item, Btn = optBtn, Label = optLabel }
                    table.insert(Dropdown.Options, optData)

                    Window._connStore:Add(optBtn.MouseButton1Click:Connect(function()
                        if multi then
                            local idx = table.find(Dropdown.Value, item)
                            if idx then
                                table.remove(Dropdown.Value, idx)
                                HighlightOption(optData, false)
                            else
                                table.insert(Dropdown.Value, item)
                                HighlightOption(optData, true)
                            end
                            Library.Flags[flag] = Dropdown.Value
                            UpdateValueLabel(); SafeCall(callback, Dropdown.Value)
                        else
                            Dropdown.Value = item; Library.Flags[flag] = item
                            for _, o in ipairs(Dropdown.Options) do
                                HighlightOption(o, o.Value == item)
                            end
                            UpdateValueLabel(); SafeCall(callback, item)
                            CloseDropdown()
                        end
                    end))
                    return optData
                end

                for _, item in ipairs(items) do AddOption(item) end

                if not multi and default ~= "" then
                    for _, o in ipairs(Dropdown.Options) do
                        HighlightOption(o, o.Value == default)
                    end
                    Library.Flags[flag] = default
                end

                function Dropdown:Set(v)
                    if multi then
                        if type(v) ~= "table" then v = {v} end
                        Dropdown.Value = v; Library.Flags[flag] = v
                        for _, o in ipairs(Dropdown.Options) do
                            HighlightOption(o, table.find(v, o.Value) ~= nil)
                        end
                    else
                        Dropdown.Value = v; Library.Flags[flag] = v
                        for _, o in ipairs(Dropdown.Options) do
                            HighlightOption(o, o.Value == v)
                        end
                    end
                    UpdateValueLabel(); SafeCall(callback, Dropdown.Value)
                end
                function Dropdown:Refresh(newItems)
                    for _, o in ipairs(Dropdown.Options) do o.Btn:Destroy() end
                    Dropdown.Options = {}
                    for _, item in ipairs(newItems) do AddOption(item) end
                end
                function Dropdown:Get() return Dropdown.Value end
                return Dropdown
            end

            -- ── Button ────────────────────────────────────────────────────────
            function Section:Button(config)
                config = config or {}
                local name     = config.Name     or "Button"
                local callback = config.Callback or function() end

                local Btn = New("TextButton", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Accent,
                    BackgroundTransparency = 0.82,
                    Size = UDim2.new(1,0,0,30), AutoButtonColor = false,
                    Text = "", Name = name, Parent = Card,
                })
                New("UICorner", { CornerRadius = UDim.new(0,6), Parent = Btn })
                New("UIStroke", { Color = T.Accent, Transparency = 0.65, Thickness = 1, Parent = Btn })
                New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 14, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextPrimary,
                    Text = name, Size = UDim2.new(1,0,1,0), Parent = Btn,
                })
                Window._connStore:Add(Btn.MouseEnter:Connect(function()
                    Tween(Btn, { BackgroundTransparency = 0.55 })
                end))
                Window._connStore:Add(Btn.MouseLeave:Connect(function()
                    Tween(Btn, { BackgroundTransparency = 0.82 })
                end))
                Window._connStore:Add(Btn.MouseButton1Click:Connect(function()
                    Tween(Btn, { BackgroundTransparency = 0.25 })
                    task.delay(0.15, function()
                        Tween(Btn, { BackgroundTransparency = 0.82 })
                    end)
                    SafeCall(callback)
                end))
                return { Name = name, Instance = Btn }
            end

            -- ── Label ─────────────────────────────────────────────────────────
            function Section:Label(config)
                config = config or {}
                local text = config.Text or config.Name or "Label"
                local Lbl = New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextMuted,
                    Text = text, Size = UDim2.new(1,0,0,22),
                    Name = "Label_"..text, Parent = Card,
                })
                local Label = { Instance = Lbl }
                function Label:SetText(t) Lbl.Text = tostring(t) end
                function Label:SetColor(c) Lbl.TextColor3 = c    end
                return Label
            end

            -- ── Separator ─────────────────────────────────────────────────────
            function Section:Separator()
                New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Stroke,
                    Size = UDim2.new(1,0,0,1), Parent = Card,
                })
                return self
            end

            return Section
        end  -- Page:Section

        return Page
    end  -- Window:Page

    return Window
end  -- Library:Window

-- ─────────────────────────────────────────────────────────────────────────────
return Library
