	CheckFrame.Size = UDim2.fromOffset(18, 18)
	CheckFrame.Parent = Holder
	MakeCorner(CheckFrame, UDim.new(0.1, 1))

	local CheckIcon = Instance.new("ImageLabel")
	CheckIcon.Name = "CheckIcon"
	CheckIcon.BackgroundTransparency = 1
	CheckIcon.Image = "rbxassetid://10709790644"
	CheckIcon.ImageColor3 = Color3.new(0, 0, 0)
	CheckIcon.Position = UDim2.new(0.045, 1, 0, 2)
	CheckIcon.Size = UDim2.fromOffset(15, 15)
	CheckIcon.ImageTransparency = state and 0 or 1
	CheckIcon.Parent = CheckFrame

	local NameLabel = Instance.new("TextLabel")
	NameLabel.Name = "NameLabel"
	NameLabel.BackgroundTransparency = 1
	NameLabel.FontFace = DefaultFont
	NameLabel.Position = UDim2.fromOffset(23, -1)
	NameLabel.Size = UDim2.fromOffset(300, 22)
	NameLabel.Text = name
	NameLabel.TextColor3 = state and ActiveTextColor or InactiveTextColor
	NameLabel.TextSize = 17
	NameLabel.TextXAlignment = Enum.TextXAlignment.Left
	NameLabel.Parent = Holder

	local Button = Instance.new("TextButton")
	Button.Name = "Button"
	Button.BackgroundTransparency = 1
	Button.Size = UDim2.new(1, 0, 1, 0)
	Button.Text = ""
	Button.Parent = Holder

	local baseCheckColor = state and AccentColor or ElementColor
	local hoverCheckColor = state and Color3.fromRGB(180, 158, 255) or Color3.fromRGB(34, 34, 34)

	Button.MouseEnter:Connect(function()
		if not state then
			Tween(CheckFrame, {BackgroundColor3 = Color3.fromRGB(34, 34, 34)}, 0.15)
		else
			Tween(CheckFrame, {BackgroundColor3 = Color3.fromRGB(180, 158, 255)}, 0.15)
		end
		Tween(NameLabel, {TextColor3 = state and ActiveTextColor or Color3.fromRGB(170, 170, 170)}, 0.15)
	end)

	Button.MouseLeave:Connect(function()
		if not state then
			Tween(CheckFrame, {BackgroundColor3 = ElementColor}, 0.15)
		else
			Tween(CheckFrame, {BackgroundColor3 = AccentColor}, 0.15)
		end
		Tween(NameLabel, {TextColor3 = state and ActiveTextColor or InactiveTextColor}, 0.15)
	end)

	Button.MouseButton1Click:Connect(function()
		state = not state

		if state then
			Tween(CheckFrame, {BackgroundColor3 = AccentColor}, 0.2)
			Tween(CheckIcon, {ImageTransparency = 0}, 0.2)
			Tween(NameLabel, {TextColor3 = ActiveTextColor}, 0.2)
		else
			Tween(CheckFrame, {BackgroundColor3 = ElementColor}, 0.2)
			Tween(CheckIcon, {ImageTransparency = 1}, 0.2)
			Tween(NameLabel, {TextColor3 = InactiveTextColor}, 0.2)
		end

		callback(state)
	end)

	local elemData = {
		Name = name,
		_state = state,
		Set = function(self, val)
			state = val
			if state then
				Tween(CheckFrame, {BackgroundColor3 = AccentColor}, 0.2)
				Tween(CheckIcon, {ImageTransparency = 0}, 0.2)
				Tween(NameLabel, {TextColor3 = ActiveTextColor}, 0.2)
			else
				Tween(CheckFrame, {BackgroundColor3 = ElementColor}, 0.2)
				Tween(CheckIcon, {ImageTransparency = 1}, 0.2)
				Tween(NameLabel, {TextColor3 = InactiveTextColor}, 0.2)
			end
			callback(state)
		end,
		Get = function(self)
			return state
		end,
	}

	return elemData
end

