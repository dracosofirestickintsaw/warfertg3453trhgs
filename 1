	SliderFill.Parent = SliderBg
	MakeCorner(SliderFill)

	local SliderButton = Instance.new("TextButton")
	SliderButton.Name = "SliderButton"
	SliderButton.BackgroundTransparency = 1
	SliderButton.Position = UDim2.fromOffset(0, 15)
	SliderButton.Size = UDim2.fromOffset(418, 15)
	SliderButton.Text = ""
	SliderButton.Parent = Holder

	SliderButton.MouseEnter:Connect(function()
		Tween(SliderBg, {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}, 0.15)
	end)

	SliderButton.MouseLeave:Connect(function()
		Tween(SliderBg, {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}, 0.15)
	end)

	local dragging = false

	local function updateSlider(inputX)
		local bgPos = SliderBg.AbsolutePosition.X
		local bgSize = SliderBg.AbsoluteSize.X
		local rel = math.clamp((inputX - bgPos) / bgSize, 0, 1)
		value = math.floor(min + rel * (max - min) + 0.5)
		local fillWidth = rel * 418
		Tween(SliderFill, {Size = UDim2.fromOffset(fillWidth, 3)}, 0.05, Enum.EasingStyle.Linear)
		ValueLabel.Text = tostring(value) .. suffix
		callback(value)
	end

	SliderButton.MouseButton1Down:Connect(function(x, y)
		dragging = true
		updateSlider(x)
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateSlider(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	local elemData = {
		Name = name,
		Set = function(self, val)
			value = math.clamp(val, min, max)
			local rel = (value - min) / (max - min)
			Tween(SliderFill, {Size = UDim2.fromOffset(rel * 418, 3)}, 0.2)
			ValueLabel.Text = tostring(value) .. suffix
			callback(value)
		end,
		Get = function(self)
			return value
		end,
	}

	return elemData
end

function Library._createDropdown(sectionData, cfg)
	local lib = sectionData._library
	local name = cfg.Name or "Dropdown"
	local options = cfg.Options or {}
	local multiSelect = cfg.MultiSelect or false
	local default = cfg.Default or (multiSelect and {} or nil)
	local callback = cfg.Callback or function() end

	local selected = multiSelect and {} or nil
	local isOpen = false

	if multiSelect then
		if type(default) == "table" then
			for _, v in ipairs(default) do
				selected[v] = true
			end
		end
	else
		selected = default
	end

	local function getDisplayText()
		if multiSelect then
			local parts = {}
			for _, opt in ipairs(options) do
				if selected[opt] then
					table.insert(parts, opt)
				end
			end
			if #parts == 0 then
				return "none"
			end
			return table.concat(parts, ", ")
		else
			return selected or "none"
		end
	end

	local function hasSelection()
		if multiSelect then
			for _, opt in ipairs(options) do
				if selected[opt] then return true end
			end
			return false
		else
			return selected ~= nil
		end
	end

	local Holder = Instance.new("Frame")
	Holder.Name = "Dropdown_" .. name
	Holder.BackgroundTransparency = 1
	Holder.Size = UDim2.fromOffset(418, 44)
	Holder.ClipsDescendants = false
	Holder.Parent = sectionData._elemHolder

	local NameLabel = Instance.new("TextLabel")
	NameLabel.Name = "NameLabel"
	NameLabel.BackgroundTransparency = 1
	NameLabel.FontFace = DefaultFont
	NameLabel.Position = UDim2.fromOffset(0, 0)
	NameLabel.Size = UDim2.fromOffset(300, 18)
	NameLabel.Text = name
	NameLabel.TextColor3 = hasSelection() and ActiveTextColor or InactiveTextColor
	NameLabel.TextSize = 17
	NameLabel.TextXAlignment = Enum.TextXAlignment.Left
	NameLabel.TextYAlignment = Enum.TextYAlignment.Top
	NameLabel.Parent = Holder

	local DropdownFrame = Instance.new("Frame")
	DropdownFrame.Name = "DropdownFrame"
	DropdownFrame.BackgroundColor3 = ElementColor
	DropdownFrame.Position = UDim2.fromOffset(0, 20)
	DropdownFrame.Size = UDim2.fromOffset(418, 25)
	DropdownFrame.ClipsDescendants = false
	DropdownFrame.Parent = Holder
	MakeCorner(DropdownFrame, UDim.new(0.1, 1))

	local DisplayText = Instance.new("TextLabel")
	DisplayText.Name = "DisplayText"
	DisplayText.BackgroundTransparency = 1
	DisplayText.FontFace = DefaultFont
	DisplayText.Position = UDim2.fromOffset(12, 0)
	DisplayText.Size = UDim2.fromOffset(380, 25)
	DisplayText.Text = getDisplayText()
	DisplayText.TextColor3 = hasSelection() and ActiveTextColor or InactiveTextColor
	DisplayText.TextSize = 17
	DisplayText.TextXAlignment = Enum.TextXAlignment.Left
	DisplayText.TextTruncate = Enum.TextTruncate.AtEnd
	DisplayText.Parent = DropdownFrame

	local ArrowIcon = Instance.new("ImageLabel")
	ArrowIcon.Name = "ArrowIcon"
	ArrowIcon.BackgroundTransparency = 1
	ArrowIcon.Image = "rbxassetid://108899987138167"
	ArrowIcon.ImageColor3 = AccentColor
	ArrowIcon.Position = UDim2.fromOffset(398, 5)
	ArrowIcon.Size = UDim2.fromOffset(15, 15)
	ArrowIcon.Parent = DropdownFrame

	local DropButton = Instance.new("TextButton")
	DropButton.Name = "DropButton"
	DropButton.BackgroundTransparency = 1
	DropButton.Size = UDim2.new(1, 0, 1, 0)
	DropButton.Text = ""
	DropButton.Parent = DropdownFrame

	local OptionsFrame = Instance.new("Frame")
	OptionsFrame.Name = "OptionsFrame"
	OptionsFrame.BackgroundColor3 = ElementColor
	OptionsFrame.Position = UDim2.new(0, 0, 1, 3)
	OptionsFrame.Size = UDim2.fromOffset(418, 0)
	OptionsFrame.ClipsDescendants = true
	OptionsFrame.ZIndex = 10
	OptionsFrame.Visible = false
	OptionsFrame.Parent = DropdownFrame
	MakeCorner(OptionsFrame, UDim.new(0.05, 1))

	local OptionsListHolder = Instance.new("Frame")
	OptionsListHolder.Name = "OptionsListHolder"
	OptionsListHolder.BackgroundTransparency = 1
	OptionsListHolder.Size = UDim2.new(1, 0, 0, 0)
	OptionsListHolder.AutomaticSize = Enum.AutomaticSize.Y
	OptionsListHolder.Parent = OptionsFrame
	MakePadding(OptionsListHolder, 4, 4, 0, 0)
	MakeListLayout(OptionsListHolder, 0)

	DropButton.MouseEnter:Connect(function()
		Tween(DropdownFrame, {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}, 0.15)
	end)

	DropButton.MouseLeave:Connect(function()
		Tween(DropdownFrame, {BackgroundColor3 = ElementColor}, 0.15)
	end)

	local optionButtons = {}

	local function refreshOptions()
		for _, btn in ipairs(optionButtons) do
			btn:Destroy()
		end
		optionButtons = {}

		for _, opt in ipairs(options) do
			local isSelected = multiSelect and selected[opt] or (selected == opt)

			local OptBtn = Instance.new("TextButton")
			OptBtn.Name = "Option_" .. opt
			OptBtn.BackgroundTransparency = 1
			OptBtn.Size = UDim2.fromOffset(418, 25)
			OptBtn.Text = ""
			OptBtn.ZIndex = 11
			OptBtn.Parent = OptionsListHolder

			local OptLabel = Instance.new("TextLabel")
			OptLabel.Name = "OptLabel"
			OptLabel.BackgroundTransparency = 1
			OptLabel.FontFace = DefaultFont
			OptLabel.Position = UDim2.fromOffset(12, 0)
			OptLabel.Size = UDim2.fromOffset(394, 25)
			OptLabel.Text = opt
			OptLabel.TextColor3 = isSelected and ActiveTextColor or InactiveTextColor
			OptLabel.TextSize = 17
			OptLabel.TextXAlignment = Enum.TextXAlignment.Left
			OptLabel.ZIndex = 12
			OptLabel.Parent = OptBtn

			OptBtn.MouseEnter:Connect(function()
				local sel = multiSelect and selected[opt] or (selected == opt)
				if not sel then
					Tween(OptLabel, {TextColor3 = Color3.fromRGB(170, 170, 170)}, 0.1)
				else
					Tween(OptLabel, {TextColor3 = Color3.fromRGB(220, 210, 255)}, 0.1)
				end
			end)

			OptBtn.MouseLeave:Connect(function()
				local sel = multiSelect and selected[opt] or (selected == opt)
				Tween(OptLabel, {TextColor3 = sel and ActiveTextColor or InactiveTextColor}, 0.1)
			end)

			OptBtn.MouseButton1Click:Connect(function()
				if multiSelect then
					selected[opt] = not selected[opt]
				else
					selected = opt
					local getVals = {}
					for _, o in ipairs(options) do
						getVals[o] = (o == opt)
					end
				end

				DisplayText.Text = getDisplayText()
				local hasSel = hasSelection()
				DisplayText.TextColor3 = hasSel and ActiveTextColor or InactiveTextColor
				NameLabel.TextColor3 = hasSel and ActiveTextColor or InactiveTextColor

				if not multiSelect then
					local totalH = #options * 25 + 8
					Tween(OptionsFrame, {Size = UDim2.fromOffset(418, 0)}, 0.2)
					Tween(ArrowIcon, {Rotation = 0}, 0.2)
					task.delay(0.2, function()
						OptionsFrame.Visible = false
					end)
					isOpen = false
				end

				if multiSelect then
					local vals = {}
					for _, o in ipairs(options) do
						if selected[o] then table.insert(vals, o) end
					end
					callback(vals)
				else
					callback(selected)
				end

				refreshOptions()
			end)

			table.insert(optionButtons, OptBtn)
		end
	end

	refreshOptions()

	DropButton.MouseButton1Click:Connect(function()
		isOpen = not isOpen
		local totalH = #options * 25 + 8

		if isOpen then
			OptionsFrame.Visible = true
			OptionsFrame.Size = UDim2.fromOffset(418, 0)
			Tween(OptionsFrame, {Size = UDim2.fromOffset(418, totalH)}, 0.2)
			Tween(ArrowIcon, {Rotation = 180}, 0.2)
		else
			Tween(OptionsFrame, {Size = UDim2.fromOffset(418, 0)}, 0.2)
			Tween(ArrowIcon, {Rotation = 0}, 0.2)
			task.delay(0.2, function()
				OptionsFrame.Visible = false
			end)
		end
	end)

	local elemData = {
		Name = name,
		Set = function(self, val)
			if multiSelect then
				selected = {}
				if type(val) == "table" then
					for _, v in ipairs(val) do
						selected[v] = true
					end
				end
			else
				selected = val
			end
			DisplayText.Text = getDisplayText()
			local hasSel = hasSelection()
			DisplayText.TextColor3 = hasSel and ActiveTextColor or InactiveTextColor
			NameLabel.TextColor3 = hasSel and ActiveTextColor or InactiveTextColor
			refreshOptions()
			if multiSelect then
				local vals = {}
				for _, o in ipairs(options) do
					if selected[o] then table.insert(vals, o) end
				end
				callback(vals)
			else
				callback(selected)
			end
		end,
		Get = function(self)
			if multiSelect then
				local vals = {}
				for _, o in ipairs(options) do
					if selected[o] then table.insert(vals, o) end
				end
				return vals
			else
				return selected
			end
		end,
	}

	return elemData
end

return Library
