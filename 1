	TabLabel.Parent = TabButton

	tabData._button = TabButton
	tabData._label = TabLabel

	table.insert(self._tabObjects, tabData)

	TabButton.MouseButton1Click:Connect(function()
		self:_selectTab(tabData)
	end)

	if #self._tabObjects == 1 then
		self:_selectTab(tabData)
	end

	local tabMeta = {}
	tabMeta.__index = tabMeta

	function tabMeta:Page(pageConfig)
		return Library._createSubPage(self, pageConfig)
	end

	setmetatable(tabData, tabMeta)
	return tabData
end

function Library:_selectTab(tabData)
	if self.ActiveTab == tabData then return end

	for _, t in ipairs(self._tabObjects) do
		Tween(t._label, {TextColor3 = InactiveTextColor}, 0.2)
	end

	Tween(tabData._label, {TextColor3 = AccentColor}, 0.2)

	local tabIndex = 1
	for i, t in ipairs(self._tabObjects) do
		if t == tabData then
			tabIndex = i
			break
		end
	end

	local targetY = 15 + (tabIndex - 1) * 30
	Tween(self.TabSelectedIndicator, {Position = UDim2.new(0.894, 6, 0, targetY)}, 0.2)

	if self.ActiveTab then
		for _, sp in ipairs(self.ActiveTab._subPageObjects) do
			sp._contentFrame.Visible = false
		end
	end

	self.ActiveTab = tabData

	if #tabData._subPageObjects > 0 then
		local firstVisible = nil

		for _, sp in ipairs(tabData._subPageObjects) do
			sp._button.Visible = true
		end

		if tabData._activeSubPage then
			self:_selectSubPage(tabData._activeSubPage)
		else
			self:_selectSubPage(tabData._subPageObjects[1])
		end
	end

	self:_rebuildSubPageBar()
end

function Library:_rebuildSubPageBar()
	for _, child in ipairs(self.SubPagesHolder:GetChildren()) do
		if child:IsA("TextButton") or child:IsA("TextLabel") then
			child:Destroy()
		end
	end

	if not self.ActiveTab then return end

	local subPages = self.ActiveTab._subPageObjects
	local totalWidth = 579
	local rightPadding = 15
	local spacing = 8
	local xOffset = totalWidth - rightPadding

	for i = #subPages, 1, -1 do
		local sp = subPages[i]
		local textSize = 20
		local approxWidth = #sp.Name * 8 + spacing

		xOffset = xOffset - approxWidth

		local SpBtn = Instance.new("TextButton")
		SpBtn.Name = "SubPageBtn_" .. sp.Name
		SpBtn.BackgroundTransparency = 1
		SpBtn.FontFace = DefaultFont
		SpBtn.Position = UDim2.fromOffset(xOffset, 9)
		SpBtn.Size = UDim2.fromOffset(approxWidth, 37)
		SpBtn.Text = string.lower(sp.Name)
		SpBtn.TextColor3 = InactiveTextColor
		SpBtn.TextSize = textSize
		SpBtn.TextXAlignment = Enum.TextXAlignment.Left
		SpBtn.Parent = self.SubPagesHolder

		sp._subBtn = SpBtn

		SpBtn.MouseButton1Click:Connect(function()
			self:_selectSubPage(sp)
		end)

		xOffset = xOffset - spacing
	end

	if self.ActiveTab._activeSubPage then
		self:_updateSubPageIndicator(self.ActiveTab._activeSubPage)
	end
end

function Library:_selectSubPage(subPageData)
	if not self.ActiveTab then return end

	for _, sp in ipairs(self.ActiveTab._subPageObjects) do
		sp._contentFrame.Visible = false
		if sp._subBtn then
			Tween(sp._subBtn, {TextColor3 = InactiveTextColor}, 0.2)
		end
	end

	subPageData._contentFrame.Visible = true
	if subPageData._subBtn then
		Tween(subPageData._subBtn, {TextColor3 = AccentColor}, 0.2)
	end

	self.ActiveTab._activeSubPage = subPageData
	self:_updateSubPageIndicator(subPageData)
end

function Library:_updateSubPageIndicator(subPageData)
	if subPageData._subBtn then
		local btn = subPageData._subBtn
		local btnPos = btn.Position
		local btnSize = btn.Size
		Tween(self.SubSelectedFrame, {
			Position = UDim2.fromOffset(btnPos.X.Offset, 53),
			Size = UDim2.fromOffset(btnSize.X.Offset, 4)
		}, 0.2)
	end
end

