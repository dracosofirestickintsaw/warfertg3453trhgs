        function CustomFont:New(Name, Weight, Style, Data)
            if not isfile(Data.Id) then
                writefile(Data.Id, game:HttpGet(Data.Url))
            end
            local FontData = {
                name = Name,
                faces = { { name = Name, weight = Weight, style = Style, assetId = getcustomasset(Data.Id) } }
            }
            writefile(Library.Directory .. "/" .. Name .. ".font", HttpService:JSONEncode(FontData))
            return Font.new(getcustomasset(Library.Directory .. "/" .. Name .. ".font"))
        end
        Library.Font = CustomFont:New("SourceSansPro", 400, "Regular", {
            Id = "SourceSansPro.ttf",
