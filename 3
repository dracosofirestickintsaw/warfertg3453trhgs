        end, function()
            Items["TrackBg"]:Tween({ BackgroundColor3 = Library.Theme.Element })
        end)

        Library:Connect(UserInputService.InputChanged, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement and Slider.Sliding then
                Slider:Set(Slider:GetValueFromInput(Input))
            end
        end)

        if Slider.Page and Slider.Page.Page and Slider.Page.Page.Search then
            table.insert(Slider.Page.Page.SearchItems, { Item = Items["Holder"], Name = Slider.Name })
        end

        Slider:Set(Slider.Default)
        SetFlags[Slider.Flag] = function(Value) Slider:Set(Value) end

        return setmetatable(Slider, Library)
    end

