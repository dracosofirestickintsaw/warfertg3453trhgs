            Slider.Value = Round(math.clamp(Value, Slider.Min, Slider.Max), Slider.Decimals)
            local pct = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
            Items["Fill"]:Tween({ Size = UDim2.new(pct, 0, 1, 0) })
