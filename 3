                Parent = OptionBtn.Instance,
                BackgroundTransparency = 1,
                FontFace = Library.Font,
                Position = UDim2.new(0, 12, 0, 0),
                Size = UDim2.new(1, -12, 1, 0),
                Text = Value,
                TextColor3 = Library.Theme.TextDim,
                TextSize = 17,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local OptionData = {
                Button = OptionBtn,
                Text   = OptionText,
                Name   = Value,
                IsSelected = false
            }

            function OptionData:ToggleState(State)
                if State == "Active" then
                    OptionData.Button:Tween({ BackgroundTransparency = 0 })
                    OptionData.Text:Tween({ TextColor3 = Library.Theme.Text, Position = UDim2.new(0, 22, 0, 0) })
                else
                    OptionData.Button:Tween({ BackgroundTransparency = 1 })
                    OptionData.Text:Tween({ TextColor3 = Library.Theme.TextDim, Position = UDim2.new(0, 12, 0, 0) })
                end
            end

            function OptionData:Set()
                OptionData.IsSelected = not OptionData.IsSelected

                if Dropdown.Multi then
                    local idx = table.find(Dropdown.Value, OptionData.Name)
                    if idx then
                        table.remove(Dropdown.Value, idx)
                        OptionData.IsSelected = false
                        OptionData:ToggleState("Inactive")
                    else
                        table.insert(Dropdown.Value, OptionData.Name)
                        OptionData.IsSelected = true
                        OptionData:ToggleState("Active")
                    end
                    Flags[Dropdown.Flag] = Dropdown.Value
                    Items["ValueLabel"].Instance.Text = #Dropdown.Value > 0 and table.concat(Dropdown.Value, ", ") or ""
                    Items["ValueLabel"].Instance.TextColor3 = #Dropdown.Value > 0 and Library.Theme.Text or Library.Theme.TextDim
                else
                    if OptionData.IsSelected then
                        Dropdown.Value = OptionData.Name
                        for _, v in Dropdown.Options do
                            v.IsSelected = v == OptionData
                            v:ToggleState(v == OptionData and "Active" or "Inactive")
                        end
                        Flags[Dropdown.Flag] = Dropdown.Value
                        Items["ValueLabel"].Instance.Text = OptionData.Name
                        Items["ValueLabel"].Instance.TextColor3 = Library.Theme.Text
                        Dropdown:SetOpen(false)
                    else
                        Dropdown.Value = nil
                        Flags[Dropdown.Flag] = nil
                        OptionData:ToggleState("Inactive")
                        Items["ValueLabel"].Instance.Text = ""
                        Items["ValueLabel"].Instance.TextColor3 = Library.Theme.TextDim
                    end
                end

                Library:SafeCall(Dropdown.Callback, Dropdown.Value)
            end

            OptionBtn:Connect("MouseButton1Down", function()
                OptionData:Set()
            end)

            OptionBtn:OnHover(function()
                if not OptionData.IsSelected then
                    OptionBtn:Tween({ BackgroundTransparency = 0.6 })
                    OptionData.Text:Tween({ TextColor3 = Library.Theme.Text })
                end
            end, function()
                if not OptionData.IsSelected then
                    OptionBtn:Tween({ BackgroundTransparency = 1 })
                    OptionData.Text:Tween({ TextColor3 = Library.Theme.TextDim })
                end
            end)

            Dropdown.Options[Value] = OptionData
            return OptionData
        end

        function Dropdown:Remove(OptionName)
            if Dropdown.Options[OptionName] then
                Dropdown.Options[OptionName].Button.Instance:Destroy()
                Dropdown.Options[OptionName] = nil
            end
        end

        function Dropdown:Refresh(List)
            for Name in Dropdown.Options do
                Dropdown:Remove(Name)
            end
            for _, Value in List do
                Dropdown:Add(Value)
            end
        end

        function Dropdown:Set(Value)
            if Dropdown.Multi then
                if type(Value) ~= "table" then return end
                Dropdown.Value = {}
                for _, v in Value do
                    if Dropdown.Options[v] then
                        table.insert(Dropdown.Value, v)
                        Dropdown.Options[v].IsSelected = true
                        Dropdown.Options[v]:ToggleState("Active")
                    end
                end
                Flags[Dropdown.Flag] = Dropdown.Value
                Items["ValueLabel"].Instance.Text = #Dropdown.Value > 0 and table.concat(Dropdown.Value, ", ") or ""
                Items["ValueLabel"].Instance.TextColor3 = #Dropdown.Value > 0 and Library.Theme.Text or Library.Theme.TextDim
            else
                if not Dropdown.Options[Value] then return end
                Dropdown.Value = Value
                for k, v in Dropdown.Options do
                    v.IsSelected = (k == Value)
                    v:ToggleState(k == Value and "Active" or "Inactive")
                end
                Flags[Dropdown.Flag] = Value
                Items["ValueLabel"].Instance.Text = Value
                Items["ValueLabel"].Instance.TextColor3 = Library.Theme.Text
            end
            Library:SafeCall(Dropdown.Callback, Dropdown.Value)
        end

        function Dropdown:SetVisibility(Bool)
            Items["Holder"].Instance.Visible = Bool
        end

        Items["DropBtn"]:Connect("MouseButton1Down", function()
            Dropdown:SetOpen(not Dropdown.IsOpen)
        end)

        Items["DropBtn"]:OnHover(function()
            Items["DropBtn"]:Tween({ BackgroundColor3 = Library.Theme.HoveredElement })
        end, function()
            Items["DropBtn"]:Tween({ BackgroundColor3 = Library.Theme.Element })
        end)

        Library:Connect(UserInputService.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                if Dropdown.IsOpen then
                    if not Items["OptionHolder"]:IsMouseOverFrame() then
                        Dropdown:SetOpen(false)
                    end
                end
            end
        end)

        for _, Value in Dropdown.OptionItems do
            Dropdown:Add(Value)
        end

        if Dropdown.Default ~= "" then
            Dropdown:Set(Dropdown.Default)
        end

        if Dropdown.Page and Dropdown.Page.Page and Dropdown.Page.Page.Search then
            table.insert(Dropdown.Page.Page.SearchItems, { Item = Items["Holder"], Name = Dropdown.Name })
        end

        SetFlags[Dropdown.Flag] = function(Value) Dropdown:Set(Value) end

        return setmetatable(Dropdown, Library)
    end

