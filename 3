    Library.Textbox = function(Self, Params)
        Params = Params or {}

        local Textbox = {
            Name        = Params.Name or Params.name or "Textbox",
            Flag        = Params.Flag or Params.flag or (Params.Name or Params.name),
            Default     = Params.Default or Params.default or "",
            Placeholder = Params.Placeholder or Params.placeholder or "",
            Numeric     = Params.Numeric or Params.numeric or false,
            Finished    = Params.Finished or Params.finished or false,
            Callback    = Params.Callback or Params.callback or function() end,
            Section     = Self,
            Page        = Self.Page,
            Value       = "",
            Items       = {}
        }

        local Items = {} do
            Items["Holder"] = Library:Create("Frame", {
                Parent = Textbox.Section.Items["Content"].Instance,
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 43),
                BackgroundColor3 = Library.Theme.Surface
            })

            Items["NameLabel"] = Library:Create("TextLabel", {
                Parent = Items["Holder"].Instance,
                BackgroundTransparency = 1,
                FontFace = Library.Font,
                Position = UDim2.new(0, 0, 0, 0),
                Size = UDim2.new(1, 0, 0, 19),
                Text = Textbox.Name,
                TextColor3 = Library.Theme.TextDim,
                TextSize = 17,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            Items["InputFrame"] = Library:Create("Frame", {
                Parent = Items["Holder"].Instance,
                BackgroundColor3 = Library.Theme.Accent,
                BorderSizePixel = 0,
                AnchorPoint = Vector2.new(0, 1),
                Position = UDim2.new(0, 0, 1, 0),
                Size = UDim2.new(1, 0, 0, 25)
            })

            Library:Create("UICorner", {
                Parent = Items["InputFrame"].Instance,
                CornerRadius = UDim.new(0, 3)
            })

            Items["Inner"] = Library:Create("TextButton", {
                Parent = Items["InputFrame"].Instance,
                BackgroundColor3 = Library.Theme.Element,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 3, 0, 0),
                Size = UDim2.new(1, -2, 1, 0),
                Text = "",
                AutoButtonColor = false
            })

            Library:Create("UICorner", {
                Parent = Items["Inner"].Instance,
                CornerRadius = UDim.new(0, 3)
            })

            Items["Input"] = Library:Create("TextBox", {
                Parent = Items["Inner"].Instance,
                BackgroundTransparency = 1,
                FontFace = Library.Font,
                PlaceholderColor3 = Library.Theme.TextDim,
                PlaceholderText = Textbox.Placeholder,
                AnchorPoint = Vector2.new(0, 0.5),
                Position = UDim2.new(0, 10, 0.5, -1),
                Size = UDim2.new(1, -20, 0, 17),
                Text = "",
                TextColor3 = Library.Theme.Text,
                TextSize = 17,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            Items["Inner"]:OnHover(function()
                Items["Inner"]:Tween({ BackgroundColor3 = Library.Theme.HoveredElement })
            end, function()
                Items["Inner"]:Tween({ BackgroundColor3 = Library.Theme.Element })
            end)

            Textbox.Items = Items
        end

        function Textbox:Set(Value)
            if Textbox.Numeric then
                if not tonumber(Value) and string.len(tostring(Value)) > 0 then
                    Value = Textbox.Value
                end
            end
            Textbox.Value = Value
            Items["Input"].Instance.Text = Value
            Flags[Textbox.Flag] = Value
            Library:SafeCall(Textbox.Callback, Value)
        end

        function Textbox:SetVisibility(Bool)
            Items["Holder"].Instance.Visible = Bool
        end

        if Textbox.Finished then
            Items["Input"]:Connect("FocusLost", function(Enter)
                if Enter then Textbox:Set(Items["Input"].Instance.Text) end
            end)
        else
            Library:Connect(Items["Input"].Instance:GetPropertyChangedSignal("Text"), function()
                Textbox:Set(Items["Input"].Instance.Text)
            end)
        end

        if Textbox.Page and Textbox.Page.Page and Textbox.Page.Page.Search then
            table.insert(Textbox.Page.Page.SearchItems, { Item = Items["Holder"], Name = Textbox.Name })
        end

        Textbox:Set(Textbox.Default)
        SetFlags[Textbox.Flag] = function(Value) Textbox:Set(Value) end

        return setmetatable(Textbox, Library)
    end
