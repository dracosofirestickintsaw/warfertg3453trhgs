        end

        local Debounce = false

        function Page:Turn(Bool)
            if Debounce then return end
            Debounce = true
            Page.Active = Bool

            if Bool then
                Items["TabText"]:Tween({ TextColor3 = Library.Theme.Accent })
                Page.Window.Items["SectionName"].Instance.Text = Page.Name

                if Page.Search then
                    Page.Window.Items["SearchHolder"].Instance.Visible = true
                    Page.Window.Items["SearchHolder"].Instance.Size = UDim2.new(1, 0, 0, 44)
                    Page.Window.Items["PageContent"].Instance.Position = UDim2.new(0, 0, 0, 89)
                    Page.Window.Items["PageContent"].Instance.Size = UDim2.new(1, 0, 1, -89)
                else
                    Page.Window.Items["SearchHolder"].Instance.Visible = false
                    Page.Window.Items["PageContent"].Instance.Position = UDim2.new(0, 0, 0, 45)
                    Page.Window.Items["PageContent"].Instance.Size = UDim2.new(1, 0, 1, -45)
                end

                Items["PageFrame"].Instance.Parent = Page.Window.Items["PageContent"].Instance
                Items["PageFrame"].Instance.Visible = true
                Items["PageFrame"]:FadeDescendants(true, function()
                    Debounce = false
                end)

                Page.Window:_UpdateIndicator(Items["TabButton"].Instance)
            else
                Items["TabText"]:Tween({ TextColor3 = Library.Theme.TextDim })
                Items["PageFrame"]:FadeDescendants(false, function()
                    Items["PageFrame"].Instance.Parent = Library.UnusedHolder.Instance
                    Debounce = false
                end)
            end
        end

        Items["TabButton"]:Connect("MouseButton1Down", function()
            for _, Value in Page.Window.Pages do
                if Value == Page and Page.Active then return end
                Value:Turn(Value == Page)
            end
        end)

        Items["TabButton"]:OnHover(function()
            if not Page.Active then
                Items["TabText"]:Tween({ TextColor3 = Library.Theme.Text })
            end
        end, function()
            if not Page.Active then
                Items["TabText"]:Tween({ TextColor3 = Library.Theme.TextDim })
            end
        end)

        if Page.Search then
            Library:Connect(Page.Window.Items["SearchInput"].Instance:GetPropertyChangedSignal("Text"), function()
                if Page.Active then
                    for _, Value in Page.SearchItems do
                        local name = Value.Name
                        local elem = Value.Item
                        if string.find(string.lower(name), string.lower(Page.Window.Items["SearchInput"].Instance.Text)) then
