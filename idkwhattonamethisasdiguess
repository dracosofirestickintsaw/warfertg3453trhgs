function WaitHRP(q0)
    if not q0 then return end
    return q0.Character:WaitForChild("HumanoidRootPart", 9)
end

function topos(Pos, onComplete)
    local plr = game.Players.LocalPlayer
    if not (plr.Character and plr.Character.Humanoid.Health > 0 and plr.Character:FindFirstChild("HumanoidRootPart")) then return end
    if not Pos then return end
    if activeTween then activeTween:Cancel(); activeTween = nil end
    local Distance = (Pos.Position - plr.Character.HumanoidRootPart.Position).Magnitude
    if plr.Character:FindFirstChild("PartTele") then plr.Character.PartTele:Destroy() end
    local PartTele = Instance.new("Part", plr.Character)
    PartTele.Size = Vector3.new(10, 1, 10)
    PartTele.Name = "PartTele"
    PartTele.Anchored = true
    PartTele.Transparency = 1
    PartTele.CanCollide = false
    PartTele.CFrame = WaitHRP(plr).CFrame
    PartTele:GetPropertyChangedSignal("CFrame"):Connect(function()
        if not isTeleporting then return end
        task.wait()
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            WaitHRP(plr).CFrame = PartTele.CFrame
        end
    end)
    isTeleporting = true
    local Tween = game:GetService("TweenService"):Create(
        PartTele,
        TweenInfo.new(Distance / tweenSpeed, Enum.EasingStyle.Linear),
        { CFrame = Pos }
    )
    activeTween = Tween
    Tween:Play()
    Tween.Completed:Connect(function(status)
        if plr.Character and plr.Character:FindFirstChild("PartTele") then
            plr.Character.PartTele:Destroy()
        end
        isTeleporting = false
        activeTween = nil
        if onComplete and status == Enum.PlaybackState.Completed then
            onComplete()
        end
    end)
end

local function titanIsAlive(titan)
    return titan and titan.Parent and titan:FindFirstChild("Humanoid") ~= nil
end

local function getClosestTitan(root)
    local titans = workspace:FindFirstChild("Titans")
    if not titans then return nil end
    local closest = nil
    local minDist = math.huge
    for _, titan in ipairs(titans:GetChildren()) do
        if not titanIsAlive(titan) then continue end
        local titanRoot = titan:FindFirstChild("HumanoidRootPart") or titan:FindFirstChildWhichIsA("BasePart")
        if titanRoot then
            local dist = (root.Position - titanRoot.Position).Magnitude
            if dist < minDist then minDist = dist; closest = titan end
        end
    end
    return closest
end

local function findGasTankRefill()
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc.Name == "GasTanks" then
            local refill = desc:FindFirstChild("Refill")
            if refill then return refill end
        end
    end
    return nil
end

local function getSetsText()
    local success, label = pcall(function()
        return game:GetService("Players").LocalPlayer.PlayerGui.Interface.HUD.Main.Top["7"].Blades.Sets
    end)
    if success and label then return label.Text end
