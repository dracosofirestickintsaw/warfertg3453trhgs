local function onAutoFarmInstant(value)
    multiNapeEnabled = value

    if not value then
        multiNapeClickActive = false
        if multiNapeFreezeConn then multiNapeFreezeConn:Disconnect(); multiNapeFreezeConn = nil end
        for _, data in ipairs(multiNapeThreads) do
            data.active = false
            disableNapeJoints(data.nape, false)
            if data.nape and data.nape.Parent then
                data.nape.Size = Vector3.new(8, 7, 8)
            end
        end
        multiNapeThreads = {}
        return
    end

    multiNapeThreads = {}
    task.spawn(function()
        local plr = game:GetService("Players").LocalPlayer
        local char = plr and plr.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local frozenCF = hrp.CFrame

        multiNapeFreezeConn = game:GetService("RunService").Heartbeat:Connect(function()
            if not multiNapeEnabled then return end
            local c = plr.Character
            if not c then return end
            local r = c:FindFirstChild("HumanoidRootPart")
            if not r then return end
            local partTele = c:FindFirstChild("PartTele")
            if partTele then
                r.CFrame = partTele.CFrame
            else
                r.CFrame = frozenCF
            end
        end)

        local highCF = CFrame.new(hrp.Position + Vector3.new(0, 300, 0))
        frozenCF = highCF
        topos(highCF)

        local arrivalTimeout = tick()
        while multiNapeEnabled do
            local curRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if not curRoot then break end
            if (curRoot.Position - highCF.Position).Magnitude < 15 then break end
            if tick() - arrivalTimeout > 6 then break end
            task.wait(0.05)
        end

        if activeTween then activeTween:Cancel(); activeTween = nil end
        isTeleporting = false
        if plr.Character and plr.Character:FindFirstChild("PartTele") then
            plr.Character.PartTele:Destroy()
        end

        if not multiNapeEnabled then
            if multiNapeFreezeConn then multiNapeFreezeConn:Disconnect(); multiNapeFreezeConn = nil end
            return
        end

        local curRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        if not curRoot then
            if multiNapeFreezeConn then multiNapeFreezeConn:Disconnect(); multiNapeFreezeConn = nil end
            return
        end
        frozenCF = curRoot.CFrame

        multiNapeClickActive = true
        task.spawn(function()
            while multiNapeClickActive do
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, true, game, 1)
                task.wait(0.05)
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, 0, false, game, 1)
                task.wait(0.05)
            end
        end)

        task.spawn(function()
            while multiNapeEnabled do
                pcall(checkSideEffects)
                task.wait(0.05)
            end
        end)

        while multiNapeEnabled do
            local curHrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if not curHrp then task.wait(0.1); continue end

            for _, nape in ipairs(getNapes()) do
                local alreadyTracked = false
                for _, data in ipairs(multiNapeThreads) do
                    if data.nape == nape then alreadyTracked = true; break end
                end

                if not alreadyTracked then
                    local data = { nape = nape, active = true }
                    table.insert(multiNapeThreads, data)

                    task.spawn(function()
                        local TweenService = game:GetService("TweenService")
                        local swingDistance = 12
                        local swingHeight = 0
                        disableNapeJoints(nape, true)

                        while data.active and multiNapeEnabled and nape and nape.Parent do
                            local hrp2 = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                            if not hrp2 then task.wait(0.05); continue end

                            nape.Size = Vector3.new(8, 7, 8)
                            nape.CFrame = hrp2.CFrame * CFrame.new(swingDistance, swingHeight, 0)

                            local tweenLeft = TweenService:Create(nape,
                                TweenInfo.new(0.18, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                                { CFrame = hrp2.CFrame * CFrame.new(-swingDistance, swingHeight, 0) }
                            )
                            tweenLeft:Play()
                            tweenLeft.Completed:Wait()
                            if not data.active or not multiNapeEnabled then break end

                            nape.CFrame = hrp2.CFrame
                            nape.Size = Vector3.new(150, 150, 150)
                            task.wait(0.1)
                            if not data.active or not multiNapeEnabled then break end

                            nape.Size = Vector3.new(8, 7, 8)
                            nape.CFrame = hrp2.CFrame * CFrame.new(-swingDistance, swingHeight, 0)

                            local tweenRight = TweenService:Create(nape,
                                TweenInfo.new(0.18, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                                { CFrame = hrp2.CFrame * CFrame.new(swingDistance, swingHeight, 0) }
                            )
                            tweenRight:Play()
                            tweenRight.Completed:Wait()
                            if not data.active or not multiNapeEnabled then break end

                            nape.CFrame = hrp2.CFrame
                            nape.Size = Vector3.new(150, 150, 150)
                            task.wait(0.1)
                        end

                        disableNapeJoints(nape, false)
                        if nape and nape.Parent then
                            nape.Size = Vector3.new(8, 7, 8)
                        end
                    end)
                end
            end

            for i = #multiNapeThreads, 1, -1 do
                local data = multiNapeThreads[i]
                if not data.nape or not data.nape.Parent then
                    data.active = false
                    table.remove(multiNapeThreads, i)
                end
            end

            task.wait(1)
        end

        multiNapeClickActive = false
        if multiNapeFreezeConn then multiNapeFreezeConn:Disconnect(); multiNapeFreezeConn = nil end
    end)
end

