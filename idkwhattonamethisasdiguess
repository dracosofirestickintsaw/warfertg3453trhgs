                    TextColor3 = Library.Theme.Text,
                    TextSize = 18,
                    ZIndex = 2
                })

                local TextGlow = self:Create("Frame", {
                    Name = "TextGlow",
                    Parent = SectionFrame.Instance,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.087, -23, 0.235, -37),
                    Size = UDim2.new(-0.493, 200, 0.017, 15),
