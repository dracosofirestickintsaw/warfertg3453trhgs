        Position = UDim2.new(0.828, 1, 0.968, 0),
        Size = UDim2.fromOffset(14, 14),
        ZIndex = 2
    })

    local HideCorner2 = self:Create("Frame", {
        Name = "HideCorner",
        Parent = TabHolder.Instance,
        BackgroundColor3 = self.Theme.Section,
        BorderColor3 = Color3.new(),
        BorderSizePixel = 0,
        Position = UDim2.new(0.828, 1, -0.004, 2),
