local function getNapes()
    local napes = {}
    local titans = workspace:FindFirstChild("Titans")
    if not titans then return napes end
    for _, titan in ipairs(titans:GetChildren()) do
        local hitboxes = titan:FindFirstChild("Hitboxes")
        if not hitboxes then continue end
        local hit = hitboxes:FindFirstChild("Hit")
        if not hit then continue end
        local nape = hit:FindFirstChild("Nape")
        if nape then table.insert(napes, nape) end
    end
    return napes
end

local function getNapeForTitan(titan)
    local hitboxes = titan:FindFirstChild("Hitboxes")
    if not hitboxes then return nil end
    local hit = hitboxes:FindFirstChild("Hit")
    if not hit then return nil end
    return hit:FindFirstChild("Nape")
end

