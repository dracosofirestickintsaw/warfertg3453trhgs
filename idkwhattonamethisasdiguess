local function setTitanAnchored(titan, state)
    if not titan or not titan.Parent then return end
    for _, part in ipairs(titan:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Anchored = state
        end
    end
end

local function disableNapeJoints(nape, state)
    if not nape then return end
    for _, c in ipairs(nape:GetChildren()) do
        if c:IsA("WeldConstraint") or c:IsA("Weld") or c:IsA("Motor6D") then
            c.Enabled = not state
        end
    end
    if nape.Parent then
        for _, c in ipairs(nape.Parent:GetChildren()) do
            if c:IsA("WeldConstraint") or c:IsA("Weld") or c:IsA("Motor6D") then
                if (c:IsA("WeldConstraint") and (c.Part0 == nape or c.Part1 == nape))
                    or (not c:IsA("WeldConstraint") and (c.Part0 == nape or c.Part1 == nape)) then
                    c.Enabled = not state
                end
            end
        end
    end
end

local function startNapeOrbit(nape, hrp, titan)
    napeTweenActive = true
    task.spawn(function()
        local TweenService = game:GetService("TweenService")
        local swingDistance = 12
        local swingHeight = 0
        disableNapeJoints(nape, true)
        while napeTweenActive and nape and nape.Parent and hrp and hrp.Parent do
            nape.Size = Vector3.new(8, 7, 8)
            nape.CFrame = hrp.CFrame * CFrame.new(swingDistance, swingHeight, 0)
            local tweenLeft = TweenService:Create(nape, TweenInfo.new(0.18, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { CFrame = hrp.CFrame * CFrame.new(-swingDistance, swingHeight, 0) })
            tweenLeft:Play()
            tweenLeft.Completed:Wait()
            if not napeTweenActive then break end
            nape.CFrame = hrp.CFrame
            nape.Size = Vector3.new(150, 150, 150)
            task.wait(0.1)
            if not napeTweenActive then break end
            nape.Size = Vector3.new(8, 7, 8)
            nape.CFrame = hrp.CFrame * CFrame.new(-swingDistance, swingHeight, 0)
            local tweenRight = TweenService:Create(nape, TweenInfo.new(0.18, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { CFrame = hrp.CFrame * CFrame.new(swingDistance, swingHeight, 0) })
            tweenRight:Play()
            tweenRight.Completed:Wait()
            if not napeTweenActive then break end
            nape.CFrame = hrp.CFrame
            nape.Size = Vector3.new(150, 150, 150)
            task.wait(0.1)
            if not napeTweenActive then break end
        end
        disableNapeJoints(nape, false)
        setTitanAnchored(titan, false)
        if nape and nape.Parent then
            nape.Size = Vector3.new(8, 7, 8)
        end
    end)
end

local function onAutoFarm(value)
    autoFarmEnabled = value
    if not value then
        stopNapeTween()
        stopClickSpam()
        if activeTween then activeTween:Cancel(); activeTween = nil end
        isTeleporting = false
        persistFreezeActive = false
        persistFreezeTarget = nil
        if persistFreezeConn then persistFreezeConn:Disconnect(); persistFreezeConn = nil end
        return
    end
    persistFreezeConn = game:GetService("RunService").Heartbeat:Connect(function()
        if not persistFreezeActive then return end
        local plr = game:GetService("Players").LocalPlayer
        local char = plr and plr.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local partTele = char:FindFirstChild("PartTele")
        if partTele then
            root.CFrame = partTele.CFrame
        elseif persistFreezeTarget then
            root.CFrame = persistFreezeTarget
        end
    end)
    task.spawn(function()
        while autoFarmEnabled do
            local ok, err = pcall(function()
                local plr = game:GetService("Players").LocalPlayer
                if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
                    plr.CharacterAdded:Wait()
                    plr.Character:WaitForChild("HumanoidRootPart", 10)
                end
                local char = plr.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if not root then return end
                checkSideEffects()
                local titan = getClosestTitan(root)
                if not titan then return end
                local head = titan:FindFirstChild("Head")
                if not head then return end
                setTitanAnchored(titan, true)
                local aboveHeadCF = CFrame.new(head.Position + Vector3.new(0, 100, 0))
                persistFreezeTarget = aboveHeadCF
                topos(aboveHeadCF)
                local arrivalTimeout = tick()
                while autoFarmEnabled do
                    local curRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                    if not curRoot then break end
                    if (curRoot.Position - aboveHeadCF.Position).Magnitude < 15 then break end
                    if tick() - arrivalTimeout > 6 then break end
                    wait(0.05)
                end
                if activeTween then activeTween:Cancel(); activeTween = nil end
                isTeleporting = false
                if plr.Character and plr.Character:FindFirstChild("PartTele") then
                    plr.Character.PartTele:Destroy()
                end
                if not autoFarmEnabled then return end
                local liveHead = titan:FindFirstChild("Head")
                if not liveHead then return end
                local frozenCF = CFrame.new(liveHead.Position + Vector3.new(0, 100, 0))
                local curRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if not curRoot then return end
                curRoot.CFrame = frozenCF
                persistFreezeTarget = frozenCF
                persistFreezeActive = true
                local nape = getNapeForTitan(titan)
                if not nape then
                    persistFreezeActive = false
                    return
                end
                stopNapeTween()
                stopClickSpam()
                nape.CFrame = curRoot.CFrame
                startNapeOrbit(nape, curRoot, titan)
                startClickSpam()
                local killTimeout = tick()
                while autoFarmEnabled and titanIsAlive(titan) do
                    checkSideEffects()
                    if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
                        plr.CharacterAdded:Wait()
                        plr.Character:WaitForChild("HumanoidRootPart", 10)
                    end
                    local liveHead = titan:FindFirstChild("Head")
                    if liveHead then
                        frozenCF = CFrame.new(liveHead.Position + Vector3.new(0, 100, 0))
                        persistFreezeTarget = frozenCF
                    end
                    if tick() - killTimeout > 60 then break end
                    wait(0.05)
                end
                stopNapeTween()
                stopClickSpam()
            end)
            if not ok then
                warn("AutoFarm error (continuing):", err)
            end
            task.wait(0.1)
        end
        persistFreezeActive = false
        persistFreezeTarget = nil
        if persistFreezeConn then persistFreezeConn:Disconnect(); persistFreezeConn = nil end
    end)
end

