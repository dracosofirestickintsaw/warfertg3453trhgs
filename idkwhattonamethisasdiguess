end

local function isRewardsVisible()
    local success, rewards = pcall(function()
        return game:GetService("Players").LocalPlayer.PlayerGui.Interface.Rewards
    end)
    return success and rewards and rewards.Visible
end

local function checkSideEffects()
    local setsText = getSetsText()
    if setsText then
        local left = setsText:match("^(%d+)%s*/%s*")
        if left and tonumber(left) == 0 then
            local refill = findGasTankRefill()
            if refill then
                game:GetService("ReplicatedStorage").Assets.Remotes.POST:FireServer("Attacks", "Reload", refill)
            end
        end
    end
    if isRewardsVisible() then
        game:GetService("ReplicatedStorage").Assets.Remotes.GET:InvokeServer("Functions", "Retry", "Add")
    end
end

