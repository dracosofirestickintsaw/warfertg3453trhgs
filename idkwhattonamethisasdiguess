                Name = "TabLineShadow",
                Parent = TabButton.Instance,
                BackgroundTransparency = 1,
                Position = UDim2.fromOffset(-4, 13),
                Size = UDim2.fromOffset(7, 25),
                ZIndex = 0
            })

            local TabLineImg = self:Create("ImageLabel", {
                Name = "ShadowImage",
                Parent = TabLineShadow.Instance,
                AnchorPoint = Vector2.new(0.5, 0.5),
                BackgroundTransparency = 1,
                Image = "rbxassetid://16389697796",
                ImageColor3 = Library.Theme.Accent,
                Position = UDim2.fromScale(0.5, 0.5),
                Size = UDim2.fromScale(1.5, 1.5),
                ZIndex = 0
            })
        end

        function Tab:Deselect()
            TabButton.Instance.BackgroundTransparency = 1
            TabIcon.Instance.ImageColor3 = Library.Theme.TabUnselected

            for _, Child in TabButton.Instance:GetChildren() do
                if Child.Name == "TabLine" or Child.Name == "TabLineShadow" then
                    Child:Destroy()
                end
            end
        end

        TabButton.Instance.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                for _, OtherTab in Window.TabButtons do
                    if OtherTab ~= Tab then
                        OtherTab:Deselect()
                    end
                end
                Tab:Select()
            end
        end)

        table.insert(Window.TabButtons, Tab)

        if #Window.TabButtons == 1 then
            Tab:Select()
        end

        return setmetatable(Tab, Library)
    end

    function Window:Destroy()
        Holder.Instance:Destroy()
        UnusedHolder.Instance:Destroy()
        for _, Connection in Library.Connections do
            Connection:Disconnect()
        end
    end

    return setmetatable(Window, Library)
end

