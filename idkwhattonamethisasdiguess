local function applyHighlightStyle(highlight)
    if fullEspEnabled then
        highlight.FillColor = fullEspColor
        highlight.FillTransparency = 0.4
        highlight.OutlineColor = fullEspColor
        highlight.OutlineTransparency = 0
    else
        highlight.FillColor = espColor
        highlight.FillTransparency = 1
        highlight.OutlineColor = espColor
        highlight.OutlineTransparency = 0
    end
end

local function onTitanEsp(value)
    titanEspEnabled = value
    for _, highlight in ipairs(espObjects) do highlight:Destroy() end
    espObjects = {}
    if not value then cleanBillboards() end
    if value then
        task.spawn(function()
            while titanEspEnabled do
                local titans = workspace:FindFirstChild("Titans")
                local root = getPlayerRoot()
                if titans then
                    for _, titan in ipairs(titans:GetChildren()) do
                        local alreadyHasHighlight = false
                        for _, highlight in ipairs(espObjects) do
                            if highlight.Adornee == titan then
                                alreadyHasHighlight = true
                                applyHighlightStyle(highlight)
                                break
                            end
                        end
                        if not alreadyHasHighlight then
                            local highlight = Instance.new("Highlight")
                            highlight.Adornee = titan
                            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                            highlight.Parent = game:GetService("CoreGui")
                            applyHighlightStyle(highlight)
                            table.insert(espObjects, highlight)
                        end
                        local titanRoot = titan:FindFirstChild("HumanoidRootPart") or titan:FindFirstChildWhichIsA("BasePart")
                        local distText = "? studs"
                        if root and titanRoot then
                            local dist = math.floor((root.Position - titanRoot.Position).Magnitude)
                            distText = dist .. " studs"
                        end
                        local stateText = tostring(titan:GetAttribute("State") or "?")
                        local existingBb = nil
                        for _, bb in ipairs(billboardObjects) do
                            if bb and bb.Parent and bb.Adornee == titan then
                                existingBb = bb
                                break
                            end
                        end
                        if not existingBb then
                            local bb = Instance.new("BillboardGui")
                            bb.Adornee = titan
                            bb.Size = UDim2.new(0, 140, 0, 50)
                            bb.StudsOffset = Vector3.new(0, 8, 0)
                            bb.AlwaysOnTop = true
                            bb.ResetOnSpawn = false
                            bb.Parent = game:GetService("CoreGui")
                            local frame = Instance.new("Frame")
                            frame.Name = "Frame"
                            frame.BackgroundTransparency = 1
                            frame.Size = UDim2.new(1, 0, 1, 0)
                            frame.Parent = bb
                            local layout = Instance.new("UIListLayout")
                            layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
                            layout.VerticalAlignment = Enum.VerticalAlignment.Center
                            layout.SortOrder = Enum.SortOrder.LayoutOrder
                            layout.Parent = frame
                            local distLabel = Instance.new("TextLabel")
                            distLabel.Name = "DistLabel"
                            distLabel.BackgroundTransparency = 1
                            distLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                            distLabel.TextStrokeTransparency = 0
                            distLabel.TextSize = 13
                            distLabel.Font = Enum.Font.GothamBold
                            distLabel.Size = UDim2.new(1, 0, 0, 18)
                            distLabel.Text = distText
                            distLabel.Visible = espDistanceEnabled
                            distLabel.LayoutOrder = 1
                            distLabel.Parent = frame
                            local stateLabel = Instance.new("TextLabel")
                            stateLabel.Name = "StateLabel"
                            stateLabel.BackgroundTransparency = 1
                            stateLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                            stateLabel.TextStrokeTransparency = 0
                            stateLabel.TextSize = 13
                            stateLabel.Font = Enum.Font.GothamBold
                            stateLabel.Size = UDim2.new(1, 0, 0, 18)
                            stateLabel.Text = stateText
                            stateLabel.Visible = espStateEnabled
                            stateLabel.LayoutOrder = 2
                            stateLabel.Parent = frame
                            table.insert(billboardObjects, bb)
                        else
                            local frame = existingBb:FindFirstChild("Frame")
                            local distLabel = frame and frame:FindFirstChild("DistLabel")
                            local stateLabel = frame and frame:FindFirstChild("StateLabel")
                            if distLabel then distLabel.Text = distText; distLabel.Visible = espDistanceEnabled end
                            if stateLabel then stateLabel.Text = stateText; stateLabel.Visible = espStateEnabled end
                        end
                    end
                end
                for i = #espObjects, 1, -1 do
                    local h = espObjects[i]
                    if not h.Adornee or not h.Adornee.Parent then
                        h:Destroy()
                        table.remove(espObjects, i)
                    end
                end
                for i = #billboardObjects, 1, -1 do
                    local bb = billboardObjects[i]
                    if not bb or not bb.Parent or not bb.Adornee or not bb.Adornee.Parent then
                        if bb and bb.Parent then bb:Destroy() end
                        table.remove(billboardObjects, i)
                    end
                end
                wait()
            end
