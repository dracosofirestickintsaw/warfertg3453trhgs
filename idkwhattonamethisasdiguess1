--[[
    TabLib - Declarative UI Library for Roblox
    Usage:
        local Tab = loadstring(game:HttpGet("your-url/TabLib.lua"))()
        
        Tab:Tab({
            name = "Main",
            icon = "lucide:home",
        }):Section({
            name = "Section1",
        }):Toggle({
            name = "Remove Sky",
            default = false,
            callback = function(value)
                print("Toggle:", value)
            end
