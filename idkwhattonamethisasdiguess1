--[[
    TabLib - Declarative UI Library for Roblox
    Transform hardcoded UI scripts into reusable declarative components

    Usage:
        local TabLib = require(path.to.TabLib)

        local UI = TabLib.create({
            Name = "MyUI",
        })

        local MainTab = UI:Tab({
            name = "Main",
            icon = "lucide:home",
        })

        MainTab:Section({
            name = "Section1",
        })

        MainTab:Toggle({
            name = "Toggle 1",
            default = false,
            callback = function(value)
                print("Toggle:", value)
            end
        })

        MainTab:Slider({
            name = "Slider 1",
            min = 0,
            max = 100,
            default = 50,
            callback = function(value)
                print("Slider:", value)
            end
        })
]]

local TabLib = {}

-- Service shortcuts
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

-- Theme configuration
local Theme = {
    AccentColor = Color3.fromRGB(141, 153, 252),
    MainBackground = Color3.fromRGB(26, 26, 26),
    SectionBackground = Color3.fromRGB(21, 23, 24),
    TextPrimary = Color3.fromRGB(191, 194, 193),
    TextSelected = Color3.fromRGB(141, 153, 252),
    GradientStart = Color3.fromRGB(43, 46, 47),
    GradientEnd = Color3.fromRGB(30, 31, 35),
}

-- Utility functions
local function CreateShadow(parent, offset, transparency, color)
    local shadow = Instance.new("ImageLabel")
    shadow.Name = "shadow"
    shadow.AnchorPoint = Vector2.new(0.5, 0.5)
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://1316045217"
    shadow.ImageColor3 = color or Theme.AccentColor
    shadow.ImageTransparency = transparency or 0.9
    shadow.Position = UDim2.fromScale(0.5, 0.5)
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.Size = UDim2.new(1, 2, 1, 2)
    shadow.SliceCenter = Rect.new(10, 10, 118, 118)
    shadow.ZIndex = 0
    shadow.Parent = parent
    return shadow
end

local function CreateShadowHolder(parent, offsetX, offsetY, sizeX, sizeY)
    local holder = Instance.new("Frame")
    holder.Name = "ShadowHolder"
    holder.BackgroundTransparency = 1
    holder.Position = UDim2.new(offsetX.Scale, offsetX.Offset or 0, offsetY.Scale, offsetY.Offset or 0)
    holder.Size = UDim2.new(sizeX.Scale, sizeX.Offset or 0, sizeY.Scale, sizeY.Offset or 0)
    holder.ZIndex = 0

    CreateShadow(holder, 0, 0.92)
    CreateShadow(holder, 0, 0.93)
    CreateShadow(holder, 0, 0.9)

    holder.Parent = parent
    return holder
end

local function CreateTextGlow(parent, offsetX, offsetY)
    local glow = Instance.new("Frame")
    glow.Name = "Text Glow"
    glow.BackgroundTransparency = 1
    glow.Position = UDim2.new(offsetX.Scale, offsetX.Offset or 0, offsetY.Scale, offsetY.Offset or 0)
    glow.Size = UDim2.new(-0.492575, 200, 0.017, 15)

    CreateShadow(glow, 0, 0.98)
    CreateShadow(glow, 0, 0.98)
    CreateShadow(glow, 0, 0.98)

    glow.Parent = parent
    return glow
end

-- Create the main UI
function TabLib.create(config)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = config.Name or "TabLibUI"
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    -- Main frame
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.BackgroundColor3 = Theme.MainBackground
    MainFrame.Position = config.Position or UDim2.fromScale(0.287726, 0.19546)
    MainFrame.Size = config.Size or UDim2.fromOffset(670, 511)
    MainFrame.Parent = ScreenGui

    -- Gradient for main frame
    local MainGradient = Instance.new("UIGradient")
    MainGradient.Name = "UIGradient"
    MainGradient.Rotation = -90
    MainGradient.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),
        NumberSequenceKeypoint.new(1, 0.16875),
    })
    MainGradient.Parent = MainFrame

    -- Corner for main frame
    local MainCorner = Instance.new("UICorner")
    MainCorner.Name = "UICorner"
    MainCorner.Parent = MainFrame

    -- Container for tabs
    local TabContainer = Instance.new("Frame")
    TabContainer.Name = "TabContainer"
    TabContainer.BackgroundTransparency = 1
    TabContainer.Position = UDim2.new(0, 0, 0, 0)
    TabContainer.Size = UDim2.new(1, 0, 0, 40)
    TabContainer.Parent = MainFrame

    -- Content area
    local ContentArea = Instance.new("Frame")
    ContentArea.Name = "ContentArea"
    ContentArea.BackgroundTransparency = 1
    ContentArea.Position = UDim2.new(0, 0, 0, 45)
    ContentArea.Size = UDim2.new(1, 0, 1, -45)
    ContentArea.Parent = MainFrame

    -- State management
    local state = {
        tabs = {},
        currentTab = nil,
        tabOrder = 0,
    }

    -- Create tab button
    local function CreateTabButton(tabConfig, tabData)
        local isSelected = tabData.index == 1

        local tabFrame = Instance.new("Frame")
        tabFrame.Name = tabConfig.name .. "Tab"
        tabFrame.BackgroundColor3 = Color3.new(1, 1, 1)
        tabFrame.Position = UDim2.new(0, tabData.offsetX, 0.03, -5)
        tabFrame.Size = UDim2.fromOffset(tabData.width, 35)
        tabFrame.Parent = TabContainer

        -- Corner
        local corner = Instance.new("UICorner")
        corner.Name = "UICorner"
        corner.CornerRadius = UDim.new(0, 3)
        corner.Parent = tabFrame

        -- Gradient
        local gradient = Instance.new("UIGradient")
        gradient.Name = "UIGradient"
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Theme.GradientStart),
            ColorSequenceKeypoint.new(1, Theme.GradientEnd),
        })
        gradient.Parent = tabFrame

        -- Label
        local label = Instance.new("TextLabel")
        label.Name = "SectionName"
        label.BackgroundTransparency = 1
        label.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json")
        label.Position = UDim2.new(0, isSelected and 1 or -21, 0.029, -1)
        label.Size = UDim2.fromOffset(103, 34)
        label.Text = tabConfig.name
        label.TextColor3 = isSelected and Theme.TextSelected or Theme.TextPrimary
        label.TextSize = 19
        label.Parent = tabFrame

        -- Icon (if provided)
        if tabConfig.icon then
            local iconLabel = Instance.new("TextLabel")
            iconLabel.Name = "Icon"
            iconLabel.BackgroundTransparency = 1
            iconLabel.FontFace = Font.new("rbxasset://fonts/families/Gotham.json")
            iconLabel.Position = UDim2.new(0, isSelected and 85 or 63, 0.029, -1)
            iconLabel.Size = UDim2.fromOffset(20, 34)
            iconLabel.Text = tabConfig.icon
            iconLabel.TextColor3 = isSelected and Theme.TextSelected or Theme.TextPrimary
            iconLabel.TextSize = 14
            iconLabel.Parent = tabFrame
        end

        -- Shadow (only for selected tab)
        if isSelected then
            CreateShadowHolder(label, {Scale = 0.0873786, Offset = 0}, {Scale = 0.235294, Offset = 0}, {Scale = 0.834952, Offset = 0}, {Scale = 0.588235, Offset = 0})
        end

        -- Click handler
        tabFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                -- Update all tabs
                for _, tab in pairs(state.tabs) do
                    tab.button.Label.TextColor3 = Theme.TextPrimary
                    tab.button.Frame.BackgroundTransparency = 1
                    if tab.button.Icon then
                        tab.button.Icon.TextColor3 = Theme.TextPrimary
                    end
                    tab.button.Frame:TweenSize(UDim2.fromOffset(tab.width, 35), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.15, true)
                    tab.button.Label.Position = UDim2.new(0, -21, 0.029, -1)
                end

                -- Select this tab
                tabData.button.Frame.BackgroundTransparency = 0
                tabData.button.Frame:TweenSize(UDim2.fromOffset(tabData.width + (tabConfig.icon and 0 or 45), 35), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.15, true)
                tabData.button.Label.Position = UDim2.new(0, 1, 0.029, -1)
                tabData.button.Label.TextColor3 = Theme.TextSelected
                if tabData.button.Icon then
                    tabData.button.Icon.TextColor3 = Theme.TextSelected
                end

                -- Show content
                for _, section in pairs(tabData.sections) do
                    section.Visible = true
                end

                -- Hide other tab contents
                for _, otherTab in pairs(state.tabs) do
                    if otherTab ~= tabData then
                        for _, section in pairs(otherTab.sections) do
                            section.Visible = false
                        end
                    end
                end

                state.currentTab = tabData

                -- Callback
                if tabConfig.callback then
                    tabConfig.callback()
                end
            end
        end)

        return {
            frame = tabFrame,
            label = label,
            icon = tabFrame:FindFirstChild("Icon"),
        }
    end

    -- Create section
    local function CreateSection(sectionConfig, tabData)
        local sectionIndex = #tabData.sections + 1
        local xOffset = sectionIndex == 1 and 100 or 385
        local yOffset = 60 + ((sectionIndex - 1) % 2) * 205

        local section = Instance.new("Frame")
        section.Name = sectionConfig.name
        section.BackgroundColor3 = Theme.SectionBackground
        section.ClipsDescendants = true
        section.Position = UDim2.fromOffset(xOffset, yOffset)
        section.Size = sectionConfig.size or UDim2.fromOffset(273, 200)
        section.Visible = tabData.index == 1
        section.Parent = ContentArea

        -- Corner
        local corner = Instance.new("UICorner")
        corner.Name = "UICorner"
        corner.CornerRadius = UDim.new(0, 5)
        corner.Parent = section

        -- Glow bar
        local glow = Instance.new("Frame")
        glow.Name = "UiGlow"
        glow.BackgroundColor3 = Theme.AccentColor
        glow.Size = UDim2.fromOffset(273, 5)
        glow.Parent = section

        local glowCorner = Instance.new("UICorner")
        glowCorner.Name = "UICorner"
        glowCorner.CornerRadius = UDim.new(0, 5)
        glowCorner.Parent = glow

        -- Hide glow
        local hideGlow = Instance.new("Frame")
        hideGlow.Name = "HideUiGlow"
        hideGlow.BackgroundColor3 = Theme.SectionBackground
        hideGlow.BorderColor3 = Color3.new()
        hideGlow.BorderSizePixel = 0
        hideGlow.Position = UDim2.new(-0.021282, 0, 0.05, -7)
        hideGlow.Size = UDim2.fromOffset(283, 8)
        hideGlow.Parent = section

        -- Section name
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Name = "SectionName"
        nameLabel.BackgroundTransparency = 1
        nameLabel.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
        nameLabel.Position = UDim2.fromOffset(-26, 3)
        nameLabel.Size = UDim2.fromOffset(124, 30)
        nameLabel.Text = sectionConfig.name
        nameLabel.TextColor3 = Theme.TextPrimary
        nameLabel.TextSize = 18
        nameLabel.Parent = section

        -- Text glow
        CreateTextGlow(section, {Scale = 0.087, Offset = -23}, {Scale = 0.235, Offset = -37})

        -- Elements container
        local elementsFrame = Instance.new("Frame")
        elementsFrame.Name = "Elements"
        elementsFrame.BackgroundTransparency = 1
        elementsFrame.Position = UDim2.fromOffset(10, 40)
        elementsFrame.Size = UDim2.new(1, -20, 1, -50)
        elementsFrame.Parent = section

        local listLayout = Instance.new("UIListLayout")
        listLayout.SortOrder = Enum.SortOrder.LayoutOrder
        listLayout.Padding = UDim.new(0, 8)
        listLayout.Parent = elementsFrame

        return {
            frame = section,
            elements = elementsFrame,
            layout = listLayout,
        }
    end

    -- Create toggle element
    local function CreateToggle(config, sectionData)
        local layoutOrder = #sectionData.children + 1

        local toggleFrame = Instance.new("Frame")
        toggleFrame.Name = config.name
        toggleFrame.BackgroundColor3 = Theme.SectionBackground
        toggleFrame.BackgroundTransparency = 0.5
        toggleFrame.Position = UDim2.new(0, 0, 0, (layoutOrder - 1) * 35)
        toggleFrame.Size = UDim2.fromOffset(250, 30)
        toggleFrame.LayoutOrder = layoutOrder
        toggleFrame.Parent = sectionData.elements

        local corner = Instance.new("UICorner")
        corner.Name = "UICorner"
        corner.CornerRadius = UDim.new(0, 3)
        corner.Parent = toggleFrame

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Name = "Name"
        nameLabel.BackgroundTransparency = 1
        nameLabel.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json")
        nameLabel.Position = UDim2.fromOffset(10, 0)
        nameLabel.Size = UDim2.fromOffset(150, 30)
        nameLabel.Text = config.name
        nameLabel.TextColor3 = Theme.TextPrimary
        nameLabel.TextSize = 14
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = toggleFrame

        local checkboxFrame = Instance.new("Frame")
        checkboxFrame.Name = "Checkbox"
        checkboxFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        checkboxFrame.Position = UDim2.fromOffset(210, 5)
        checkboxFrame.Size = UDim2.fromOffset(30, 20)
        checkboxFrame.Parent = toggleFrame

        local checkboxCorner = Instance.new("UICorner")
        checkboxCorner.Name = "UICorner"
        checkboxCorner.CornerRadius = UDim.new(0, 3)
        checkboxCorner.Parent = checkboxFrame

        local state = { enabled = config.default or false }

        local function updateCheckbox()
            checkboxFrame.BackgroundColor3 = state.enabled and Theme.AccentColor or Color3.fromRGB(50, 50, 50)
        end

        updateCheckbox()

        local function toggle()
            state.enabled = not state.enabled
            updateCheckbox()
            if config.callback then
                config.callback(state.enabled)
            end
        end

        checkboxFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                toggle()
            end
        end)

        toggleFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                toggle()
            end
        end)

        return {
            frame = toggleFrame,
            setValue = function(value)
                state.enabled = value
                updateCheckbox()
            end,
            getValue = function()
                return state.enabled
            end,
        }
    end

    -- Create slider element
    local function CreateSlider(config, sectionData)
        local layoutOrder = #sectionData.children + 1

        local sliderFrame = Instance.new("Frame")
        sliderFrame.Name = config.name
        sliderFrame.BackgroundColor3 = Theme.SectionBackground
        sliderFrame.BackgroundTransparency = 0.5
        sliderFrame.Position = UDim2.new(0, 0, 0, (layoutOrder - 1) * 50)
        sliderFrame.Size = UDim2.fromOffset(250, 45)
        sliderFrame.LayoutOrder = layoutOrder
        sliderFrame.Parent = sectionData.elements

        local corner = Instance.new("UICorner")
        corner.Name = "UICorner"
        corner.CornerRadius = UDim.new(0, 3)
        corner.Parent = sliderFrame

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Name = "Name"
        nameLabel.BackgroundTransparency = 1
        nameLabel.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json")
        nameLabel.Position = UDim2.fromOffset(10, 2)
        nameLabel.Size = UDim2.fromOffset(150, 20)
        nameLabel.Text = config.name
        nameLabel.TextColor3 = Theme.TextPrimary
        nameLabel.TextSize = 14
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = sliderFrame

        local valueLabel = Instance.new("TextLabel")
        valueLabel.Name = "Value"
        valueLabel.BackgroundTransparency = 1
        valueLabel.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json")
        valueLabel.Position = UDim2.fromOffset(190, 2)
        valueLabel.Size = UDim2.fromOffset(50, 20)
        valueLabel.Text = tostring(config.default or config.min or 0)
        valueLabel.TextColor3 = Theme.AccentColor
        valueLabel.TextSize = 14
        valueLabel.TextXAlignment = Enum.TextXAlignment.Right
        valueLabel.Parent = sliderFrame

        local sliderTrack = Instance.new("Frame")
        sliderTrack.Name = "SliderTrack"
        sliderTrack.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        sliderTrack.Position = UDim2.fromOffset(10, 25)
        sliderTrack.Size = UDim2.fromOffset(230, 10)
        sliderTrack.Parent = sliderFrame

        local trackCorner = Instance.new("UICorner")
        trackCorner.Name = "UICorner"
        trackCorner.CornerRadius = UDim.new(0, 5)
        trackCorner.Parent = sliderTrack

        local sliderFill = Instance.new("Frame")
        sliderFill.Name = "SliderFill"
        sliderFill.BackgroundColor3 = Theme.AccentColor
        sliderFill.Size = UDim2.fromOffset(0, 10)
        sliderFill.Parent = sliderTrack

        local fillCorner = Instance.new("UICorner")
        fillCorner.Name = "UICorner"
        fillCorner.CornerRadius = UDim.new(0, 5)
        fillCorner.Parent = sliderFill

        local state = { value = config.default or config.min or 0 }
        local minVal = config.min or 0
        local maxVal = config.max or 100

        local function updateSlider()
            local percent = (state.value - minVal) / (maxVal - minVal)
            sliderFill.Size = UDim2.fromOffset(230 * percent, 10)
            valueLabel.Text = tostring(math.floor(state.value))
        end

        updateSlider()

        local dragging = false

        sliderTrack.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
            end
        end)

        sliderTrack.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)

        sliderFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
            end
        end)

        sliderFrame.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)

        RunService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local relativePos = (input.Position.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X
                relativePos = math.clamp(relativePos, 0, 1)
                state.value = minVal + (maxVal - minVal) * relativePos
                updateSlider()
                if config.callback then
                    config.callback(state.value)
                end
            end
        end)

        return {
            frame = sliderFrame,
            setValue = function(value)
                state.value = math.clamp(value, minVal, maxVal)
                updateSlider()
            end,
            getValue = function()
                return state.value
            end,
        }
    end

    -- Create button element
    local function CreateButton(config, sectionData)
        local layoutOrder = #sectionData.children + 1

        local buttonFrame = Instance.new("Frame")
        buttonFrame.Name = config.name
        buttonFrame.BackgroundColor3 = Theme.AccentColor
        buttonFrame.BackgroundTransparency = 0.3
        buttonFrame.Position = UDim2.new(0, 0, 0, (layoutOrder - 1) * 35)
        buttonFrame.Size = UDim2.fromOffset(250, 30)
        buttonFrame.LayoutOrder = layoutOrder
        buttonFrame.Parent = sectionData.elements

        local corner = Instance.new("UICorner")
        corner.Name = "UICorner"
        corner.CornerRadius = UDim.new(0, 5)
        corner.Parent = buttonFrame

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Name = "Name"
        nameLabel.BackgroundTransparency = 1
        nameLabel.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json", Enum.FontWeight.Bold)
        nameLabel.Position = UDim2.fromOffset(10, 0)
        nameLabel.Size = UDim2.fromOffset(230, 30)
        nameLabel.Text = config.name
        nameLabel.TextColor3 = Color3.new(1, 1, 1)
        nameLabel.TextSize = 14
        nameLabel.Parent = buttonFrame

        buttonFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if config.callback then
                    config.callback()
                end
            end
        end)

        return {
            frame = buttonFrame,
        }
    end

    -- Create label element
    local function CreateLabel(config, sectionData)
        local layoutOrder = #sectionData.children + 1

        local labelFrame = Instance.new("Frame")
        labelFrame.Name = config.name
        labelFrame.BackgroundTransparency = 1
        labelFrame.Position = UDim2.new(0, 0, 0, (layoutOrder - 1) * 25)
        labelFrame.Size = UDim2.fromOffset(250, 20)
        labelFrame.LayoutOrder = layoutOrder
        labelFrame.Parent = sectionData.elements

        local label = Instance.new("TextLabel")
        label.Name = "Label"
        label.BackgroundTransparency = 1
        label.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json")
        label.Position = UDim2.fromOffset(0, 0)
        label.Size = UDim2.fromOffset(250, 20)
        label.Text = config.text or config.name
        label.TextColor3 = config.color or Theme.TextPrimary
        label.TextSize = config.textSize or 12
        label.TextXAlignment = config.alignment or Enum.TextXAlignment.Left
        label.Parent = labelFrame

        return {
            frame = labelFrame,
            setText = function(text)
                label.Text = text
            end,
            getText = function()
                return label.Text
            end,
        }
    end

    -- Create divider element
    local function CreateDivider(config, sectionData)
        local layoutOrder = #sectionData.children + 1

        local dividerFrame = Instance.new("Frame")
        dividerFrame.Name = "Divider"
        dividerFrame.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        dividerFrame.BackgroundTransparency = 0.5
        dividerFrame.Position = UDim2.new(0, 0, 0, (layoutOrder - 1) * 15)
        dividerFrame.Size = UDim2.fromOffset(250, 1)
        dividerFrame.LayoutOrder = layoutOrder
        dividerFrame.Parent = sectionData.elements

        return {
            frame = dividerFrame,
        }
    end

    -- Create section shadow holder
    local function CreateSectionShadow(sectionData, index)
        local offsetY = index == 1 and 41 or 325
        local shadowHolder = Instance.new("Frame")
        shadowHolder.Name = "ShadowHolder(Section" .. index .. ")"
        shadowHolder.BackgroundTransparency = 1
        shadowHolder.Position = UDim2.new(0.087, 41, 0.235, -66 + (offsetY - 60))
        shadowHolder.Size = UDim2.new(0.185, 150, 0.017, 5)
        shadowHolder.Parent = MainFrame

        CreateShadow(shadowHolder, 0, 0.86)
        CreateShadow(shadowHolder, 0, 0.86)
        CreateShadow(shadowHolder, 0, 0.86)

        return shadowHolder
    end

    -- Public API
    local API = {}

    function API:Tab(config)
        local tabData = {
            config = config,
            index = state.tabOrder + 1,
            offsetX = state.tabOrder == 0 and -5 or (state.tabOrder == 1 and 98 or state.tabOrder == 2 and 152 or 179 + (state.tabOrder - 3) * 55),
            width = (config.icon and 50 or 40) + (#config.name * 7.5),
            sections = {},
            children = {},
        }

        tabData.button = CreateTabButton(config, tabData)

        state.tabs[tabData.index] = tabData
        state.tabOrder = state.tabOrder + 1

        return {
                Section = function(sectionConfig)
                    local section = CreateSection(sectionConfig, tabData)
                    table.insert(tabData.sections, section)
                    table.insert(tabData.children, section)
                    return {
                        Toggle = function(toggleConfig)
                            return CreateToggle(toggleConfig, section)
                        end,
                        Slider = function(sliderConfig)
                            return CreateSlider(sliderConfig, section)
                        end,
                        Button = function(buttonConfig)
                            return CreateButton(buttonConfig, section)
                        end,
                        Label = function(labelConfig)
                            return CreateLabel(labelConfig, section)
                        end,
                        Divider = function()
                            return CreateDivider({}, section)
                        end,
                    }
                end,
            }
    end

    function API:Destroy()
        ScreenGui:Destroy()
    end

    function API:GetGui()
        return ScreenGui
    end

    function API:SetAccentColor(color)
        Theme.AccentColor = color
    end

    return API
end

return TabLib
