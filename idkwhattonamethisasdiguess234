-- ============================================
function Library:CreateToggle(Section, Data)
    local Name = Data.Name or "Toggle"
    local Default = Data.Default or false
    local Flag = Data.Flag or "toggle_" .. format("%.0f", tick())
    local Callback = Data.Callback or function() end

    local Theme = self.CurrentTheme

    local Toggle = {}
    Toggle.Name = Name
    Toggle.Flag = Flag
    Toggle.Value = Default
    Toggle.Callback = Callback

    -- Container
    Toggle.Container = InstanceNew("Frame")
    Toggle.Container.Size = UDim2.new(1, 0, 0, 32)
    Toggle.Container.BackgroundTransparency = 1
    Toggle.Container.ZIndex = 3
    Toggle.Container.Parent = Section.Content

    -- Label
    Toggle.Label = InstanceNew("TextLabel")
    Toggle.Label.Size = UDim2.new(1, -50, 1, 0)
    Toggle.Label.BackgroundTransparency = 1
    Toggle.Label.Text = Name
    Toggle.Label.TextColor3 = Theme.Text
    Toggle.Label.TextSize = 13
    Toggle.Label.Font = Enum.Font.Gotham
    Toggle.Label.TextXAlignment = Enum.TextXAlignment.Left
    Toggle.Label.TextYAlignment = Enum.TextYAlignment.Center
    Toggle.Label.ZIndex = 4
    Toggle.Label.Parent = Toggle.Container

    -- Checkbox
    Toggle.Checkbox = InstanceNew("TextButton")
    Toggle.Checkbox.Size = UDim2.new(0, 24, 0, 24)
    Toggle.Checkbox.Position = UDim2.new(1, -26, 0.5, 0)
    Toggle.Checkbox.AnchorPoint = Vector2.new(0, 0.5)
    Toggle.Checkbox.BackgroundColor3 = Default and Theme.ToggleOn or Theme.ToggleOff
    Toggle.Checkbox.Text = ""
    Toggle.Checkbox.AutoButtonColor = false
    Toggle.Checkbox.ZIndex = 4
    Toggle.Checkbox.Parent = Toggle.Container

    AddCorner(Toggle.Checkbox, UDim.new(0, 6))
    AddStroke(Toggle.Checkbox, Theme.Border, 1)

    -- Checkmark
    Toggle.Checkmark = InstanceNew("TextLabel")
    Toggle.Checkmark.Size = UDim2.new(1, 0, 1, 0)
    Toggle.Checkmark.BackgroundTransparency = 1
    Toggle.Checkmark.Text = "✓"
    Toggle.Checkmark.TextColor3 = Theme.Text
    Toggle.Checkmark.TextSize = 14
    Toggle.Checkmark.Font = Enum.Font.GothamBold
    Toggle.Checkmark.Visible = Default
    Toggle.Checkmark.ZIndex = 5
    Toggle.Checkmark.Parent = Toggle.Checkbox

    -- Set method
    function Toggle:Set(Value)
        self.Value = Value
        self.Checkmark.Visible = Value
        self.Checkbox.BackgroundColor3 = Value and Theme.ToggleOn or Theme.ToggleOff
        Library.Flags[self.Flag] = Value
        self.Callback(Value)
    end

    -- Click handler
    Toggle.Checkbox.MouseButton1Click:Connect(function()
        Toggle:Set(not Toggle.Value)
    end)

    -- Hover effect
    Toggle.Checkbox.MouseEnter:Connect(function()
        local TargetColor = Toggle.Value and Theme.AccentHover or Theme.SecondaryBackground
        CreateTween(Toggle.Checkbox, {BackgroundColor3 = TargetColor}, 0.1)
    end)

    Toggle.Checkbox.MouseLeave:Connect(function()
        local TargetColor = Toggle.Value and Theme.ToggleOn or Theme.ToggleOff
        CreateTween(Toggle.Checkbox, {BackgroundColor3 = TargetColor}, 0.1)
    end)

    Library.Flags[Flag] = Default
    insert(Section.Elements, Toggle)

    return Toggle
end

