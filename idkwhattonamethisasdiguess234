-- WINDOW CREATION
-- ============================================
function Library:Window(Data)
    local Name = Data.Name or "My Window"
    local Size = Data.Size or UDim2.new(0, 550, 0, 450)
    local Position = Data.Position or UDim2.new(0.5, 0, 0.5, 0)
    local ThemeName = Data.Theme or "Default"

    -- Apply theme if specified
    if self.Themes[ThemeName] then
        self.CurrentTheme = self.Themes[ThemeName]
    end

    local Theme = self.CurrentTheme

    -- Create window object
    local Window = {}
    Window.Name = Name
    Window.Elements = {}
    Window.Pages = {}
    Window.IsOpen = true

    -- Main frame
    Window.Instance = InstanceNew("Frame")
    Window.Instance.Name = Name
    Window.Instance.Size = Size
    Window.Instance.Position = Position
    Window.Instance.AnchorPoint = Vector2.new(0.5, 0.5)
    Window.Instance.BackgroundColor3 = Theme.Background
    Window.Instance.BorderSizePixel = 0
    Window.Instance.ZIndex = 10
    Window.Instance.Parent = CoreGui

    -- Add corner and stroke
    AddCorner(Window.Instance, Theme.LargeCornerRadius)
    AddStroke(Window.Instance, Theme.Border, 1)

    -- Title bar
    Window.TitleBar = InstanceNew("Frame")
    Window.TitleBar.Name = "TitleBar"
    Window.TitleBar.Size = UDim2.new(1, 0, 0, 45)
    Window.TitleBar.BackgroundColor3 = Theme.SecondaryBackground
    Window.TitleBar.BackgroundTransparency = 0
    Window.TitleBar.BorderSizePixel = 0
    Window.TitleBar.ZIndex = 2
    Window.TitleBar.Parent = Window.Instance

    -- Title bar corners (fix bottom corners)
    local TitleCorner = InstanceNew("UICorner")
    TitleCorner.CornerRadius = Theme.LargeCornerRadius
    TitleCorner.Parent = Window.TitleBar

    local CornerFix = InstanceNew("Frame")
    CornerFix.Size = UDim2.new(1, 0, 0, 10)
    CornerFix.Position = UDim2.new(0, 0, 1, -10)
    CornerFix.BackgroundColor3 = Theme.SecondaryBackground
    CornerFix.BorderSizePixel = 0
    CornerFix.ZIndex = 2
    CornerFix.Parent = Window.TitleBar

    -- Title text
    Window.Title = InstanceNew("TextLabel")
    Window.Title.Size = UDim2.new(1, -80, 1, 0)
    Window.Title.Position = UDim2.new(0, 15, 0, 0)
    Window.Title.BackgroundTransparency = 1
    Window.Title.Text = Name
    Window.Title.TextColor3 = Theme.Text
    Window.Title.TextSize = 16
    Window.Title.Font = Enum.Font.GothamBold
    Window.Title.TextXAlignment = Enum.TextXAlignment.Left
    Window.Title.ZIndex = 3
    Window.Title.Parent = Window.TitleBar

    -- Minimize button
    Window.MinimizeBtn = InstanceNew("TextButton")
    Window.MinimizeBtn.Size = UDim2.new(0, 26, 0, 26)
    Window.MinimizeBtn.Position = UDim2.new(1, -80, 0.5, 0)
    Window.MinimizeBtn.AnchorPoint = Vector2.new(0, 0.5)
    Window.MinimizeBtn.BackgroundColor3 = Theme.TertiaryBackground
    Window.MinimizeBtn.Text = "−"
    Window.MinimizeBtn.TextColor3 = Theme.Text
    Window.MinimizeBtn.TextSize = 18
    Window.MinimizeBtn.Font = Enum.Font.GothamBold
    Window.MinimizeBtn.AutoButtonColor = false
    Window.MinimizeBtn.ZIndex = 3
    Window.MinimizeBtn.Parent = Window.TitleBar

    AddCorner(Window.MinimizeBtn, Theme.SmallCornerRadius)

    -- Close button
    Window.CloseBtn = InstanceNew("TextButton")
    Window.CloseBtn.Size = UDim2.new(0, 26, 0, 26)
    Window.CloseBtn.Position = UDim2.new(1, -45, 0.5, 0)
    Window.CloseBtn.AnchorPoint = Vector2.new(0, 0.5)
    Window.CloseBtn.BackgroundColor3 = Theme.Error
    Window.CloseBtn.Text = "×"
    Window.CloseBtn.TextColor3 = Theme.Text
    Window.CloseBtn.TextSize = 18
    Window.CloseBtn.Font = Enum.Font.GothamBold
    Window.CloseBtn.AutoButtonColor = false
    Window.CloseBtn.ZIndex = 3
    Window.CloseBtn.Parent = Window.TitleBar

    AddCorner(Window.CloseBtn, Theme.SmallCornerRadius)

    -- Button handlers
    Window.CloseBtn.MouseButton1Click:Connect(function()
        CreateTween(Window.Instance, {Size = UDim2.new(0, 0, 0, 0)}, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In, function()
            Window.Instance:Destroy()
            Window.IsOpen = false
        end)
    end)

    Window.MinimizeBtn.MouseButton1Click:Connect(function()
        Window.IsOpen = not Window.IsOpen

        if Window.IsOpen then
            CreateTween(Window.Instance, {Size = Size}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        else
            CreateTween(Window.Instance, {Size = UDim2.new(0, Size.X.Scale * 550, 0, 45)}, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        end
    end)

    -- Content area
    Window.Content = InstanceNew("Frame")
    Window.Content.Size = UDim2.new(1, -10, 1, -55)
    Window.Content.Position = UDim2.new(0, 5, 0, 50)
    Window.Content.BackgroundTransparency = 1
    Window.Content.ZIndex = 2
    Window.Content.Parent = Window.Instance

    -- Sidebar
    Window.Sidebar = InstanceNew("Frame")
    Window.Sidebar.Size = UDim2.new(0, 130, 1, 0)
    Window.Sidebar.BackgroundColor3 = Theme.SecondaryBackground
    Window.Sidebar.BackgroundTransparency = 0
    Window.Sidebar.BorderSizePixel = 0
    Window.Sidebar.ZIndex = 1
    Window.Sidebar.Parent = Window.Content

    AddCorner(Window.Sidebar, Theme.CornerRadius)
    AddListLayout(Window.Sidebar, 5, Enum.SortOrder.LayoutOrder, Enum.FillDirection.Vertical)

    -- Sidebar padding
    local SidebarPadding = InstanceNew("UIPadding")
    SidebarPadding.PaddingTop = UDim.new(0, 8)
    SidebarPadding.PaddingBottom = UDim.new(0, 8)
    SidebarPadding.Parent = Window.Sidebar

    -- Page container
    Window.PageContainer = InstanceNew("Frame")
    Window.PageContainer.Size = UDim2.new(1, -140, 1, 0)
    Window.PageContainer.Position = UDim2.new(0, 135, 0, 0)
    Window.PageContainer.BackgroundTransparency = 1
    Window.PageContainer.ZIndex = 1
    Window.PageContainer.Parent = Window.Content

    -- ============================================
    -- DRAGGING SYSTEM
    -- ============================================
    Window.Dragging = false
    Window.DragStart = nil
    Window.StartPos = nil

    local function StartDrag(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Window.Dragging = true
            Window.DragStart = Input.Position
            Window.StartPos = Window.Instance.Position
        end
    end

    local function UpdateDrag(Input)
        if Window.Dragging then
            local Delta = Input.Position - Window.DragStart
            Window.Instance.Position = UDim2.new(
                Window.StartPos.X.Scale, Window.StartPos.X.Offset + Delta.X,
                Window.StartPos.Y.Scale, Window.StartPos.Y.Offset + Delta.Y
            )
        end
    end

    local function EndDrag(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Window.Dragging = false
        end
    end

    Window.TitleBar.InputBegan:Connect(StartDrag)
    Window.TitleBar.InputEnded:Connect(EndDrag)
    UserInputService.InputChanged:Connect(UpdateDrag)

    -- Track window
    insert(self.Windows, Window)

    -- ============================================
    -- PAGE METHOD
    -- ============================================
    function Window:Page(PageData)
        local PageName = PageData.Name or "Page"
        local PageIcon = PageData.Icon or "📄"

        local Page = {}
        Page.Name = PageName
        Page.Window = self
        Page.Elements = {}

        -- Page button
        Page.Button = InstanceNew("TextButton")
        Page.Button.Size = UDim2.new(0.95, 0, 0, 35)
        Page.Button.BackgroundColor3 = Theme.TertiaryBackground
        Page.Button.Text = ""
        Page.Button.AutoButtonColor = false
        Page.Button.ZIndex = 2
        Page.Button.Parent = self.Sidebar

        AddCorner(Page.Button, Theme.SmallCornerRadius)

        -- Icon
        local Icon = InstanceNew("TextLabel")
        Icon.Size = UDim2.new(0, 30, 1, 0)
        Icon.Position = UDim2.new(0, 5, 0, 0)
        Icon.BackgroundTransparency = 1
        Icon.Text = PageIcon
        Icon.TextSize = 18
        Icon.ZIndex = 3
        Icon.Parent = Page.Button

        -- Text
        Page.Text = InstanceNew("TextLabel")
        Page.Text.Size = UDim2.new(1, -35, 1, 0)
        Page.Text.Position = UDim2.new(0, 35, 0, 0)
        Page.Text.BackgroundTransparency = 1
        Page.Text.Text = PageName
        Page.Text.TextColor3 = Theme.Text
        Page.Text.TextSize = 13
        Page.Text.Font = Enum.Font.Gotham
        Page.Text.TextXAlignment = Enum.TextXAlignment.Left
        Page.Text.ZIndex = 3
        Page.Text.Parent = Page.Button

        -- Page content
        Page.Content = InstanceNew("Frame")
        Page.Content.BackgroundTransparency = 1
        Page.Content.Visible = false
        Page.Content.ZIndex = 1
        Page.Content.Parent = self.PageContainer

        -- Scroll frame
        Page.ScrollFrame = InstanceNew("ScrollingFrame")
        Page.ScrollFrame.Size = UDim2.new(1, 0, 1, 0)
        Page.ScrollFrame.BackgroundTransparency = 1
        Page.ScrollFrame.BorderSizePixel = 0
        Page.ScrollFrame.ScrollBarThickness = 4
        Page.ScrollFrame.ScrollBarImageColor3 = Theme.Accent
        Page.ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        Page.ScrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
        Page.ScrollFrame.ScrollingEnabled = true
        Page.ScrollFrame.ZIndex = 1
        Page.ScrollFrame.Parent = Page.Content

        AddListLayout(Page.ScrollFrame, 8, Enum.SortOrder.LayoutOrder)

        local ScrollPadding = InstanceNew("UIPadding")
        ScrollPadding.PaddingTop = UDim.new(0, 5)
        ScrollPadding.PaddingBottom = UDim.new(0, 10)
        ScrollPadding.PaddingLeft = UDim.new(0, 5)
        ScrollPadding.PaddingRight = UDim.new(0, 5)
        ScrollPadding.Parent = Page.ScrollFrame

        -- Page selection
        local function SelectPage()
            for _, P in ipairs(self.Window.Pages) do
                P.Content.Visible = false
                P.Button.BackgroundColor3 = Theme.TertiaryBackground
                P.Text.TextColor3 = Theme.Text
            end

            Page.Content.Visible = true
            Page.Button.BackgroundColor3 = Theme.Accent
            Page.Text.TextColor3 = Theme.Text
            Library.CurrentPage = Page
        end

        Page.Button.MouseButton1Click:Connect(SelectPage)

        Page.Button.MouseEnter:Connect(function()
            if Page.Content.Visible ~= true then
                CreateTween(Page.Button, {BackgroundColor3 = Theme.SecondaryBackground}, 0.1)
            end
        end)

        Page.Button.MouseLeave:Connect(function()
            if Page.Content.Visible ~= true then
                CreateTween(Page.Button, {BackgroundColor3 = Theme.TertiaryBackground}, 0.1)
            end
        end)

        -- Section method
        function Page:Section(SectionData)
            local SectionName = SectionData.Name or "Section"
            local SectionSide = SectionData.Side or "left"

            local Section = {}
            Section.Name = SectionName
            Section.Page = self
            Section.Elements = {}

            -- Section container
            Section.Container = InstanceNew("Frame")
            Section.Container.Size = UDim2.new(0.48, 0, 0, 0)
            Section.Container.AutomaticSize = Enum.AutomaticSize.Y
            Section.Container.BackgroundColor3 = Theme.SecondaryBackground
            Section.Container.BorderSizePixel = 0
            Section.Container.LayoutOrder = SectionSide == "left" and 1 or 2
            Section.Container.ZIndex = 2
            Section.Container.Parent = self.ScrollFrame

            AddCorner(Section.Container, Theme.CornerRadius)
            AddStroke(Section.Container, Theme.Border, 1)

            -- Section header
            local Header = InstanceNew("TextLabel")
            Header.Size = UDim2.new(1, -16, 0, 30)
            Header.Position = UDim2.new(0, 8, 0, 8)
            Header.BackgroundTransparency = 1
            Header.Text = SectionName
            Header.TextColor3 = Theme.Text
            Header.TextSize = 14
            Header.Font = Enum.Font.GothamBold
            Header.TextXAlignment = Enum.TextXAlignment.Left
            Header.ZIndex = 3
            Header.Parent = Section.Container

            -- Section content
            Section.Content = InstanceNew("Frame")
            Section.Content.Size = UDim2.new(1, -16, 0, 0)
            Section.Content.Position = UDim2.new(0, 8, 0, 40)
            Section.Content.AutomaticSize = Enum.AutomaticSize.Y
            Section.Content.BackgroundTransparency = 1
            Section.Content.ZIndex = 2
            Section.Content.Parent = Section.Container

            AddListLayout(Section.Content, 5, Enum.SortOrder.LayoutOrder)

            insert(self.Elements, Section)
            insert(Library.Sections, Section)

            return Section
        end

        -- Select first page
        if #self.Window.Pages == 0 then
            SelectPage()
        end

        insert(self.Pages, Page)
        insert(self.Window.Pages, Page)
        insert(Library.Pages, Page)

        return Page
    end

    return Window
end

