    Window.Title.Position = UDim2.new(0, 15, 0, 0)
    Window.Title.BackgroundTransparency = 1
    Window.Title.Text = Name
    Window.Title.TextColor3 = Theme.Text
    Window.Title.TextSize = 16
    Window.Title.Font = Enum.Font.GothamBold
    Window.Title.TextXAlignment = Enum.TextXAlignment.Left
    Window.Title.ZIndex = 3
    Window.Title.Parent = Window.TitleBar

    print("[Window] Title text created")

    -- Close button
    Window.CloseBtn = InstanceNew("TextButton")
    Window.CloseBtn.Size = UDim2.new(0, 26, 0, 26)
    Window.CloseBtn.Position = UDim2.new(1, -40, 0.5, 0)
    Window.CloseBtn.AnchorPoint = Vector2.new(0, 0.5)
    Window.CloseBtn.BackgroundColor3 = Theme.Error
    Window.CloseBtn.BackgroundTransparency = 0
    Window.CloseBtn.Text = "×"
    Window.CloseBtn.TextColor3 = Theme.Text
    Window.CloseBtn.TextSize = 18
    Window.CloseBtn.Font = Enum.Font.GothamBold
    Window.CloseBtn.AutoButtonColor = false
    Window.CloseBtn.ZIndex = 3
    Window.CloseBtn.Parent = Window.TitleBar

    AddCorner(Window.CloseBtn, UDim.new(0, 6))

    Window.CloseBtn.MouseButton1Click:Connect(function()
        Window.Instance:Destroy()
    end)

    -- Content area
    Window.Content = InstanceNew("Frame")
    Window.Content.Size = UDim2.new(1, -10, 1, -50)
    Window.Content.Position = UDim2.new(0, 5, 0, 45)
    Window.Content.BackgroundTransparency = 1
    Window.Content.ZIndex = 2
    Window.Content.Parent = Window.Instance

    -- Sidebar
    Window.Sidebar = InstanceNew("Frame")
    Window.Sidebar.Size = UDim2.new(0, 120, 1, 0)
    Window.Sidebar.BackgroundColor3 = Theme.SecondaryBackground
    Window.Sidebar.BackgroundTransparency = 0
    Window.Sidebar.BorderSizePixel = 0
    Window.Sidebar.ZIndex = 1
    Window.Sidebar.Parent = Window.Content

    AddCorner(Window.Sidebar, UDim.new(0, 6))
    AddLayout(Window.Sidebar, 5)

    local SidebarPad = InstanceNew("UIPadding")
    SidebarPad.PaddingTop = UDim.new(0, 8)
    SidebarPad.PaddingBottom = UDim.new(0, 8)
    SidebarPad.Parent = Window.Sidebar

    -- Page container
    Window.PageContainer = InstanceNew("Frame")
    Window.PageContainer.Size = UDim2.new(1, -130, 1, 0)
    Window.PageContainer.Position = UDim2.new(0, 125, 0, 0)
    Window.PageContainer.BackgroundTransparency = 1
    Window.PageContainer.ZIndex = 1
    Window.PageContainer.Parent = Window.Content

    -- Dragging
    Window.Dragging = false

    Window.TitleBar.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            Window.Dragging = true
            Window.StartPos = Input.Position
            Window.OriginalPos = Window.Instance.Position
        end
    end)

    Window.TitleBar.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            Window.Dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(Input)
        if Window.Dragging and Input.UserInputType == Enum.UserInputType.MouseMovement then
            local Delta = Input.Position - Window.StartPos
            Window.Instance.Position = UDim2.new(
                Window.OriginalPos.X.Scale, Window.OriginalPos.X.Offset + Delta.X,
                Window.OriginalPos.Y.Scale, Window.OriginalPos.Y.Offset + Delta.Y
            )
        end
    end)

    insert(self.Windows, Window)

    print("[Window] Window created successfully!")
    print("[Window] Instance:", Window.Instance)
    print("[Window] Instance.Parent:", Window.Instance.Parent)
    print("[Window] Instance.Visible:", Window.Instance.Visible)

    -- PAGE METHOD
    function Window:Page(PageData)
        local PageName = PageData.Name or "Page"
        local PageIcon = PageData.Icon or "📄"

        print("[Page] Creating page:", PageName)

        local Page = {}
        Page.Name = PageName
        Page.Elements = {}
        Page.Sections = {}

        -- Page button
        Page.Button = InstanceNew("TextButton")
        Page.Button.Size = UDim2.new(0.95, 0, 0, 32)
        Page.Button.BackgroundColor3 = Theme.TertiaryBackground
        Page.Button.BackgroundTransparency = 0
        Page.Button.Text = ""
        Page.Button.AutoButtonColor = false
        Page.Button.ZIndex = 2
        Page.Button.Parent = Window.Sidebar

        AddCorner(Page.Button, UDim.new(0, 6))

        local IconLabel = InstanceNew("TextLabel")
        IconLabel.Size = UDim2.new(0, 25, 1, 0)
        IconLabel.Position = UDim2.new(0, 5, 0, 0)
        IconLabel.BackgroundTransparency = 1
        IconLabel.Text = PageIcon
        IconLabel.TextSize = 16
        IconLabel.ZIndex = 3
        IconLabel.Parent = Page.Button

        Page.Text = InstanceNew("TextLabel")
        Page.Text.Size = UDim2.new(1, -30, 1, 0)
        Page.Text.Position = UDim2.new(0, 30, 0, 0)
        Page.Text.BackgroundTransparency = 1
        Page.Text.Text = PageName
        Page.Text.TextColor3 = Theme.Text
        Page.Text.TextSize = 12
        Page.Text.Font = Enum.Font.Gotham
        Page.Text.TextXAlignment = Enum.TextXAlignment.Left
        Page.Text.ZIndex = 3
        Page.Text.Parent = Page.Button

        -- Page content
        Page.Content = InstanceNew("Frame")
        Page.Content.BackgroundTransparency = 1
        Page.Content.Visible = false
        Page.Content.ZIndex = 1
        Page.Content.Parent = Window.PageContainer

        Page.ScrollFrame = InstanceNew("ScrollingFrame")
        Page.ScrollFrame.Size = UDim2.new(1, 0, 1, 0)
        Page.ScrollFrame.BackgroundTransparency = 1
        Page.ScrollFrame.BorderSizePixel = 0
        Page.ScrollFrame.ScrollBarThickness = 4
        Page.ScrollFrame.ScrollBarImageColor3 = Theme.Accent
        Page.ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        Page.ScrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
        Page.ScrollFrame.ZIndex = 1
        Page.ScrollFrame.Parent = Page.Content

        AddLayout(Page.ScrollFrame, 8)

        local ScrollPad = InstanceNew("UIPadding")
        ScrollPad.PaddingTop = UDim.new(0, 5)
        ScrollPad.PaddingBottom = UDim.new(0, 10)
        ScrollPad.Parent = Page.ScrollFrame

        -- Page selection
        local function SelectPage()
            for _, P in ipairs(Window.Pages) do
                P.Content.Visible = false
                P.Button.BackgroundColor3 = Theme.TertiaryBackground
                P.Text.TextColor3 = Theme.Text
            end
            Page.Content.Visible = true
            Page.Button.BackgroundColor3 = Theme.Accent
            Page.Text.TextColor3 = Theme.Text
        end

        Page.Button.MouseButton1Click:Connect(SelectPage)

        Page.Button.MouseEnter:Connect(function()
            if not Page.Content.Visible then
                CreateTween(Page.Button, {BackgroundColor3 = Theme.SecondaryBackground}, 0.1)
            end
        end)

        Page.Button.MouseLeave:Connect(function()
            if not Page.Content.Visible then
                CreateTween(Page.Button, {BackgroundColor3 = Theme.TertiaryBackground}, 0.1)
            end
        end)

        -- SECTION METHOD
        function Page:Section(SectionData)
            local SectionName = SectionData.Name or "Section"
            local SectionSide = SectionData.Side or "left"

            print("[Section] Creating section:", SectionName)

            local Section = {}
            Section.Name = SectionName
            Section.Elements = {}

            Section.Container = InstanceNew("Frame")
            Section.Container.Size = UDim2.new(0.48, 0, 0, 0)
            Section.Container.AutomaticSize = Enum.AutomaticSize.Y
            Section.Container.BackgroundColor3 = Theme.SecondaryBackground
            Section.Container.BackgroundTransparency = 0
            Section.Container.BorderSizePixel = 0
            Section.Container.LayoutOrder = SectionSide == "left" and 1 or 2
            Section.Container.ZIndex = 2
            Section.Container.Parent = Page.ScrollFrame

            AddCorner(Section.Container, UDim.new(0, 6))
            AddStroke(Section.Container, Theme.Border, 1)

            local SectionHeader = InstanceNew("TextLabel")
            SectionHeader.Size = UDim2.new(1, -16, 0, 28)
            SectionHeader.Position = UDim2.new(0, 8, 0, 8)
            SectionHeader.BackgroundTransparency = 1
            SectionHeader.Text = SectionName
            SectionHeader.TextColor3 = Theme.Text
            SectionHeader.TextSize = 14
            SectionHeader.Font = Enum.Font.GothamBold
            SectionHeader.TextXAlignment = Enum.TextXAlignment.Left
            SectionHeader.ZIndex = 3
            SectionHeader.Parent = Section.Container

            Section.Content = InstanceNew("Frame")
            Section.Content.Size = UDim2.new(1, -16, 0, 0)
            Section.Content.Position = UDim2.new(0, 8, 0, 38)
            Section.Content.AutomaticSize = Enum.AutomaticSize.Y
            Section.Content.BackgroundTransparency = 1
            Section.Content.ZIndex = 2
            Section.Content.Parent = Section.Container

            AddLayout(Section.Content, 5)

            insert(Page.Elements, Section)
            insert(Page.Sections, Section)
            insert(Library.Sections, Section)

            print("[Section] Section created:", SectionName)

            -- TOGGLE METHOD
            function Section:Toggle(Data)
                local ToggleName = Data.Name or "Toggle"
                local Default = Data.Default or false
                local Flag = Data.Flag or "toggle_" .. tick()
                local Callback = Data.Callback or function() end

                print("[Toggle] Creating toggle:", ToggleName)

                local Toggle = {}
                Toggle.Name = ToggleName
                Toggle.Flag = Flag
                Toggle.Value = Default
                Toggle.Callback = Callback

                Toggle.Container = InstanceNew("Frame")
                Toggle.Container.Size = UDim2.new(1, 0, 0, 30)
                Toggle.Container.BackgroundTransparency = 1
                Toggle.Container.ZIndex = 3
                Toggle.Container.Parent = Section.Content

                Toggle.Label = InstanceNew("TextLabel")
                Toggle.Label.Size = UDim2.new(1, -45, 1, 0)
                Toggle.Label.BackgroundTransparency = 1
                Toggle.Label.Text = ToggleName
                Toggle.Label.TextColor3 = Theme.Text
                Toggle.Label.TextSize = 13
                Toggle.Label.Font = Enum.Font.Gotham
                Toggle.Label.TextXAlignment = Enum.TextXAlignment.Left
                Toggle.Label.TextYAlignment = Enum.TextYAlignment.Center
                Toggle.Label.ZIndex = 4
                Toggle.Label.Parent = Toggle.Container

                Toggle.Checkbox = InstanceNew("TextButton")
                Toggle.Checkbox.Size = UDim2.new(0, 22, 0, 22)
                Toggle.Checkbox.Position = UDim2.new(1, -24, 0.5, 0)
                Toggle.Checkbox.AnchorPoint = Vector2.new(0, 0.5)
                Toggle.Checkbox.BackgroundColor3 = Default and Theme.ToggleOn or Theme.ToggleOff
                Toggle.Checkbox.BackgroundTransparency = 0
                Toggle.Checkbox.Text = ""
                Toggle.Checkbox.AutoButtonColor = false
                Toggle.Checkbox.ZIndex = 4
                Toggle.Checkbox.Parent = Toggle.Container

                AddCorner(Toggle.Checkbox, UDim.new(0, 6))
                AddStroke(Toggle.Checkbox, Theme.Border, 1)

                Toggle.Checkmark = InstanceNew("TextLabel")
                Toggle.Checkmark.Size = UDim2.new(1, 0, 1, 0)
                Toggle.Checkmark.BackgroundTransparency = 1
                Toggle.Checkmark.Text = "✓"
                Toggle.Checkmark.TextColor3 = Theme.Text
                Toggle.Checkmark.TextSize = 14
                Toggle.Checkmark.Font = Enum.Font.GothamBold
                Toggle.Checkmark.Visible = Default
                Toggle.Checkmark.ZIndex = 5
                Toggle.Checkmark.Parent = Toggle.Checkbox

                function Toggle:Set(Value)
                    self.Value = Value
                    self.Checkmark.Visible = Value
                    self.Checkbox.BackgroundColor3 = Value and Theme.ToggleOn or Theme.ToggleOff
                    Library.Flags[self.Flag] = Value
                    self.Callback(Value)
                end

                Toggle.Checkbox.MouseButton1Click:Connect(function()
                    Toggle:Set(not Toggle.Value)
                end)

                Toggle.Checkbox.MouseEnter:Connect(function()
                    local Color = Toggle.Value and Theme.AccentHover or Theme.SecondaryBackground
                    CreateTween(Toggle.Checkbox, {BackgroundColor3 = Color}, 0.1)
                end)

                Toggle.Checkbox.MouseLeave:Connect(function()
                    local Color = Toggle.Value and Theme.ToggleOn or Theme.ToggleOff
                    CreateTween(Toggle.Checkbox, {BackgroundColor3 = Color}, 0.1)
                end)

                Library.Flags[Flag] = Default
                insert(Section.Elements, Toggle)

                print("[Toggle] Toggle created:", ToggleName)

                return Toggle
            end

            -- BUTTON METHOD
            function Section:Button(Data)
                local ButtonName = Data.Name or "Button"
                local Callback = Data.Callback or function() end

                print("[Button] Creating button:", ButtonName)

                local Button = {}
                Button.Name = ButtonName

                Button.Container = InstanceNew("Frame")
                Button.Container.Size = UDim2.new(1, 0, 0, 34)
                Button.Container.BackgroundTransparency = 1
                Button.Container.ZIndex = 3
                Button.Container.Parent = Section.Content

                Button.Instance = InstanceNew("TextButton")
                Button.Instance.Size = UDim2.new(1, 0, 1, 0)
                Button.Instance.BackgroundColor3 = Theme.Accent
                Button.Instance.BackgroundTransparency = 0
                Button.Instance.Text = ButtonName
                Button.Instance.TextColor3 = Theme.Text
                Button.Instance.TextSize = 13
                Button.Instance.Font = Enum.Font.GothamBold
                Button.Instance.AutoButtonColor = false
                Button.Instance.ZIndex = 4
                Button.Instance.Parent = Button.Container

                AddCorner(Button.Instance, UDim.new(0, 6))

                Button.Instance.MouseButton1Click:Connect(function()
                    print("[Button] Clicked:", ButtonName)
                    Callback()
                end)

                Button.Instance.MouseEnter:Connect(function()
                    CreateTween(Button.Instance, {BackgroundColor3 = Theme.AccentHover}, 0.1)
                end)

                Button.Instance.MouseLeave:Connect(function()
                    CreateTween(Button.Instance, {BackgroundColor3 = Theme.Accent}, 0.1)
                end)

                Button.Instance.MouseButton1Down:Connect(function()
                    CreateTween(Button.Instance, {BackgroundColor3 = Theme.AccentDark}, 0.05)
                end)

                Button.Instance.MouseButton1Up:Connect(function()
                    CreateTween(Button.Instance, {BackgroundColor3 = Theme.Accent}, 0.05)
                end)

                insert(Section.Elements, Button)

                print("[Button] Button created:", ButtonName)

                return Button
            end

            return Section
        end

        if #Window.Pages == 0 then
            SelectPage()
        end

        insert(Window.Pages, Page)
        insert(Library.Pages, Page)

        print("[Page] Page created:", PageName)

        return Page
    end

    return Window
end

-- NOTIFICATION
function Library:Notify(Data)
    local Text = Data.Text or "Notification"
    local Duration = Data.Duration or 3

    print("[Notify] Creating notification:", Text)

    if not self.NotifHolder then
        self.NotifHolder = InstanceNew("Frame")
        self.NotifHolder.Size = UDim2.new(0, 300, 1, 0)
        self.NotifHolder.Position = UDim2.new(1, -310, 0, 20)
        self.NotifHolder.BackgroundTransparency = 1
        self.NotifHolder.ZIndex = 100
        self.NotifHolder.Parent = CoreGui

        local Layout = InstanceNew("UIListLayout")
        Layout.SortOrder = Enum.SortOrder.LayoutOrder
        Layout.Padding = UDim.new(0, 10)
        Layout.HorizontalAlignment = Enum.HorizontalAlignment.Right
        Layout.VerticalAlignment = Enum.VerticalAlignment.Top
        Layout.Parent = self.NotifHolder
    end

    local Notification = InstanceNew("Frame")
    Notification.Size = UDim2.new(1, 0, 0, 50)
    Notification.BackgroundColor3 = Theme.Background
    Notification.BackgroundTransparency = 0
    Notification.BorderSizePixel = 0
    Notification.ZIndex = 101
    Notification.Parent = self.NotifHolder

    AddCorner(Notification, UDim.new(0, 8))
    AddStroke(Notification, Theme.Border, 1)

    local NotifText = InstanceNew("TextLabel")
    NotifText.Size = UDim2.new(1, -20, 1, 0)
    NotifText.Position = UDim2.new(0, 10, 0, 0)
    NotifText.BackgroundTransparency = 1
    NotifText.Text = Text
    NotifText.TextColor3 = Theme.Text
    NotifText.TextSize = 13
    NotifText.Font = Enum.Font.Gotham
    NotifText.TextWrapped = true
    NotifText.ZIndex = 102
    NotifText.Parent = Notification

    Notification.Position = UDim2.new(1, 20, 0, 0)
    CreateTween(Notification, {
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 0,
        TextTransparency = 0
    }, 0.3, Enum.EasingStyle.Back)

    task.delay(Duration, function()
        CreateTween(Notification, {
            Position = UDim2.new(1, 20, 0, 0),
            BackgroundTransparency = 1,
            TextTransparency = 1
        }, 0.2)
        task.wait(0.2)
        Notification:Destroy()
    end)

    print("[Notify] Notification created")

    return Notification
end

-- CLEANUP
function Library:Unload()
    for _, Window in ipairs(self.Windows) do
        if Window.Instance and Window.Instance.Parent then
            Window.Instance:Destroy()
        end
    end
    if self.NotifHolder and self.NotifHolder.Parent then
        self.NotifHolder:Destroy()
    end
    self.Windows = {}
    self.Pages = {}
    self.Sections = {}
    self.Flags = {}
end

-- EXPORT
getgenv().MyUILibrary = Library

print("[Library] Export complete. Library ready.")

return Library
