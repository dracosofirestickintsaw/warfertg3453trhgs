    AddStroke(Window.Instance, Theme.Border, 1)

    -- Title bar
    Window.TitleBar = InstanceNew("Frame")
    Window.TitleBar.Size = UDim2.new(1, 0, 0, 40)
    Window.TitleBar.BackgroundColor3 = Theme.SecondaryBackground
    Window.TitleBar.BackgroundTransparency = 0  -- EXPLICIT
    Window.TitleBar.BorderSizePixel = 0
    Window.TitleBar.ZIndex = 2
    Window.TitleBar.Parent = Window.Instance

    print("[Window] Title bar created")

    AddCorner(Window.TitleBar, UDim.new(0, 10))

    -- Corner fix
    local CornerFix = InstanceNew("Frame")
    CornerFix.Size = UDim2.new(1, 0, 0, 10)
    CornerFix.Position = UDim2.new(0, 0, 1, -10)
    CornerFix.BackgroundColor3 = Theme.SecondaryBackground
    CornerFix.BackgroundTransparency = 0
    CornerFix.BorderSizePixel = 0
    CornerFix.ZIndex = 2
    CornerFix.Parent = Window.TitleBar

    -- Title text
    Window.Title = InstanceNew("TextLabel")
