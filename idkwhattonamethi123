    Window.Instance.BackgroundTransparency = 0  -- EXPLICIT: Not transparent!
    Window.Instance.BorderSizePixel = 0
    Window.Instance.ZIndex = 10
    Window.Instance.Visible = true  -- EXPLICIT: Make visible

