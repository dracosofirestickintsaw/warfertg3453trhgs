--[[
    SUPER SIMPLE UI LIBRARY
    This WILL show on screen - guaranteed
    Line by line debugging included
]]

-- STEP 1: Get services
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

print("[1] Services loaded")

-- STEP 2: Create the Library table
local MyUILib = {}

print("[2] Library table created")

-- STEP 3: Set metatable RIGHT AWAY before anything else
setmetatable(MyUILib, {__index = MyUILib})

print("[3] Metatable set")

-- STEP 4: Create a simple function that makes a FRAME
function MyUILib:MakeWindow()
    print("[4a] Creating window...")
    
    -- Create a SIMPLE RED FRAME
    local Window = Instance.new("Frame")
    Window.Name = "TestWindow"
    Window.Size = UDim2.new(0, 400, 0, 300)
    Window.Position = UDim2.new(0.5, 0, 0.5, 0)
    Window.AnchorPoint = Vector2.new(0.5, 0.5)
    Window.BackgroundColor3 = Color3.fromRGB(255, 50, 50)  -- RED!
    Window.BackgroundTransparency = 0
    Window.BorderSizePixel = 0
    Window.Visible = true
    Window.ZIndex = 10
    
    print("[4b] Frame properties set")
    
    -- Parent to CoreGui
    Window.Parent = CoreGui
    
    print("[4c] Parent set to CoreGui")
    print("[4d] Window created! Check your screen!")
    
    return Window
end

-- STEP 5: Function to add a button
function MyUILib:AddButton(Window, Text, Callback)
    local Button = Instance.new("TextButton")
    Button.Name = "TestButton"
    Button.Size = UDim2.new(0, 200, 0, 50)
    Button.Position = UDim2.new(0.5, 0, 0.5, 0)
    Button.AnchorPoint = Vector2.new(0.5, 0.5)
    Button.BackgroundColor3 = Color3.fromRGB(50, 150, 255)  -- BLUE
    Button.BackgroundTransparency = 0
    Button.Text = Text or "Click Me!"
    Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    Button.TextSize = 16
    Button.Font = Enum.Font.GothamBold
    Button.AutoButtonColor = false
    Button.Visible = true
    Button.ZIndex = 11
    
    Button.Parent = Window
    
    Button.MouseButton1Click:Connect(function()
        if Callback then
            Callback()
        end
    end)
    
    print("[5] Button added: " .. (Text or "unnamed"))
    
    return Button
end

-- STEP 6: Function to add a label
function MyUILib:AddLabel(Window, Text)
    local Label = Instance.new("TextLabel")
    Label.Name = "TestLabel"
    Label.Size = UDim2.new(1, -20, 0, 30)
    Label.Position = UDim2.new(0, 10, 0, 10)
    Label.BackgroundTransparency = 1
    Label.Text = Text or "Hello!"
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.TextSize = 18
    Label.Font = Enum.Font.GothamBold
    Label.Visible = true
    Label.ZIndex = 11
    
    Label.Parent = Window
    
    print("[6] Label added: " .. (Text or "unnamed"))
    
    return Label
end

-- STEP 7: Simple notification
function MyUILib:Notify(Text)
    local Notif = Instance.new("TextLabel")
    Notif.Name = "Notification"
    Notif.Size = UDim2.new(0, 300, 0, 50)
    Notif.Position = UDim2.new(1, -320, 0, 20)
    Notif.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Notif.BackgroundTransparency = 0
    Notif.Text = Text or "Notification"
    Notif.TextColor3 = Color3.fromRGB(255, 255, 255)
    Notif.TextSize = 14
    Notif.Font = Enum.Font.Gotham
    Notif.Visible = true
    Notif.ZIndex = 100
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 8)
    Corner.Parent = Notif
    
    Notif.Parent = CoreGui
    
    print("[7] Notification shown: " .. (Text or "unnamed"))
    
    return Notif
end

print("[8] All functions defined")

-- STEP 8: Export
getgenv().MyUILib = MyUILib

print("[9] Exported to getgenv().MyUILib")

-- STEP 9: Return the library
return MyUILib
