--[[
    UI Library — dark/purple aesthetic
    Matching the reference design (MainFrame, glow sections, tab bar)

    API USAGE:
    ─────────────────────────────────────────────────────────
    local Library = loadstring(game:HttpGet("..."))()

    local Window = Library:Window({
        name   = "myhub",
        logo   = "rbxassetid://...",   -- or "lucide:star"
        key    = "RightControl",       -- toggle keybind
        size   = Vector2.new(700, 520) -- optional
    })

    local Tab = Window:Tab({
        name = "Environment",
        icon = "lucide:leaf",          -- lucide icon or rbxassetid://...
    })

    local Section = Tab:Section({
        name = "World",
        side = 1,   -- 1 = left column, 2 = right column
    })

    Section:Toggle({ name = "Remove Sky", flag = "sky",   default = false, callback = function(v) end })
    Section:Button({ name = "Rejoin",     icon = "lucide:refresh-cw",     callback = function()   end })
    Section:Slider({ name = "Walk Speed", flag = "ws",    min = 0, max = 200, default = 16, suffix = " stud/s", callback = function(v) end })
    Section:Dropdown({ name = "Quality",  flag = "qual",  items = {"Low","Med","High"}, default = "Med", callback = function(v) end })
    Section:Textbox({ name = "Username",  flag = "user",  placeholder = "enter name…", callback = function(v) end })
    Section:Label({ name = "Version: 1.0" })

    Window:Notify({ title = "Hello", description = "Library loaded.", duration = 4 })
    ─────────────────────────────────────────────────────────
]]

