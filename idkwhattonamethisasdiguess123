-- ── tiny helpers ──────────────────────────────────────────────────────────────
local function inst(class, props, parent)
    local i = Instance.new(class)
    for k, v in props or {} do i[k] = v end
    if parent then i.Parent = parent end
    return i
end

local function corner(r, p)
    inst("UICorner", { CornerRadius = UDim.new(0, r) }, p)
end

local function stroke(color, transp, thick, p)
    inst("UIStroke", {
        Color = color, Transparency = transp or 0,
        Thickness = thick or 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    }, p)
end

local function gradient(cs, p)
    inst("UIGradient", { Color = cs }, p)
end

local function tw(obj, props, dur, style, dir)
    TweenSvc:Create(obj,
        TweenInfo.new(dur or .2,
            Enum.EasingStyle[style or "Quart"],
            Enum.EasingDirection[dir or "Out"]),
        props):Play()
end

local function mkIcon(name, size, color)
    size  = size  or UDim2.fromOffset(16, 16)
    color = color or T.Text
    if not name or name == "" then return nil end

    -- asset id
    if name:match("^rbxassetid://") or name:match("^%d+$") then
        local img = inst("ImageLabel", {
            BackgroundTransparency = 1,
            Size = size,
            Image = name:match("^%d+$") and ("rbxassetid://"..name) or name,
            ImageColor3 = color,
        })
        return img
    end

    -- lucide
    if Icons then
        local ok, obj = pcall(function()
            return Icons.Image({ Icon = name, Size = size, Colors = { color } })
        end)
        if ok and obj and obj.IconFrame then
            obj.IconFrame.BackgroundTransparency = 1
            return obj.IconFrame
        end
    end
    return nil
end

-- ── notification stack holder (global, above everything) ─────────────────────
