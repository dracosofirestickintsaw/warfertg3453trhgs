-- ── library object ────────────────────────────────────────────────────────────
local Library = {
    Flags      = {},
    SetFlags   = {},
    _conns     = {},
}
Library.__index = Library

function Library:Destroy()
    if self._root then self._root:Destroy() end
    for _, c in self._conns do pcall(function() c:Disconnect() end) end
end

-- ══════════════════════════════════════════════════════════════════════════════
-- WINDOW
-- ══════════════════════════════════════════════════════════════════════════════
function Library:Window(p)
    p = p or {}
    local title   = p.name  or p.Name  or "hub"
    local logo    = p.logo  or p.Logo  or nil
    local key     = p.key   or p.Key   or "RightControl"
    local sz      = p.size  or p.Size  or Vector2.new(700, 520)

    local visible   = true
    local minimized = false
    local Tabs      = {}

    -- ── screen gui ────────────────────────────────────────────────────────────
    local Gui = inst("ScreenGui", {
        Name            = "UILib",
        ZIndexBehavior  = Enum.ZIndexBehavior.Global,
        ResetOnSpawn    = false,
        DisplayOrder    = 999,
        IgnoreGuiInset  = true,
        Parent          = gethui(),
    })
    Library._root = Gui

    -- ── root frame ────────────────────────────────────────────────────────────
    local Root = inst("Frame", {
        AnchorPoint      = Vector2.new(.5, .5),
        Position         = UDim2.new(.5, 0, .5, 0),
        Size             = UDim2.fromOffset(sz.X, sz.Y),
        BackgroundColor3 = T.BG,
        BorderSizePixel  = 0,
        ClipsDescendants = false,
        Parent           = Gui,
    })
    corner(8, Root)
    inst("UIGradient", {
        Rotation     = -90,
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0,  0),
            NumberSequenceKeypoint.new(1,  .18),
        }),
    }, Root)
    stroke(T.Accent, .82, 1.5, Root)

    -- ── topbar ────────────────────────────────────────────────────────────────
    local Topbar = inst("Frame", {
        Size             = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = T.Topbar,
        BorderSizePixel  = 0,
        ZIndex           = 3,
        Parent           = Root,
    })
    corner(8, Topbar)
    -- cover bottom rounded corners
    inst("Frame", {
        AnchorPoint      = Vector2.new(0, 1),
        Position         = UDim2.new(0, 0, 1, 0),
        Size             = UDim2.new(1, 0, 0, 8),
        BackgroundColor3 = T.Topbar,
        BorderSizePixel  = 0,
        ZIndex           = 3,
        Parent           = Topbar,
    })

    -- logo
    local txtOffX = 12
    if logo then
        local ic = mkIcon(logo, UDim2.fromOffset(20, 20), T.Accent)
        if ic then
            ic.AnchorPoint = Vector2.new(0, .5)
            ic.Position    = UDim2.new(0, 10, .5, 0)
            ic.ZIndex      = 4
            ic.Parent      = Topbar
            txtOffX        = 36
        end
    end

    inst("TextLabel", {
        Text             = title,
        Font             = Enum.Font.GothamBold,
        TextSize         = 14,
        TextColor3       = T.Accent,
        BackgroundTransparency = 1,
        Position         = UDim2.new(0, txtOffX, 0, 0),
        Size             = UDim2.new(.6, -txtOffX, 1, 0),
        TextXAlignment   = Enum.TextXAlignment.Left,
        ZIndex           = 4,
        Parent           = Topbar,
    })

    -- accent separator line under topbar
    local sepLine = inst("Frame", {
        AnchorPoint      = Vector2.new(0, 1),
        Position         = UDim2.new(0, 0, 1, 0),
        Size             = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = T.White,
        BorderSizePixel  = 0,
        ZIndex           = 3,
        Parent           = Topbar,
    })
    gradient(ColorSequence.new({
        ColorSequenceKeypoint.new(0, T.Accent),
        ColorSequenceKeypoint.new(1, T.AccentDark),
    }), sepLine)

    -- control buttons
    local function ctrlBtn(xOff, txt, size2)
        local b = inst("TextButton", {
            Text             = txt,
            Font             = Enum.Font.GothamBold,
            TextSize         = size2 or 16,
            TextColor3       = T.TextDim,
            BackgroundTransparency = 1,
            AnchorPoint      = Vector2.new(1, .5),
            Position         = UDim2.new(1, xOff, .5, 0),
            Size             = UDim2.new(0, 22, 0, 22),
            AutoButtonColor  = false,
            ZIndex           = 4,
            Parent           = Topbar,
        })
        b.MouseEnter:Connect(function() tw(b, { TextColor3 = T.White }) end)
        b.MouseLeave:Connect(function() tw(b, { TextColor3 = T.TextDim }) end)
        return b
    end
    local CloseBtn = ctrlBtn(-6,  "×", 20)
    local MinBtn   = ctrlBtn(-28, "−", 14)

    -- ── tab bar ───────────────────────────────────────────────────────────────
    local TabBar = inst("Frame", {
        Position         = UDim2.new(0, 0, 0, 37),
        Size             = UDim2.new(1, 0, 0, 32),
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        ZIndex           = 3,
        Parent           = Root,
    })
    inst("UIListLayout", {
        FillDirection      = Enum.FillDirection.Horizontal,
        VerticalAlignment  = Enum.VerticalAlignment.Center,
        Padding            = UDim.new(0, 6),
        SortOrder          = Enum.SortOrder.LayoutOrder,
    }, TabBar)
    inst("UIPadding", {
        PaddingLeft = UDim.new(0, 10),
        PaddingTop  = UDim.new(0, 4),
    }, TabBar)

    -- ── content area ──────────────────────────────────────────────────────────
    local Content = inst("Frame", {
        Position         = UDim2.new(0, 0, 0, 69),
        Size             = UDim2.new(1, 0, 1, -69),
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        Parent           = Root,
    })

    -- ── notification holder ───────────────────────────────────────────────────
    NotifHolder = inst("Frame", {
        AnchorPoint = Vector2.new(1, 1),
        Position    = UDim2.new(1, -14, 1, -14),
        Size        = UDim2.new(0, 280, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = 200,
        Parent = Gui,
    })
    inst("UIListLayout", {
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        FillDirection = Enum.FillDirection.Vertical,
        Padding = UDim.new(0, 6),
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, NotifHolder)

    -- ── draggable ─────────────────────────────────────────────────────────────
    do
        local drag, ds, sp
        Topbar.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                drag = true; ds = i.Position; sp = Root.Position
            end
        end)
        local c1 = UIS.InputChanged:Connect(function(i)
            if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
                local d = i.Position - ds
                Root.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
            end
        end)
        local c2 = UIS.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
        end)
        table.insert(Library._conns, c1)
        table.insert(Library._conns, c2)
    end

    -- ── minimize ──────────────────────────────────────────────────────────────
    MinBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            tw(Root, { Size = UDim2.fromOffset(sz.X, 36) })
            Content.Visible = false; TabBar.Visible = false
        else
            tw(Root, { Size = UDim2.fromOffset(sz.X, sz.Y) })
            Content.Visible = true; TabBar.Visible = true
        end
    end)

    -- ── close ─────────────────────────────────────────────────────────────────
    CloseBtn.MouseButton1Click:Connect(function()
        tw(Root, { Size = UDim2.fromOffset(60, 60), BackgroundTransparency = 1 }, .35)
        task.delay(.35, function() Gui:Destroy() end)
    end)

    -- ── toggle keybind ────────────────────────────────────────────────────────
    local kc = UIS.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if tostring(input.KeyCode):find(key) or tostring(input.UserInputType):find(key) then
            visible = not visible
            Root.Visible = visible
        end
    end)
    table.insert(Library._conns, kc)

    -- ══════════════════════════════════════════════════════════════════════════
    -- WINDOW object
    -- ══════════════════════════════════════════════════════════════════════════
    local Window = { _root = Root, _gui = Gui }

    -- ── NOTIFY ────────────────────────────────────────────────────────────────
    function Window:Notify(np)
        np = np or {}
        local nt  = np.title       or "Notification"
        local nd  = np.description or np.desc or ""
        local dur = np.duration    or 4

        local NF = inst("Frame", {
            BackgroundColor3 = T.Inline,
            Size             = UDim2.new(1, 0, 0, 62),
            BorderSizePixel  = 0,
            ZIndex           = 201,
            Parent           = NotifHolder,
        })
        corner(6, NF)
        stroke(T.Accent, .65, 1, NF)

        -- top accent strip
        local strip = inst("Frame", {
            Size             = UDim2.new(1, 0, 0, 3),
            BackgroundColor3 = T.Accent,
            BorderSizePixel  = 0,
            ZIndex           = 202,
            Parent           = NF,
        })
        corner(3, strip)
        inst("Frame", {   -- hide bottom half of strip's corners
            Position         = UDim2.new(0, 0, 0, 1),
            Size             = UDim2.new(1, 0, 0, 3),
            BackgroundColor3 = T.Inline,
            BorderSizePixel  = 0,
            ZIndex           = 203,
            Parent           = NF,
        })

        inst("TextLabel", {
            Text             = nt,
            Font             = Enum.Font.GothamBold,
            TextSize         = 13,
            TextColor3       = T.Accent,
            BackgroundTransparency = 1,
            Position         = UDim2.new(0, 10, 0, 8),
            Size             = UDim2.new(1, -20, 0, 17),
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 202,
            Parent           = NF,
        })
        inst("TextLabel", {
            Text             = nd,
            Font             = Enum.Font.Gotham,
            TextSize         = 11,
            TextColor3       = T.Text,
            BackgroundTransparency = 1,
            Position         = UDim2.new(0, 10, 0, 28),
            Size             = UDim2.new(1, -20, 0, 26),
            TextXAlignment   = Enum.TextXAlignment.Left,
            TextWrapped      = true,
            ZIndex           = 202,
            Parent           = NF,
        })

        -- progress bar
        local pb = inst("Frame", {
            AnchorPoint      = Vector2.new(0, 1),
            Position         = UDim2.new(0, 0, 1, 0),
            Size             = UDim2.new(1, 0, 0, 2),
            BackgroundColor3 = T.Accent,
            BorderSizePixel  = 0,
            ZIndex           = 202,
            Parent           = NF,
        })
        corner(2, pb)
        gradient(ColorSequence.new({
            ColorSequenceKeypoint.new(0, T.Accent),
            ColorSequenceKeypoint.new(1, T.AccentDark),
        }), pb)

        TweenSvc:Create(pb, TweenInfo.new(dur, Enum.EasingStyle.Linear),
            { Size = UDim2.new(0, 0, 0, 2) }):Play()

        task.delay(dur, function()
            tw(NF, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0) }, .3)
            task.wait(.35)
            NF:Destroy()
        end)

        return NF
    end

    -- ══════════════════════════════════════════════════════════════════════════
    -- TAB
    -- ══════════════════════════════════════════════════════════════════════════
    function Window:Tab(tp)
        tp = tp or {}
        local tname   = tp.name or tp.Name or "Tab"
        local ticon   = tp.icon or tp.Icon or ""
        local isFirst = #Tabs == 0

        -- tab button frame
        local BF = inst("Frame", {
            BackgroundColor3 = T.TabStart,
            Size             = UDim2.new(0, 0, 0, 24),
            AutomaticSize    = Enum.AutomaticSize.X,
            BorderSizePixel  = 0,
            ZIndex           = 4,
            Parent           = TabBar,
        })
        corner(4, BF)
        inst("UIGradient", {
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, T.TabStart),
                ColorSequenceKeypoint.new(1, T.TabEnd),
            }),
        }, BF)
        inst("UIPadding", {
            PaddingLeft  = UDim.new(0, 8),
            PaddingRight = UDim.new(0, 8),
        }, BF)
        inst("UIListLayout", {
            FillDirection     = Enum.FillDirection.Horizontal,
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Padding           = UDim.new(0, 5),
        }, BF)

        -- icon in tab
        if ticon ~= "" then
            local ic = mkIcon(ticon, UDim2.fromOffset(13, 13), isFirst and T.Accent or T.TextDim)
            if ic then ic.ZIndex = 5; ic.Parent = BF end
        end

        local BLabel = inst("TextLabel", {
            Text             = tname,
            Font             = Enum.Font.Gotham,
            TextSize         = 13,
            TextColor3       = isFirst and T.Accent or T.Text,
            BackgroundTransparency = 1,
            Size             = UDim2.new(0, 0, 1, 0),
            AutomaticSize    = Enum.AutomaticSize.X,
            ZIndex           = 5,
            Parent           = BF,
        })

        -- clickable overlay
        local BClick = inst("TextButton", {
            Text             = "",
            BackgroundTransparency = 1,
            Size             = UDim2.new(1, 0, 1, 0),
            AutoButtonColor  = false,
            ZIndex           = 6,
            Parent           = BF,
        })

        -- active underline
        local ActiveLine = inst("Frame", {
            AnchorPoint      = Vector2.new(0, 1),
            Position         = UDim2.new(0, 0, 1, 0),
            Size             = UDim2.new(isFirst and 1 or 0, 0, 0, 2),
            BackgroundColor3 = T.Accent,
            BorderSizePixel  = 0,
            ZIndex           = 5,
            Parent           = BF,
        })
        corner(1, ActiveLine)

        -- page
        local Page = inst("Frame", {
            BackgroundTransparency = 1,
            Size             = UDim2.new(1, 0, 1, 0),
            Visible          = isFirst,
            BorderSizePixel  = 0,
            Parent           = Content,
        })

        -- two scrolling columns
        local function mkCol(posX, w)
            local sf = inst("ScrollingFrame", {
                Position                = posX,
                Size                    = w,
                BackgroundTransparency  = 1,
                ScrollBarThickness      = 2,
                ScrollBarImageColor3    = T.Accent,
                ScrollBarImageTransparency = .5,
                AutomaticCanvasSize     = Enum.AutomaticSize.Y,
                CanvasSize              = UDim2.new(0,0,0,0),
                BorderSizePixel         = 0,
                Parent                  = Page,
            })
            inst("UIListLayout", {
                Padding       = UDim.new(0, 10),
                SortOrder     = Enum.SortOrder.LayoutOrder,
            }, sf)
            inst("UIPadding", {
                PaddingTop    = UDim.new(0, 10),
                PaddingBottom = UDim.new(0, 10),
                PaddingLeft   = UDim.new(0, 12),
                PaddingRight  = UDim.new(0, 10),
            }, sf)
            return sf
        end
        local LeftCol  = mkCol(UDim2.new(0,0,0,0),      UDim2.new(.5,-8,1,0))
        local RightCol = mkCol(UDim2.new(.5,8,0,0),     UDim2.new(.5,-8,1,0))

        -- tab object
        local Tab = {
            _bf      = BF,
            _label   = BLabel,
            _line    = ActiveLine,
            _page    = Page,
            _cols    = { LeftCol, RightCol },
            Active   = isFirst,
        }

        function Tab:_activate(v)
            self.Active = v
            self._page.Visible = v
            tw(self._label, { TextColor3 = v and T.Accent or T.Text })
            tw(self._line,  { Size = UDim2.new(v and 1 or 0, 0, 0, 2) })
        end

        BClick.MouseButton1Click:Connect(function()
            for _, t in Tabs do t:_activate(false) end
            Tab:_activate(true)
        end)

        table.insert(Tabs, Tab)

        -- ════════════════════════════════════════════════════════════════════
        -- SECTION
        -- ════════════════════════════════════════════════════════════════════
        function Tab:Section(sp)
            sp = sp or {}
            local sname = sp.name or sp.Name or "Section"
            local side  = sp.side or sp.Side or 1
            local col   = self._cols[side] or self._cols[1]

            -- outer container (clips inner content)
            local SF = inst("Frame", {
                BackgroundColor3 = T.Inline,
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                BorderSizePixel  = 0,
                ClipsDescendants = true,
                Parent           = col,
            })
            corner(5, SF)

            -- purple glow strip (top border illusion)
            local glowStrip = inst("Frame", {
                Size             = UDim2.new(1, 0, 0, 4),
                BackgroundColor3 = T.Accent,
                BorderSizePixel  = 0,
                ZIndex           = 2,
                Parent           = SF,
            })
            corner(5, glowStrip)
            -- cover the lower half of the strip's rounded corners
            inst("Frame", {
                Position         = UDim2.new(0, 0, 0, 2),
                Size             = UDim2.new(1, 0, 0, 4),
                BackgroundColor3 = T.Inline,
                BorderSizePixel  = 0,
                ZIndex           = 3,
                Parent           = SF,
            })

            -- shadow glow effect behind strip
            inst("ImageLabel", {
                AnchorPoint      = Vector2.new(.5, .5),
                Position         = UDim2.new(.5, 0, 0, 4),
                Size             = UDim2.new(1, 2, 0, 12),
                BackgroundTransparency = 1,
                Image            = "rbxassetid://1316045217",
                ImageColor3      = T.Accent,
                ImageTransparency = .88,
                ScaleType        = Enum.ScaleType.Slice,
                SliceCenter      = Rect.new(10, 10, 118, 118),
                ZIndex           = 1,
                Parent           = SF,
            })

            -- section title
            inst("TextLabel", {
                Text             = sname,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                TextColor3       = T.Text,
                BackgroundTransparency = 1,
                Position         = UDim2.new(0, 10, 0, 7),
                Size             = UDim2.new(1, -20, 0, 17),
                TextXAlignment   = Enum.TextXAlignment.Left,
                ZIndex           = 4,
                Parent           = SF,
            })

            -- element content container
            local SC = inst("Frame", {
                BackgroundTransparency = 1,
                Position         = UDim2.new(0, 0, 0, 28),
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                BorderSizePixel  = 0,
                Parent           = SF,
            })
            inst("UIListLayout", {
                Padding   = UDim.new(0, 6),
                SortOrder = Enum.SortOrder.LayoutOrder,
            }, SC)
            inst("UIPadding", {
                PaddingLeft   = UDim.new(0, 10),
                PaddingRight  = UDim.new(0, 10),
                PaddingBottom = UDim.new(0, 10),
                PaddingTop    = UDim.new(0, 4),
            }, SC)

            -- section object
            local Section = { _frame = SF, _content = SC }

            -- ── helpers shared by elements ──────────────────────────────────
            local function row(h)
                return inst("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, h),
                    Parent = SC,
                })
            end

            local function accentBorder(parent, h)
                local outer = inst("Frame", {
                    BackgroundColor3 = T.Accent,
                    Size             = UDim2.new(1, 0, 0, h),
                    BorderSizePixel  = 0,
                    Parent           = parent,
                })
                corner(5, outer)
                local inner = inst("Frame", {
                    BackgroundColor3 = T.Element,
                    Size             = UDim2.new(1, -2, 1, 0),
                    Position         = UDim2.new(0, 1, 0, 0),
                    BorderSizePixel  = 0,
                    Parent           = outer,
                })
                corner(5, inner)
                return outer, inner
            end

            -- ── TOGGLE ──────────────────────────────────────────────────────
            function Section:Toggle(ep)
                ep = ep or {}
                local ename = ep.name    or ep.Name    or "Toggle"
                local flag  = ep.flag    or ep.Flag    or ename
                local def   = ep.default ~= nil and ep.default or (ep.Default ~= nil and ep.Default or false)
                local cb    = ep.callback or ep.Callback or function() end
                local val   = false

                local R = row(22)

                local Ind = inst("Frame", {
                    Size             = UDim2.new(0, 18, 0, 18),
                    AnchorPoint      = Vector2.new(0, .5),
                    Position         = UDim2.new(0, 0, .5, 0),
                    BackgroundColor3 = T.Element,
                    BorderSizePixel  = 0,
                    Parent           = R,
                })
                corner(4, Ind)

                local Chk = inst("Frame", {
                    Size             = UDim2.new(0, 0, 0, 0),
                    AnchorPoint      = Vector2.new(.5, .5),
                    Position         = UDim2.new(.5, 0, .5, 0),
                    BackgroundColor3 = T.Accent,
                    BorderSizePixel  = 0,
                    Parent           = Ind,
                })
                corner(3, Chk)

                local Lbl = inst("TextLabel", {
                    Text             = ename,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 13,
                    TextColor3       = T.Text,
                    BackgroundTransparency = 1,
                    Position         = UDim2.new(0, 24, 0, 0),
                    Size             = UDim2.new(1, -24, 1, 0),
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    Parent           = R,
                })

                local Btn = inst("TextButton", {
                    Text  = "", BackgroundTransparency = 1,
                    Size  = UDim2.new(1, 0, 1, 0), AutoButtonColor = false, Parent = R,
                })

                Ind.MouseEnter:Connect(function()
                    if not val then tw(Ind, { BackgroundColor3 = T.ElementHov }) end
                end)
                Ind.MouseLeave:Connect(function()
                    if not val then tw(Ind, { BackgroundColor3 = T.Element }) end
                end)

                local Toggle = {}
                function Toggle:Set(v)
                    val = v
                    Library.Flags[flag] = v
                    if v then
                        tw(Chk,  { Size = UDim2.new(0, 12, 0, 12) })
                        tw(Ind,  { BackgroundColor3 = Color3.fromRGB(34, 37, 55) })
                        tw(Lbl,  { TextColor3 = T.Accent })
                    else
                        tw(Chk,  { Size = UDim2.new(0, 0, 0, 0) })
                        tw(Ind,  { BackgroundColor3 = T.Element })
                        tw(Lbl,  { TextColor3 = T.Text })
                    end
                    pcall(cb, v)
                end
                function Toggle:Get()        return val end
                function Toggle:SetText(t)   Lbl.Text = t end
                function Toggle:SetVisible(v) R.Visible = v end

                Btn.MouseButton1Click:Connect(function() Toggle:Set(not val) end)
                Library.SetFlags[flag] = function(v) Toggle:Set(v) end
                Toggle:Set(def)
                return Toggle
            end

            -- ── BUTTON ──────────────────────────────────────────────────────
            function Section:Button(ep)
                ep = ep or {}
                local ename = ep.name or ep.Name or "Button"
                local ticon = ep.icon or ep.Icon or ""
                local cb    = ep.callback or ep.Callback or function() end
                local pressed = false

                local R = row(26)
                local _, Inner = accentBorder(R, 26)

                inst("UIListLayout", {
                    FillDirection     = Enum.FillDirection.Horizontal,
                    HorizontalAlignment = Enum.HorizontalAlignment.Center,
                    VerticalAlignment   = Enum.VerticalAlignment.Center,
                    Padding           = UDim.new(0, 5),
                }, Inner)

                if ticon ~= "" then
                    local ic = mkIcon(ticon, UDim2.fromOffset(13, 13), T.Text)
                    if ic then ic.ZIndex = 2; ic.Parent = Inner end
                end

                local Lbl = inst("TextLabel", {
                    Text             = ename,
                    Font             = Enum.Font.GothamSemibold,
                    TextSize         = 13,
                    TextColor3       = T.Text,
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(0, 0, 1, 0),
                    AutomaticSize    = Enum.AutomaticSize.X,
                    ZIndex           = 2,
                    Parent           = Inner,
                })

                Inner.MouseEnter:Connect(function() tw(Inner, { BackgroundColor3 = T.ElementHov }) end)
                Inner.MouseLeave:Connect(function() tw(Inner, { BackgroundColor3 = T.Element    }) end)

                local BtnClick = inst("TextButton", {
                    Text = "", BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0), AutoButtonColor = false, ZIndex = 3, Parent = Inner,
                })
                BtnClick.MouseButton1Click:Connect(function()
                    if pressed then return end; pressed = true
                    tw(Inner, { Size = UDim2.new(.4, -1, 1, 0) }, .1)
                    task.delay(.15, function()
                        tw(Inner, { Size = UDim2.new(1, -2, 1, 0) }, .15)
                        pressed = false
                    end)
                    pcall(cb)
                end)

                local Btn = {}
                function Btn:SetText(t) Lbl.Text = t end
                function Btn:SetVisible(v) R.Visible = v end
                return Btn
            end

            -- ── SLIDER ──────────────────────────────────────────────────────
            function Section:Slider(ep)
                ep = ep or {}
                local ename   = ep.name     or ep.Name     or "Slider"
                local flag    = ep.flag     or ep.Flag     or ename
                local minV    = ep.min      or ep.Min      or 0
                local maxV    = ep.max      or ep.Max      or 100
                local def     = ep.default  or ep.Default  or minV
                local suffix  = ep.suffix   or ep.Suffix   or ""
                local dec     = ep.decimals or ep.Decimals or 0
                local cb      = ep.callback or ep.Callback or function() end
                local val     = def
                local sliding = false

                local SF = inst("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 42),
                    Parent = SC,
                })

                local TopRow = inst("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 18), Parent = SF })
                inst("TextLabel", {
                    Text = ename, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = T.Text,
                    BackgroundTransparency = 1, Size = UDim2.new(.7, 0, 1, 0), TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = TopRow,
                })
                local ValLbl = inst("TextLabel", {
                    Text = tostring(def)..suffix,
                    Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = T.Accent,
                    BackgroundTransparency = 1,
                    AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, 0, 0, 0),
                    Size = UDim2.new(.3, 0, 1, 0), TextXAlignment = Enum.TextXAlignment.Right,
                    Parent = TopRow,
                })

                local Track = inst("TextButton", {
                    Text = "", BackgroundColor3 = T.Element,
                    Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 0, 22),
                    AutoButtonColor = false, BorderSizePixel = 0, ClipsDescendants = true,
                    Parent = SF,
                })
                corner(8, Track)

                local Fill = inst("Frame", {
                    BackgroundColor3 = T.Accent,
                    Size = UDim2.new(math.max((def-minV)/math.max(maxV-minV,.001),0), 0, 1, 0),
                    BorderSizePixel = 0, Parent = Track,
                })
                corner(8, Fill)
                gradient(ColorSequence.new({
                    ColorSequenceKeypoint.new(0, T.Accent),
                    ColorSequenceKeypoint.new(1, T.AccentDark),
                }), Fill)

                local function rnd(n)
                    local m = 10^dec
                    return math.floor(n*m+.5)/m
                end

                local Slider = {}
                function Slider:Set(v)
                    v = rnd(math.clamp(v, minV, maxV))
                    val = v
                    Library.Flags[flag] = v
                    local pct = (v-minV)/math.max(maxV-minV,.001)
                    tw(Fill, { Size = UDim2.new(pct, 0, 1, 0) })
                    ValLbl.Text = tostring(v)..suffix
                    pcall(cb, v)
                end
                function Slider:Get() return val end
                function Slider:SetVisible(vis) SF.Visible = vis end

                local function fromInput(input)
                    local pct = math.clamp(
                        (input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    Slider:Set(minV + (maxV-minV)*pct)
                end

                Track.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = true; fromInput(i)
                    end
                end)
                local c1 = UIS.InputChanged:Connect(function(i)
                    if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then fromInput(i) end
                end)
                local c2 = UIS.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
                end)
                table.insert(Library._conns, c1)
                table.insert(Library._conns, c2)

                Library.SetFlags[flag] = function(v) Slider:Set(v) end
                Slider:Set(def)
                return Slider
            end

            -- ── DROPDOWN ────────────────────────────────────────────────────
            function Section:Dropdown(ep)
                ep = ep or {}
                local ename  = ep.name    or ep.Name    or "Dropdown"
                local flag   = ep.flag    or ep.Flag    or ename
                local items  = ep.items   or ep.Items   or {}
                local def    = ep.default or ep.Default or ""
                local multi  = ep.multi   or ep.Multi   or false
                local cb     = ep.callback or ep.Callback or function() end
                local val    = multi and {} or nil
                local isOpen = false
                local opts   = {}

                -- label + button (44px total: 18 label + 26 button)
                local DF = inst("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 44), Parent = SC })
                inst("TextLabel", {
                    Text = ename, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = T.Text,
                    BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 18), TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = DF,
                })

                local _, DropInner = accentBorder(
                    inst("Frame", { BackgroundTransparency = 1, Position = UDim2.new(0,0,0,20), Size = UDim2.new(1,0,0,24), Parent = DF }),
                    24)

                local ValLbl = inst("TextLabel", {
                    Text = (def ~= "" and def or (multi and "Select…" or "Select…")),
                    Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = T.Text,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -28, 1, 0),
                    TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd,
                    Parent = DropInner,
                })
                local Arrow = inst("TextLabel", {
                    Text = "▾", Font = Enum.Font.GothamBold, TextSize = 11, TextColor3 = T.Text,
                    BackgroundTransparency = 1,
                    AnchorPoint = Vector2.new(1,.5), Position = UDim2.new(1,-7,.5,0),
                    Size = UDim2.new(0,14,0,14), Parent = DropInner,
                })

                -- floating option panel (parented to Gui so it escapes clipping)
                local OptPanel = inst("Frame", {
                    BackgroundColor3 = Color3.fromRGB(24, 26, 27),
                    Visible = false, ZIndex = 60, BorderSizePixel = 0, Parent = Gui,
                })
                corner(5, OptPanel)
                stroke(T.Accent, .6, 1, OptPanel)

                local OptScroll = inst("ScrollingFrame", {
                    BackgroundTransparency = 1, BorderSizePixel = 0,
                    Size = UDim2.new(1, 0, 1, 0),
                    ScrollBarThickness = 2, ScrollBarImageColor3 = T.Accent,
                    AutomaticCanvasSize = Enum.AutomaticSize.Y,
                    CanvasSize = UDim2.new(0,0,0,0),
                    Parent = OptPanel,
                })
                inst("UIListLayout", { Padding = UDim.new(0, 3), SortOrder = Enum.SortOrder.LayoutOrder }, OptScroll)
                inst("UIPadding", {
                    PaddingTop = UDim.new(0,4), PaddingBottom = UDim.new(0,4),
                    PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                }, OptScroll)

                local Dropdown = { Value = val }

                local function updateDisplay()
                    if multi then
                        ValLbl.Text = (#val > 0) and table.concat(val, ", ") or "Select…"
                    else
                        ValLbl.Text = val or "Select…"
                    end
                end

                local function close()
                    isOpen = false; OptPanel.Visible = false
                    tw(Arrow, { Rotation = 0 })
                end
                local function open()
                    isOpen = true
                    local ap = DropInner.AbsolutePosition
                    local as = DropInner.AbsoluteSize
                    local h  = math.min(#opts * 28 + 8, 160)
                    OptPanel.Position = UDim2.new(0, ap.X, 0, ap.Y + as.Y + 4)
                    OptPanel.Size     = UDim2.new(0, as.X, 0, h)
                    OptPanel.Visible  = true
                    tw(Arrow, { Rotation = 180 })
                end

                function Dropdown:Set(v)
                    if multi then
                        if type(v) == "table" then val = v
                        else
                            local idx = table.find(val, v)
                            if idx then table.remove(val, idx) else table.insert(val, v) end
                        end
                        for _, o in opts do
                            local sel = table.find(val, o._name) ~= nil
                            tw(o._frame, { BackgroundColor3 = sel and T.ElementHov or Color3.fromRGB(22, 24, 25) })
                            tw(o._lbl,   { TextColor3 = sel and T.Accent or T.Text })
                        end
                    else
                        val = v; close()
                        for _, o in opts do
                            local sel = o._name == v
                            tw(o._frame, { BackgroundColor3 = sel and T.ElementHov or Color3.fromRGB(22, 24, 25) })
                            tw(o._lbl,   { TextColor3 = sel and T.Accent or T.Text })
                        end
                    end
                    Library.Flags[flag] = val
                    updateDisplay()
                    pcall(cb, val)
                end

                function Dropdown:AddItem(item)
                    local oF = inst("Frame", {
                        BackgroundColor3 = Color3.fromRGB(22, 24, 25),
                        Size = UDim2.new(1, 0, 0, 24), BorderSizePixel = 0, ZIndex = 61, Parent = OptScroll,
                    })
                    corner(4, oF)
                    local oLbl = inst("TextLabel", {
                        Text = item, Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = T.Text,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -16, 1, 0),
                        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 62, Parent = oF,
                    })
                    local oBtn = inst("TextButton", {
                        Text = "", BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 1, 0), ZIndex = 63, Parent = oF,
                    })
                    oBtn.MouseEnter:Connect(function() tw(oF, { BackgroundColor3 = T.Element }) end)
                    oBtn.MouseLeave:Connect(function()
                        local sel = (not multi) and val == item or (multi and table.find(val, item) ~= nil)
                        tw(oF, { BackgroundColor3 = sel and T.ElementHov or Color3.fromRGB(22, 24, 25) })
                    end)
                    oBtn.MouseButton1Click:Connect(function() Dropdown:Set(item) end)
                    table.insert(opts, { _frame = oF, _lbl = oLbl, _name = item })
                end

                function Dropdown:Refresh(newItems)
                    items = newItems
                    for _, o in opts do o._frame:Destroy() end
                    opts = {}
                    val  = multi and {} or nil
                    updateDisplay()
                    for _, i in newItems do Dropdown:AddItem(i) end
                end

                function Dropdown:SetVisible(v) DF.Visible = v end

                for _, item in items do Dropdown:AddItem(item) end

                local DClick = inst("TextButton", {
                    Text = "", BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0), AutoButtonColor = false, ZIndex = 3, Parent = DropInner,
                })
                DClick.MouseButton1Click:Connect(function()
                    if isOpen then close() else open() end
                end)
                DropInner.MouseEnter:Connect(function() tw(DropInner, { BackgroundColor3 = T.ElementHov }) end)
                DropInner.MouseLeave:Connect(function() tw(DropInner, { BackgroundColor3 = T.Element    }) end)

                local c = UIS.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 and isOpen then
                        local p = input.Position
                        local ap, as = OptPanel.AbsolutePosition, OptPanel.AbsoluteSize
                        if not (p.X >= ap.X and p.X <= ap.X+as.X and p.Y >= ap.Y and p.Y <= ap.Y+as.Y) then
                            close()
                        end
                    end
                end)
                table.insert(Library._conns, c)

                Library.SetFlags[flag] = function(v) Dropdown:Set(v) end
                if def ~= "" then Dropdown:Set(def) end
                return Dropdown
            end

            -- ── TEXTBOX ─────────────────────────────────────────────────────
            function Section:Textbox(ep)
                ep = ep or {}
                local ename = ep.name        or ep.Name        or "Textbox"
                local flag  = ep.flag        or ep.Flag        or ename
                local ph    = ep.placeholder or ep.Placeholder or ""
                local def   = ep.default     or ep.Default     or ""
                local fin   = ep.finished    or ep.Finished    or false
                local cb    = ep.callback    or ep.Callback    or function() end

                local TF = inst("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 44), Parent = SC })
                inst("TextLabel", {
                    Text = ename, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = T.Text,
                    BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 18), TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = TF,
                })

                local _, InputInner = accentBorder(
                    inst("Frame", { BackgroundTransparency = 1, Position = UDim2.new(0,0,0,20), Size = UDim2.new(1,0,0,22), Parent = TF }),
                    22)

                local Outer = InputInner.Parent -- the gradient-bordered frame
                local Input = inst("TextBox", {
                    Text = def, PlaceholderText = ph,
                    Font = Enum.Font.Gotham, TextSize = 12,
                    TextColor3 = T.Text, PlaceholderColor3 = T.TextDim,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -16, 1, 0),
                    TextXAlignment = Enum.TextXAlignment.Left, ClearTextOnFocus = false,
                    Parent = InputInner,
                })

                Input.Focused:Connect(function()
                    tw(InputInner.Parent, { BackgroundColor3 = Color3.fromRGB(160, 170, 255) })
                end)
                Input.FocusLost:Connect(function(enter)
                    tw(InputInner.Parent, { BackgroundColor3 = T.Accent })
                    if fin then
                        Library.Flags[flag] = Input.Text
                        pcall(cb, Input.Text)
                    end
                end)
                if not fin then
                    Input:GetPropertyChangedSignal("Text"):Connect(function()
                        Library.Flags[flag] = Input.Text
                        pcall(cb, Input.Text)
                    end)
                end

                local Tbox = {}
                function Tbox:Set(v)    Input.Text = tostring(v) end
                function Tbox:Get()     return Input.Text end
                function Tbox:SetVisible(v) TF.Visible = v end
                Library.SetFlags[flag] = function(v) Input.Text = tostring(v) end
                return Tbox
            end

            -- ── LABEL ───────────────────────────────────────────────────────
            function Section:Label(ep)
                ep = ep or {}
                local text = ep.name or ep.Name or ep.text or ep.Text or ""
                local Lbl = inst("TextLabel", {
                    Text = text, Font = Enum.Font.Gotham, TextSize = 12,
                    TextColor3 = T.TextDim, BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 16), TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = SC,
                })
                local Obj = {}
                function Obj:Set(t) Lbl.Text = t end
                function Obj:SetColor(c) Lbl.TextColor3 = c end
                return Obj
            end

            return Section
        end -- :Section

        return Tab
    end -- :Tab

    if getgenv then getgenv().__UILib = Library end
    return Window
end -- :Window

return Library
