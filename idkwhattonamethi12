                Slider.Label.TextSize = 12
                Slider.Label.Font = Enum.Font.Gotham
                Slider.Label.TextXAlignment = Enum.TextXAlignment.Left
                Slider.Label.ZIndex = 5
                Slider.Label.Parent = HeaderFrame

                Slider.ValueLabel = InstanceNew("TextLabel")
                Slider.ValueLabel.Size = UDim2.new(0, 45, 1, 0)
                Slider.ValueLabel.Position = UDim2.new(1, -47, 0, 0)
                Slider.ValueLabel.BackgroundTransparency = 1
                Slider.ValueLabel.Text = format("%." .. Decimals .. "f", Default) .. Suffix
                Slider.ValueLabel.TextColor3 = Theme.Accent
                Slider.ValueLabel.TextSize = 11
                Slider.ValueLabel.Font = Enum.Font.GothamBold
                Slider.ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
                Slider.ValueLabel.ZIndex = 5
                Slider.ValueLabel.Parent = HeaderFrame

                Slider.Track = InstanceNew("Frame")
                Slider.Track.Size = UDim2.new(1, 0, 0, 8)
                Slider.Track.Position = UDim2.new(0, 0, 0, 26)
                Slider.Track.BackgroundColor3 = Theme.SliderTrack
                Slider.Track.BorderSizePixel = 0
                Slider.Track.ZIndex = 4
                Slider.Track.Parent = Slider.Container

                AddCorner(Slider.Track, UDim.new(0, 4))

                Slider.Fill = InstanceNew("Frame")
                Slider.Fill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
                Slider.Fill.BackgroundColor3 = Theme.SliderFill
                Slider.Fill.BorderSizePixel = 0
                Slider.Fill.ZIndex = 5
                Slider.Fill.Parent = Slider.Track

                AddCorner(Slider.Fill, UDim.new(0, 4))

                Slider.Handle = InstanceNew("Frame")
                Slider.Handle.Size = UDim2.new(0, 14, 0, 14)
                Slider.Handle.Position = UDim2.new((Default - Min) / (Max - Min), -7, 0.5, 0)
                Slider.Handle.AnchorPoint = Vector2.new(0.5, 0.5)
                Slider.Handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Slider.Handle.BorderSizePixel = 0
                Slider.Handle.ZIndex = 6
                Slider.Handle.Parent = Slider.Track

                AddCorner(Slider.Handle, UDim.new(0, 4))
                AddStroke(Slider.Handle, Theme.Border, 1)

                function Slider:Set(Value)
                    Value = clamp(Value, Min, Max)
                    self.Value = Value
                    local Percent = (Value - Min) / (Max - Min)
                    self.Fill.Size = UDim2.new(Percent, 0, 1, 0)
                    self.Handle.Position = UDim2.new(Percent, 0, 0.5, 0)
                    self.ValueLabel.Text = format("%." .. Decimals .. "f", Value) .. Suffix
                    Library.Flags[self.Flag] = Value
                    self.Callback(Value)
                end

                local function UpdateSlider(Input)
                    local RelativePos = (Input.Position.X - Slider.Track.AbsolutePosition.X) / Slider.Track.AbsoluteSize.X
                    RelativePos = clamp(RelativePos, 0, 1)
                    local NewValue = Min + (Max - Min) * RelativePos
                    Slider:Set(NewValue)
                end

                Slider.Track.InputBegan:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                        Slider.Dragging = true
                        UpdateSlider(Input)
                    end
                end)

                Slider.Track.InputEnded:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                        Slider.Dragging = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(Input)
                    if Slider.Dragging and Input.UserInputType == Enum.UserInputType.MouseMovement then
                        UpdateSlider(Input)
                    end
                end)

                Library.Flags[Flag] = Default
                insert(Section.Elements, Slider)

                return Slider
            end

