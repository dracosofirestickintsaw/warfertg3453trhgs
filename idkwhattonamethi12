            -- SLIDER METHOD
            function Section:Slider(Data)
                local SliderName = Data.Name or "Slider"
                local Min = Data.Min or 0
                local Max = Data.Max or 100
                local Default = Data.Default or (Min + Max) / 2
                local Suffix = Data.Suffix or ""
                local Decimals = Data.Decimals or 0
                local Flag = Data.Flag or "slider_" .. tick()
                local Callback = Data.Callback or function() end
                local Theme = Library.CurrentTheme

                local Slider = {}
                Slider.Name = SliderName
                Slider.Flag = Flag
                Slider.Min = Min
                Slider.Max = Max
                Slider.Value = Default
                Slider.Suffix = Suffix
                Slider.Decimals = Decimals
                Slider.Callback = Callback
                Slider.Dragging = false

                Slider.Container = InstanceNew("Frame")
                Slider.Container.Size = UDim2.new(1, 0, 0, 50)
                Slider.Container.BackgroundTransparency = 1
                Slider.Container.ZIndex = 3
                Slider.Container.Parent = Section.Content

                local HeaderFrame = InstanceNew("Frame")
                HeaderFrame.Size = UDim2.new(1, 0, 0, 18)
                HeaderFrame.BackgroundTransparency = 1
                HeaderFrame.ZIndex = 4
                HeaderFrame.Parent = Slider.Container

                Slider.Label = InstanceNew("TextLabel")
                Slider.Label.Size = UDim2.new(1, -50, 1, 0)
