                Button.Instance.TextSize = 13
                Button.Instance.Font = Enum.Font.GothamBold
                Button.Instance.AutoButtonColor = false
                Button.Instance.ZIndex = 4
                Button.Instance.Parent = Button.Container

                AddCorner(Button.Instance, UDim.new(0, 6))

                Button.Instance.MouseButton1Click:Connect(function()
                    Callback()
                end)

                Button.Instance.MouseEnter:Connect(function()
                    CreateTween(Button.Instance, {BackgroundColor3 = Theme.AccentHover}, 0.1)
                end)

                Button.Instance.MouseLeave:Connect(function()
                    CreateTween(Button.Instance, {BackgroundColor3 = Theme.Accent}, 0.1)
                end)

                Button.Instance.MouseButton1Down:Connect(function()
                    CreateTween(Button.Instance, {BackgroundColor3 = Theme.AccentDark}, 0.05)
                end)

                Button.Instance.MouseButton1Up:Connect(function()
                    CreateTween(Button.Instance, {BackgroundColor3 = Theme.Accent}, 0.05)
                end)

                insert(Section.Elements, Button)

                return Button
            end

            return Section
        end

        if #Window.Pages == 0 then
            SelectPage()
        end

        insert(Window.Pages, Page)
        insert(Library.Pages, Page)

        return Page
    end

    return Window
end

-- NOTIFICATION
function Library:Notify(Data)
    local Text = Data.Text or "Notification"
    local Duration = Data.Duration or 3
    local Theme = self.CurrentTheme

    if not self.NotifHolder then
        self.NotifHolder = InstanceNew("Frame")
        self.NotifHolder.Size = UDim2.new(0, 300, 1, 0)
        self.NotifHolder.Position = UDim2.new(1, -310, 0, 20)
        self.NotifHolder.BackgroundTransparency = 1
        self.NotifHolder.ZIndex = 100
        self.NotifHolder.Parent = CoreGui

        local Layout = InstanceNew("UIListLayout")
        Layout.SortOrder = Enum.SortOrder.LayoutOrder
        Layout.Padding = UDim.new(0, 10)
        Layout.HorizontalAlignment = Enum.HorizontalAlignment.Right
        Layout.VerticalAlignment = Enum.VerticalAlignment.Top
        Layout.Parent = self.NotifHolder
    end

    local Notification = InstanceNew("Frame")
    Notification.Size = UDim2.new(1, 0, 0, 50)
    Notification.BackgroundColor3 = Theme.Background
    Notification.BorderSizePixel = 0
    Notification.BackgroundTransparency = 1
    Notification.TextTransparency = 1
    Notification.ZIndex = 101
    Notification.Parent = self.NotifHolder

    AddCorner(Notification, UDim.new(0, 8))
    AddStroke(Notification, Theme.Border, 1)

    local NotifText = InstanceNew("TextLabel")
    NotifText.Size = UDim2.new(1, -20, 1, 0)
    NotifText.Position = UDim2.new(0, 10, 0, 0)
    NotifText.BackgroundTransparency = 1
    NotifText.Text = Text
    NotifText.TextColor3 = Theme.Text
    NotifText.TextSize = 13
    NotifText.Font = Enum.Font.Gotham
    NotifText.TextWrapped = true
    NotifText.ZIndex = 102
    NotifText.Parent = Notification

    Notification.Position = UDim2.new(1, 20, 0, 0)
    CreateTween(Notification, {
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 0,
        TextTransparency = 0
    }, 0.3, Enum.EasingStyle.Back)

    task.delay(Duration, function()
        CreateTween(Notification, {
            Position = UDim2.new(1, 20, 0, 0),
            BackgroundTransparency = 1,
            TextTransparency = 1
        }, 0.2)
        task.wait(0.2)
        Notification:Destroy()
    end)

    return Notification
end

-- CLEANUP
function Library:Unload()
    for _, Window in ipairs(self.Windows) do
        if Window.Instance and Window.Instance.Parent then
            Window.Instance:Destroy()
        end
    end
    if self.NotifHolder and self.NotifHolder.Parent then
        self.NotifHolder:Destroy()
    end
    self.Windows = {}
    self.Pages = {}
    self.Sections = {}
    self.Flags = {}
end

-- EXPORT
getgenv().MyUILibrary = Library

return Library
