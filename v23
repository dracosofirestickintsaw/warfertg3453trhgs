local function Tween(obj, props, duration, style, direction)
    TweenService:Create(
        obj,
        TweenInfo.new(
            duration  or 0.18,
            style     or Enum.EasingStyle.Quad,
            direction or Enum.EasingDirection.Out
        ),
        props
    ):Play()
end

local function New(class, props)
    local inst   = Instance.new(class)
    local parent = props.Parent
    props.Parent = nil
    for k, v in pairs(props) do inst[k] = v end
    if parent then inst.Parent = parent end
    return inst
end

local function SafeCall(fn, ...)
    local ok, err = pcall(fn, ...)
    if not ok then warn("[Da7muLibrary] callback error: " .. tostring(err)) end
end

local function Round(n, decimals)
    local mult = 10 ^ (decimals or 0)
    return math.floor(n * mult + 0.5) / mult
end

local function NewConnStore()
    local store = { _list = {} }
    function store:Add(c)
        table.insert(self._list, c)
        return c
    end
    function store:DisconnectAll()
        for _, c in ipairs(self._list) do
            if typeof(c) == "RBXScriptConnection" then c:Disconnect() end
        end
        self._list = {}
    end
    return store
end

-- ─────────────────────────────────────────────────────────────────────────────
--  Blur  (v4 – IgnoreGuiInset-aware, intensity 0.5)
-- ─────────────────────────────────────────────────────────────────────────────
local function CreateBlur(frame, intensity)
    intensity = intensity or 0.5   -- increased from v3's 0.25
    local BLUR_SIZE         = Vector2.new(10, 10)
    local PART_SIZE         = 0.01
    local PART_TRANSPARENCY = 1 - 1e-7
    local bindName          = "Da7muBlur_" .. tostring(math.random(1, 9999999))

    local ok, result = pcall(function()
        local dof = New("DepthOfFieldEffect", {
            FarIntensity = 0, NearIntensity = intensity,
            FocusDistance = 0.25, InFocusRadius = 0, Parent = Lighting,
        })

        local blurPart = New("Part", {
            Size = Vector3.one * PART_SIZE, Anchored = true,
            CanCollide = false, CanTouch = false, CastShadow = false,
            Material = Enum.Material.Glass, Transparency = PART_TRANSPARENCY,
            Parent = Camera,
        })
        local mesh = New("BlockMesh", { Parent = blurPart })

        -- Detect IgnoreGuiInset at construction time (stable for our ScreenGui)
        local ignoreInset = false
        local cur = frame
        while true do
            cur = cur.Parent
            if cur and cur:IsA("ScreenGui") then
                ignoreInset = cur.IgnoreGuiInset
                break
            elseif cur == nil then
                break
            end
        end

        local function rpi(pO, pN, rO, rD)
            local d = pN:Dot(rD)
            if math.abs(d) < 1e-6 then return rO end
            return rO + (-pN:Dot(rO - pO) / d) * rD
        end

        local function updateBlur()
            if not frame or not frame.Visible then
                blurPart.Transparency = 1
                return
            end
            blurPart.Transparency = PART_TRANSPARENCY

            local corner0 = frame.AbsolutePosition + BLUR_SIZE
            local corner1 = corner0 + frame.AbsoluteSize - BLUR_SIZE * 2

            local ray0, ray1
            if ignoreInset then
                ray0 = Camera:ViewportPointToRay(corner0.X, corner0.Y, 1)
                ray1 = Camera:ViewportPointToRay(corner1.X, corner1.Y, 1)
            else
                ray0 = Camera:ScreenPointToRay(corner0.X, corner0.Y, 1)
                ray1 = Camera:ScreenPointToRay(corner1.X, corner1.Y, 1)
            end

            local nz = Camera.NearPlaneZ
            if nz ~= nz then return end  -- NaN guard

            local planeOrigin = Camera.CFrame.Position + Camera.CFrame.LookVector * (0.05 - nz)
            local planeNormal = Camera.CFrame.LookVector

            local pos0 = Camera.CFrame:PointToObjectSpace(rpi(planeOrigin, planeNormal, ray0.Origin, ray0.Direction))
            local pos1 = Camera.CFrame:PointToObjectSpace(rpi(planeOrigin, planeNormal, ray1.Origin, ray1.Direction))

            mesh.Offset = (pos0 + pos1) / 2
            mesh.Scale  = (pos1 - pos0) / PART_SIZE
            dof.FocusDistance = 0.25 - nz
        end

        RunService:BindToRenderStep(bindName, Enum.RenderPriority.Camera.Value + 1, function()
            pcall(function()
                blurPart.CFrame = Camera.CFrame
                updateBlur()
            end)
        end)

        return function()
            RunService:UnbindFromRenderStep(bindName)
            pcall(function() blurPart:Destroy() end)
            pcall(function() dof:Destroy() end)
        end
    end)

    if ok and type(result) == "function" then return result end
    if not ok then warn("[Da7muLibrary] Blur unavailable:", result) end
    return function() end
end

