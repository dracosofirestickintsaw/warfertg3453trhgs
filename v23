            BorderSizePixel = 0, TextSize = 15, FontFace = RFont,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1, TextColor3 = T.TextSecondary,
            Text = pageName,
            Position = UDim2.new(0,36,0,0), Size = UDim2.new(1,-36,1,0),
            Name = "Label", Parent = NavBtnFrame,
        })
        local NavBtn = New("TextButton", {
            BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0),
            Text = "", AutoButtonColor = false, ZIndex = 5, Parent = NavBtnFrame,
        })

        Page.NavBtnFrame = NavBtnFrame
        Page.NavIcon     = NavIcon
        Page.NavLabel    = NavLabel
        Page.NavBtn      = NavBtn

        local function Activate()
            for _, p in ipairs(Window.Pages) do
                if p ~= Page and p.Active then
                    p.Active = false; p.Frame.Visible = false
                    Tween(p.NavBtnFrame, { BackgroundTransparency = 1    })
                    Tween(p.NavLabel,    { TextColor3 = T.TextSecondary  })
                    Tween(p.NavIcon,     { ImageColor3 = T.TextSecondary })
                end
            end
            Page.Active = true
            PageFrame.Visible = true
            -- v4: slide-up page transition
            PageFrame.Position = UDim2.new(0, 0, 0, 18)
            Tween(PageFrame, { Position = UDim2.new(0,0,0,0) }, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            -- v4: active tab has transparent background (0.3)
            Tween(NavBtnFrame, { BackgroundTransparency = 0.3  })
            Tween(NavLabel,    { TextColor3  = T.TextPrimary   })
            Tween(NavIcon,     { ImageColor3 = T.Accent        })
        end

        Window._connStore:Add(NavBtn.MouseButton1Click:Connect(function()
            if not Page.Active then Activate() end
        end))
        Window._connStore:Add(NavBtn.MouseEnter:Connect(function()
            if not Page.Active then
                Tween(NavBtnFrame, { BackgroundTransparency = 0.6  })
                Tween(NavLabel,    { TextColor3 = T.TextPrimary    })
            end
        end))
        Window._connStore:Add(NavBtn.MouseLeave:Connect(function()
            if not Page.Active then
                Tween(NavBtnFrame, { BackgroundTransparency = 1    })
                Tween(NavLabel,    { TextColor3 = T.TextSecondary  })
            end
        end))

        if #Window.Pages == 0 then Activate() end
        table.insert(Window.Pages, Page)

        -- ── Section ───────────────────────────────────────────────────────────
        function Page:Section(config)
            config = config or {}
            local sectionName = config.Name or "Section"
            local side        = config.Side or 1
            local column      = (side == 2) and self.Side2 or self.Side1

            local Section = { Page = self, _hasElements = false }

            New("TextLabel", {
                BorderSizePixel = 0, TextSize = 11, FontFace = RFont,
                BackgroundTransparency = 1, TextColor3 = T.TextMuted,
                TextXAlignment = Enum.TextXAlignment.Left,
                Text = string.upper(sectionName),
                Size = UDim2.new(1,0,0,14), Parent = column,
            })

            local Card = New("Frame", {
                BorderSizePixel = 0, BackgroundColor3 = T.Section,
                BackgroundTransparency = 0.5,   -- v4: slightly more transparent
                Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y,
                Name = sectionName, Parent = column,
            })
            New("UICorner", { CornerRadius = UDim.new(0,10), Parent = Card })
            New("UIStroke", {
                Transparency = 0.41, Thickness = 1.3, Color = T.Stroke, Parent = Card,
            })
            New("UIPadding", {
                PaddingTop = UDim.new(0,8), PaddingBottom = UDim.new(0,10),
                PaddingLeft = UDim.new(0,10), PaddingRight = UDim.new(0,10),
                Parent = Card,
            })
            New("UIListLayout", {
                Padding = UDim.new(0,2), SortOrder = Enum.SortOrder.LayoutOrder,
                Parent = Card,
            })

            Section.Card = Card

            -- ── Auto-separator between elements ───────────────────────────────
            local function AddSep()
                if Section._hasElements then
                    New("Frame", {
                        BorderSizePixel = 0, BackgroundColor3 = T.Stroke,
                        BackgroundTransparency = 0.55,
                        Size = UDim2.new(1,-6,0,1), Parent = Card,
                    })
                end
                Section._hasElements = true
            end

            -- ── 3-Dots sub-panel builder ──────────────────────────────────────
            --  Creates a floating ScrollingFrame parented to ScreenGui.
            --  Populates it by calling subElemsFn(panel) with a mini-API.
            --  Returns { Open, Close, IsOpen } functions.
            local function MakeSubPanel(anchorRow, subElemsFn)
                if not subElemsFn then return nil end

                -- Floating panel
                local SubFrame = New("ScrollingFrame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Nav,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0, 210, 0, 180),  -- fixed visible size, scrollable
                    CanvasSize = UDim2.new(0,0,0,0),
                    AutomaticCanvasSize = Enum.AutomaticSize.Y,
                    ScrollBarImageTransparency = 1, ScrollBarThickness = 2,
                    Visible = false, ZIndex = 200, Name = "SubPanel",
                    Parent = ScreenGui,
                })
                New("UICorner", { CornerRadius = UDim.new(0,10), Parent = SubFrame })
                New("UIStroke", { Color = T.Stroke, Thickness = 1.2,
                    Transparency = 1, Parent = SubFrame })
                New("UIPadding", {
                    PaddingTop = UDim.new(0,6), PaddingBottom = UDim.new(0,6),
                    PaddingLeft = UDim.new(0,8), PaddingRight = UDim.new(0,8),
                    Parent = SubFrame,
                })
                New("UIListLayout", {
                    Padding = UDim.new(0,0), SortOrder = Enum.SortOrder.LayoutOrder,
                    Parent = SubFrame,
                })
                local subScale = New("UIScale", { Scale = 0.95, Parent = SubFrame })
                local subStroke = SubFrame:FindFirstChildOfClass("UIStroke")
                -- We already created it above, grab a ref:
                subStroke = SubFrame:FindFirstChildWhichIsA("UIStroke")

                -- Mini panel API (smaller elements: 26px rows, 13px font)
                local panel = { _hasElements = false }
                local SUB_H  = 26
                local SUB_FS = 13

                local function SubAddSep()
                    if panel._hasElements then
                        New("Frame", {
                            BorderSizePixel = 0, BackgroundColor3 = T.Stroke,
                            BackgroundTransparency = 0.55,
                            Size = UDim2.new(1,0,0,1), Parent = SubFrame,
                        })
                    end
                    panel._hasElements = true
                end

                -- Sub:Toggle
                function panel:Toggle(cfg)
                    cfg = cfg or {}
                    local name     = cfg.Name     or "Toggle"
                    local flag     = cfg.Flag     or name
                    local default  = cfg.Default  or false
                    local callback = cfg.Callback or function() end
                    local value    = default
                    SubAddSep()
                    local Row = New("Frame", {
                        BorderSizePixel = 0, BackgroundColor3 = T.Element,
                        BackgroundTransparency = 0.9,
                        Size = UDim2.new(1,0,0,SUB_H), Parent = SubFrame,
                    })
                    New("UICorner", { CornerRadius = UDim.new(0,4), Parent = Row })
                    New("UIPadding", {
                        PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                        PaddingTop = UDim.new(0,2), PaddingBottom = UDim.new(0,2),
                        Parent = Row,
                    })
                    local Title = New("TextLabel", {
                        BorderSizePixel = 0, TextSize = SUB_FS, FontFace = RFont,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        BackgroundTransparency = 1,
                        TextColor3 = default and T.TextPrimary or T.TextDim,
                        Text = name, Size = UDim2.new(1,-44,1,0), Parent = Row,
                    })
                    local Pill = New("Frame", {
                        BorderSizePixel = 0,
                        BackgroundColor3 = default and T.AccentDark or T.ToggleOff,
                        Size = UDim2.new(0,36,0,18), AnchorPoint = Vector2.new(1,0.5),
                        Position = UDim2.new(1,0,0.5,0), Parent = Row,
                    })
                    New("UICorner", { CornerRadius = UDim.new(0,20), Parent = Pill })
                    local Circle = New("Frame", {
                        BorderSizePixel = 0,
                        BackgroundColor3 = default and T.ToggleCircleOn or T.TextDim,
                        Size = UDim2.new(0,14,0,14),
                        Position = default and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7),
                        Parent = Pill,
                    })
                    New("UICorner", { CornerRadius = UDim.new(0,100), Parent = Circle })
                    local Clk = New("TextButton", {
                        BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0),
                        Text = "", AutoButtonColor = false, ZIndex = 5, Parent = Row,
                    })
                    Library.Flags[flag] = value
                    local Toggle = { Value = value, Flag = flag }
                    local function Apply(v, anim)
                        value = v; Toggle.Value = v; Library.Flags[flag] = v
                        local pc = v and T.AccentDark    or T.ToggleOff
                        local cc = v and T.ToggleCircleOn or T.TextDim
                        local cp = v and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
                        if anim then
                            Tween(Pill,   { BackgroundColor3 = pc })
                            Tween(Circle, { BackgroundColor3 = cc, Position = cp })
                            Tween(Title,  { TextColor3 = v and T.TextPrimary or T.TextDim })
                        else
                            Pill.BackgroundColor3 = pc; Circle.BackgroundColor3 = cc
                            Circle.Position = cp
                            Title.TextColor3 = v and T.TextPrimary or T.TextDim
                        end
                        SafeCall(callback, v)
                    end
                    Apply(value, false)
                    Window._connStore:Add(Clk.MouseButton1Click:Connect(function()
                        Apply(not value, true)
                    end))
                    function Toggle:Set(v) Apply(v, true) end
                    function Toggle:Get() return value    end
                    return Toggle
                end

                -- Sub:Slider
                function panel:Slider(cfg)
                    cfg = cfg or {}
                    local name     = cfg.Name     or "Slider"
                    local flag     = cfg.Flag     or name
                    local minV     = cfg.Min      or 0
                    local maxV     = cfg.Max      or 100
                    local default  = cfg.Default  or minV
                    local decimals = cfg.Decimals or 0
                    local suffix   = cfg.Suffix   or ""
                    local callback = cfg.Callback or function() end
                    local value    = default
                    SubAddSep()
                    local Container = New("Frame", {
                        BorderSizePixel = 0, BackgroundTransparency = 1,
                        Size = UDim2.new(1,0,0,38), Parent = SubFrame,
                    })
                    New("UIPadding", {
                        PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                        PaddingTop = UDim.new(0,2), PaddingBottom = UDim.new(0,2),
                        Parent = Container,
                    })
                    New("TextLabel", {
                        BorderSizePixel = 0, TextSize = SUB_FS, FontFace = RFont,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        BackgroundTransparency = 1, TextColor3 = T.TextPrimary,
                        Text = name, Size = UDim2.new(0.6,0,0,16),
                        Position = UDim2.new(0,0,0,1), Parent = Container,
                    })
                    local VBg = New("Frame", {
                        BorderSizePixel = 0, BackgroundColor3 = T.ElementDark,
                        Size = UDim2.new(0,40,0,18), AnchorPoint = Vector2.new(1,0),
                        Position = UDim2.new(1,0,0,0), Parent = Container,
                    })
                    New("UICorner", { Parent = VBg })
                    local VLbl = New("TextLabel", {
                        BorderSizePixel = 0, TextSize = 11, FontFace = RFont,
                        BackgroundTransparency = 1, TextColor3 = T.TextValue,
                        Text = tostring(value)..suffix,
                        Size = UDim2.new(1,0,1,0), Parent = VBg,
                    })
                    local Track = New("Frame", {
                        BorderSizePixel = 0, BackgroundColor3 = T.Track,
                        Size = UDim2.new(1,-46,0,5), AnchorPoint = Vector2.new(0,1),
                        Position = UDim2.new(0,0,1,-1), Parent = Container,
                    })
                    New("UICorner", { Parent = Track })
                    local Fill = New("Frame", {
                        BorderSizePixel = 0, BackgroundColor3 = T.Accent,
                        Size = UDim2.new(0,0,1,0), Parent = Track,
                    })
                    New("UICorner", { Parent = Fill })
                    local Knob = New("Frame", {
                        BorderSizePixel = 0, BackgroundColor3 = T.SliderCircle,
                        Size = UDim2.new(0,11,0,11), AnchorPoint = Vector2.new(0.5,0.5),
                        Position = UDim2.new(0,0,0.5,0), ZIndex = 3, Parent = Track,
                    })
                    New("UICorner", { CornerRadius = UDim.new(0,100), Parent = Knob })
                    Library.Flags[flag] = value
                    local Slider = { Value = value, Flag = flag }
                    local sliding = false
                    local function SetVal(v, anim)
                        v = Round(math.clamp(v, minV, maxV), decimals)
                        value = v; Slider.Value = v; Library.Flags[flag] = v
                        local t = (maxV ~= minV) and ((v-minV)/(maxV-minV)) or 0
                        if anim then
                            Tween(Fill, { Size = UDim2.new(t,0,1,0) })
                            Tween(Knob, { Position = UDim2.new(t,0,0.5,0) })
                        else
                            Fill.Size = UDim2.new(t,0,1,0)
                            Knob.Position = UDim2.new(t,0,0.5,0)
                        end
                        VLbl.Text = tostring(v)..suffix
                        SafeCall(callback, v)
                    end
                    local function PI(pos)
                        local w = Track.AbsoluteSize.X
                        if w == 0 then return end
                        SetVal(minV + (maxV-minV) * math.clamp(
                            (pos.X - Track.AbsolutePosition.X) / w, 0, 1), false)
                    end
                    Window._connStore:Add(Track.InputBegan:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1
                        or i.UserInputType == Enum.UserInputType.Touch then
                            sliding = true; PI(i.Position)
                        end
                    end))
                    Window._connStore:Add(UserInputService.InputChanged:Connect(function(i)
                        if not sliding then return end
                        if i.UserInputType == Enum.UserInputType.MouseMovement
                        or i.UserInputType == Enum.UserInputType.Touch then PI(i.Position) end
                    end))
                    Window._connStore:Add(UserInputService.InputEnded:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1
                        or i.UserInputType == Enum.UserInputType.Touch then sliding = false end
                    end))
                    SetVal(value, false)
                    function Slider:Set(v) SetVal(v, true) end
                    function Slider:Get() return value      end
                    return Slider
                end

                -- Sub:Button
                function panel:Button(cfg)
                    cfg = cfg or {}
                    local name     = cfg.Name     or "Button"
                    local callback = cfg.Callback or function() end
                    SubAddSep()
                    local Btn = New("TextButton", {
                        BorderSizePixel = 0, BackgroundColor3 = T.Accent,
                        BackgroundTransparency = 0.82,
                        Size = UDim2.new(1,0,0,24), AutoButtonColor = false,
                        Text = "", Name = name, Parent = SubFrame,
                    })
                    New("UICorner", { CornerRadius = UDim.new(0,5), Parent = Btn })
                    New("UIStroke", { Color = T.Accent, Transparency = 0.65, Thickness = 1, Parent = Btn })
                    New("TextLabel", {
                        BorderSizePixel = 0, TextSize = SUB_FS, FontFace = RFont,
                        BackgroundTransparency = 1, TextColor3 = T.TextPrimary,
                        Text = name, Size = UDim2.new(1,0,1,0), Parent = Btn,
                    })
                    Window._connStore:Add(Btn.MouseEnter:Connect(function()
                        Tween(Btn, { BackgroundTransparency = 0.55 })
                    end))
                    Window._connStore:Add(Btn.MouseLeave:Connect(function()
                        Tween(Btn, { BackgroundTransparency = 0.82 })
                    end))
                    Window._connStore:Add(Btn.MouseButton1Click:Connect(function()
                        Tween(Btn, { BackgroundTransparency = 0.25 })
                        task.delay(0.15, function() Tween(Btn, { BackgroundTransparency = 0.82 }) end)
                        SafeCall(callback)
                    end))
                    return { Name = name, Instance = Btn }
                end

                -- Populate sub-panel with user's elements
                SafeCall(subElemsFn, panel)

                -- Open / Close logic with fade+scale animation
                local isSubOpen  = false
                local isSubClose = false

                local function OpenSub()
                    if isSubOpen then return end
                    isSubOpen = true; isSubClose = false
                    local ap  = anchorRow.AbsolutePosition
                    local as  = anchorRow.AbsoluteSize
                    local vp  = Camera.ViewportSize
                    local pH  = 180
                    local pW  = math.max(as.X, 180)
                    local pY  = ap.Y + as.Y + 6
                    if pY + pH > vp.Y - 10 then pY = ap.Y - pH - 6 end
                    SubFrame.Position = UDim2.new(0, ap.X, 0, pY)
                    SubFrame.Size     = UDim2.new(0, pW, 0, pH)
                    SubFrame.BackgroundTransparency = 1
                    subStroke.Transparency = 1
                    subScale.Scale = 0.95
                    SubFrame.Visible = true
                    Tween(SubFrame,  { BackgroundTransparency = 0.05 }, 0.18)
                    Tween(subStroke, { Transparency = 0              }, 0.18)
                    Tween(subScale,  { Scale = 1.0                   }, 0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                end

                local function CloseSub()
                    if not isSubOpen then return end
                    isSubOpen = false; isSubClose = true
                    Tween(SubFrame,  { BackgroundTransparency = 1 }, 0.13)
                    Tween(subStroke, { Transparency = 1           }, 0.13)
                    Tween(subScale,  { Scale = 0.95               }, 0.13)
                    task.delay(0.15, function()
                        if isSubClose then SubFrame.Visible = false; isSubClose = false end
                    end)
                end

                -- Close when clicking outside the sub-panel
                Window._connStore:Add(UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                    if not isSubOpen then return end
                    local mp = input.Position
                    local ap = SubFrame.AbsolutePosition
                    local as = SubFrame.AbsoluteSize
                    if not (mp.X >= ap.X and mp.X <= ap.X+as.X and mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y) then
                        CloseSub()
                    end
                end))

                return { Open = OpenSub, Close = CloseSub, IsOpen = function() return isSubOpen end }
            end

            -- Helper to attach a 3-dots button to an existing row frame
            local function AttachDots(row, subElemsFn)
                if not subElemsFn then return end
                local dotsBtn = New("TextButton", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    Text = "...", TextSize = 20, FontFace = RFontBold,
                    TextColor3 = T.TextDim,
                    Size = UDim2.new(0,22,0,22), AnchorPoint = Vector2.new(1,0.5),
                    Position = UDim2.new(1,0,0.5,0),
                    AutoButtonColor = false, ZIndex = 6, Parent = row,
                })
                local sp = MakeSubPanel(row, subElemsFn)
                Window._connStore:Add(dotsBtn.MouseButton1Click:Connect(function()
                    if sp.IsOpen() then sp.Close() else sp.Open() end
                end))
                Window._connStore:Add(dotsBtn.MouseEnter:Connect(function()
                    Tween(dotsBtn, { TextColor3 = T.TextPrimary })
                end))
                Window._connStore:Add(dotsBtn.MouseLeave:Connect(function()
                    Tween(dotsBtn, { TextColor3 = T.TextDim })
                end))
            end

            -- ── Toggle ────────────────────────────────────────────────────────
            function Section:Toggle(config)
                config = config or {}
                local name       = config.Name        or "Toggle"
                local flag       = config.Flag        or name
                local default    = config.Default     or false
                local callback   = config.Callback    or function() end
                local subElemsFn = config.SubElements
                local value      = default

                AddSep()

                local Row = New("Frame", {
                    BorderSizePixel = 0,
                    BackgroundColor3 = T.Element, BackgroundTransparency = 0.9,
                    Size = UDim2.new(1,0,0,30), Name = name, Parent = Card,
                })
                New("UICorner", { CornerRadius = UDim.new(0,4), Parent = Row })
                New("UIPadding", {
                    PaddingTop = UDim.new(0,2), PaddingBottom = UDim.new(0,2),
                    PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                    Parent = Row,
                })

                -- Reserve room for dots button if needed
                local titleW = subElemsFn and UDim2.new(1,-80,1,0) or UDim2.new(1,-56,1,0)

                local Title = New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 15,
                    TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                    BackgroundTransparency = 1,
                    TextColor3 = default and T.TextPrimary or T.TextDim,
                    Text = name, Size = titleW, Parent = Row,
                })
                local Pill = New("Frame", {
                    BorderSizePixel = 0,
                    BackgroundColor3 = default and T.AccentDark or T.ToggleOff,
                    Size = UDim2.new(0,44,0,24), AnchorPoint = Vector2.new(1,0.5),
                    Position = subElemsFn and UDim2.new(1,-26,0.5,0) or UDim2.new(1,0,0.5,0),
                    Parent = Row,
                })
                New("UICorner", { CornerRadius = UDim.new(0,20), Parent = Pill })
                local Circle = New("Frame", {
                    BorderSizePixel = 0,
                    BackgroundColor3 = default and T.ToggleCircleOn or T.TextDim,
                    Size = UDim2.new(0,19,0,19),
                    Position = default and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,2,0.5,-9),
                    Parent = Pill,
                })
                New("UICorner", { CornerRadius = UDim.new(0,100), Parent = Circle })
                local ClickBtn = New("TextButton", {
                    BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0),
                    Text = "", AutoButtonColor = false, ZIndex = 5, Parent = Row,
                })

                AttachDots(Row, subElemsFn)

                Library.Flags[flag] = value
                local Toggle = { Value = value, Flag = flag }

                local function Apply(v, animated)
                    value = v; Toggle.Value = v; Library.Flags[flag] = v
                    local pc = v and T.AccentDark    or T.ToggleOff
                    local cc = v and T.ToggleCircleOn or T.TextDim
                    local cp = v and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,2,0.5,-9)
                    if animated then
                        Tween(Pill,   { BackgroundColor3 = pc })
                        Tween(Circle, { BackgroundColor3 = cc, Position = cp })
                        Tween(Title,  { TextColor3 = v and T.TextPrimary or T.TextDim })
                    else
                        Pill.BackgroundColor3   = pc
                        Circle.BackgroundColor3 = cc
                        Circle.Position         = cp
                        Title.TextColor3 = v and T.TextPrimary or T.TextDim
                    end
                    SafeCall(callback, v)
                end

                Apply(value, false)
                Window._connStore:Add(ClickBtn.MouseButton1Click:Connect(function()
                    Apply(not value, true)
                end))

                function Toggle:Set(v) Apply(v, true) end
                function Toggle:Get() return value    end
                return Toggle
            end

            -- ── Slider  (visuals unchanged per request) ───────────────────────
            function Section:Slider(config)
                config = config or {}
                local name       = config.Name     or "Slider"
                local flag       = config.Flag     or name
                local minV       = config.Min      or 0
                local maxV       = config.Max      or 100
                local default    = config.Default  or minV
                local decimals   = config.Decimals or 0
                local suffix     = config.Suffix   or ""
                local callback   = config.Callback or function() end
                local subElemsFn = config.SubElements
                local value      = default

                AddSep()

                -- Slider keeps BackgroundTransparency = 1 (no row tint)
                local Container = New("Frame", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,46), Name = name, Parent = Card,
                })
                New("UIPadding", {
                    PaddingTop = UDim.new(0,2), PaddingBottom = UDim.new(0,2),
                    PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                    Parent = Container,
                })
                New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 15,
                    TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextPrimary,
                    Text = name, Size = UDim2.new(0.6,0,0,20),
                    Position = UDim2.new(0,0,0,2), Parent = Container,
                })
                local ValueBg = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.ElementDark,
                    Size = UDim2.new(0,50,0,22), AnchorPoint = Vector2.new(1,0),
                    Position = UDim2.new(1,0,0,1), Parent = Container,
                })
                New("UICorner", { Parent = ValueBg })
                local ValueLabel = New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 13, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextValue,
                    Text = tostring(value)..suffix,
                    Size = UDim2.new(1,0,1,0), Parent = ValueBg,
                })
                local TrackBack = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Track,
                    Size = UDim2.new(1,-58,0,6), AnchorPoint = Vector2.new(0,1),
                    Position = UDim2.new(0,0,1,-2), Parent = Container,
                })
                New("UICorner", { Parent = TrackBack })
                local Fill = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Accent,
                    Size = UDim2.new(0,0,1,0), Parent = TrackBack,
                })
                New("UICorner", { Parent = Fill })
                local DragCircle = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.SliderCircle,
                    Size = UDim2.new(0,13,0,13), AnchorPoint = Vector2.new(0.5,0.5),
                    Position = UDim2.new(0,0,0.5,0), ZIndex = 3, Parent = TrackBack,
                })
                New("UICorner", { CornerRadius = UDim.new(0,100), Parent = DragCircle })

                AttachDots(Container, subElemsFn)

                Library.Flags[flag] = value
                local Slider  = { Value = value, Flag = flag }
                local sliding = false

                local function SetValue(v, animated)
                    v = Round(math.clamp(v, minV, maxV), decimals)
                    value = v; Slider.Value = v; Library.Flags[flag] = v
                    local t = (maxV ~= minV) and ((v-minV)/(maxV-minV)) or 0
                    if animated then
                        Tween(Fill,       { Size = UDim2.new(t,0,1,0)       })
                        Tween(DragCircle, { Position = UDim2.new(t,0,0.5,0) })
                    else
                        Fill.Size = UDim2.new(t,0,1,0)
                        DragCircle.Position = UDim2.new(t,0,0.5,0)
                    end
                    ValueLabel.Text = tostring(v)..suffix
                    SafeCall(callback, v)
                end

                local function ProcessInput(pos)
                    local w = TrackBack.AbsoluteSize.X
                    if w == 0 then return end
                    SetValue(minV + (maxV-minV) * math.clamp(
                        (pos.X - TrackBack.AbsolutePosition.X) / w, 0, 1), false)
                end

                Window._connStore:Add(TrackBack.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = true; ProcessInput(input.Position)
                    end
                end))
                Window._connStore:Add(UserInputService.InputChanged:Connect(function(input)
                    if not sliding then return end
                    if input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch then
                        ProcessInput(input.Position)
                    end
                end))
                Window._connStore:Add(UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = false
                    end
                end))

                SetValue(value, false)
                function Slider:Set(v) SetValue(v, true) end
                function Slider:Get() return value       end
                return Slider
            end

            -- ── Dropdown  (v4: searchbar, checkmark, updated value box) ───────
            function Section:Dropdown(config)
                config = config or {}
                local name            = config.Name             or "Dropdown"
                local flag            = config.Flag             or name
                local items           = config.Items            or {}
                local default         = config.Default          or ""
                local multi           = config.Multi            or false
                local callback        = config.Callback         or function() end
                local searchEnabled   = config.SearchbarEnabled or false
                local subElemsFn      = config.SubElements

                local value   = multi and {} or default
                local isOpen  = false
                local closing = false

                AddSep()

                local Outer = New("Frame", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,32), ClipsDescendants = false,
                    Name = name, Parent = Card,
                })
                local Header = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Element,
                    BackgroundTransparency = 0.9,
                    Size = UDim2.new(1,0,0,30), Parent = Outer,
                })
                New("UICorner", { CornerRadius = UDim.new(0,4), Parent = Header })
                New("UIPadding", {
                    PaddingTop = UDim.new(0,2), PaddingBottom = UDim.new(0,2),
                    PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4),
                    Parent = Header,
                })
                New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 15,
                    TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextPrimary,
                    Text = name..":", Size = UDim2.new(0.44,0,1,0), Parent = Header,
                })

                -- v4 value box: fixed size, left-anchored at 44% + 4px offset
                local ValueBox = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.ElementDark,
                    BackgroundTransparency = 0.4,
                    Size = UDim2.new(0.44,-16,0,22),
                    AnchorPoint = Vector2.new(0,0.5),
                    Position = UDim2.new(0.46,2,0.5,0),
                    Parent = Header,
                })
                New("UICorner", { CornerRadius = UDim.new(0,5), Parent = ValueBox })
                local ValueLabel = New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 12, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextSecondary,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = multi and "" or default,
                    Size = UDim2.new(1,-8,1,0), Position = UDim2.new(0,4,0,0),
                    Parent = ValueBox,
                })
                local Arrow = New("ImageLabel", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    ImageColor3 = T.TextMuted, AnchorPoint = Vector2.new(1,0.5),
                    Image = "rbxassetid://84949494757640",
                    Size = UDim2.new(0,10,0,10),
                    Position = UDim2.new(1,0,0.5,0),
                    Parent = Header,
                })

                AttachDots(Header, subElemsFn)

                -- ── Options panel (parented to ScreenGui to avoid clipping) ───
                local OptionsList = New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Nav,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0,200,0,0),
                    Visible = false, ZIndex = 100,
                    Name = name.."_Options", Parent = ScreenGui,
                })
                New("UICorner", { CornerRadius = UDim.new(0,10), Parent = OptionsList })
                local ddStroke = New("UIStroke", {
                    Color = T.Stroke, Thickness = 1, Transparency = 1,
                    Parent = OptionsList,
                })
                New("UIPadding", {
                    PaddingTop = UDim.new(0,6), PaddingBottom = UDim.new(0,6),
                    PaddingLeft = UDim.new(0,6), PaddingRight = UDim.new(0,6),
                    Parent = OptionsList,
                })
                New("UIListLayout", {
                    Padding = UDim.new(0,4), SortOrder = Enum.SortOrder.LayoutOrder,
                    Parent = OptionsList,
                })
                local ddScale = New("UIScale", { Scale = 0.96, Parent = OptionsList })

                -- Optional Searchbar
                local SearchInput = nil
                if searchEnabled then
                    local SBar = New("Frame", {
                        BorderSizePixel = 0, BackgroundColor3 = T.ElementDark,
                        Size = UDim2.new(1,0,0,26), ZIndex = 101,
                        Name = "Searchbar", Parent = OptionsList,
                    })
                    New("UICorner", { CornerRadius = UDim.new(0,6), Parent = SBar })
                    SearchInput = New("TextBox", {
                        BorderSizePixel = 0, BackgroundTransparency = 1,
                        TextSize = 12, FontFace = RFont,
                        TextColor3 = T.TextSecondary, PlaceholderColor3 = T.TextMuted,
                        PlaceholderText = "Search...",
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Text = "", ClearTextOnFocus = false,
                        Size = UDim2.new(1,-26,1,0), Position = UDim2.new(0,8,0,0),
                        ZIndex = 102, Name = "Input", Parent = SBar,
                    })
                    New("ImageLabel", {
                        BorderSizePixel = 0, BackgroundTransparency = 1,
                        ImageColor3 = T.TextMuted, AnchorPoint = Vector2.new(1,0.5),
                        Image = "rbxassetid://10734943674",
                        Size = UDim2.new(0,13,0,13),
                        Position = UDim2.new(1,-5,0.5,0),
                        ZIndex = 102, Parent = SBar,
                    })
                end

                -- Scrollable options holder
                local OptionsHolder = New("ScrollingFrame", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,120),    -- resized on open
                    CanvasSize = UDim2.new(0,0,0,0),
                    AutomaticCanvasSize = Enum.AutomaticSize.Y,
                    ScrollBarImageTransparency = 0.7,
                    ScrollBarImageColor3 = T.Stroke,
                    ScrollBarThickness = 2,
                    ZIndex = 101, Name = "OptionsHolder", Parent = OptionsList,
                })
                New("UIListLayout", {
                    Padding = UDim.new(0,2), SortOrder = Enum.SortOrder.LayoutOrder,
                    Parent = OptionsHolder,
                })

                local Dropdown    = { Value = value, Flag = flag, Options = {} }
                Library.Flags[flag] = value

                local DD_IN  = 0.18
                local DD_OUT = 0.13

                local function HighlightOption(opt, selected)
                    Tween(opt.Btn,   { BackgroundTransparency = selected and 0 or 1,
                                       BackgroundColor3 = T.AccentDark })
                    Tween(opt.Label, { TextColor3 = selected and T.TextPrimary or T.TextSecondary })
                    if opt.Check then opt.Check.Visible = selected end
                end

                local function UpdateValueLabel()
                    ValueLabel.Text = multi
                        and (#Dropdown.Value > 0 and table.concat(Dropdown.Value, ", ") or "")
                        or  tostring(Dropdown.Value or "")
                end

                local function FilterOptions(query)
                    if not searchEnabled then return end
                    query = query:lower()
                    for _, o in ipairs(Dropdown.Options) do
                        local m = query == "" or tostring(o.Value):lower():find(query, 1, true)
                        o.Btn.Visible = (m ~= nil and m ~= false)
                    end
                end

                local function RepositionList()
                    local ap = Header.AbsolutePosition
                    local as = Header.AbsoluteSize
                    local nOpts = math.min(#Dropdown.Options, 6)
                    local optsH = nOpts * 28 + 8
                    local barH  = searchEnabled and 32 or 0
                    local total = optsH + barH + 16
                    OptionsList.Position = UDim2.new(0, ap.X, 0, ap.Y + as.Y + 4)
                    OptionsList.Size     = UDim2.new(0, as.X, 0, total)
                    OptionsHolder.Size   = UDim2.new(1,0,0,optsH)
                end

                local function OpenDropdown()
                    if isOpen then return end
                    isOpen = true; closing = false
                    RepositionList()
                    OptionsList.BackgroundTransparency = 1
                    ddStroke.Transparency = 1
                    ddScale.Scale = 0.96
                    for _, o in ipairs(Dropdown.Options) do
                        o.Label.TextTransparency = 1
                    end
                    OptionsList.Visible = true
                    Tween(OptionsList, { BackgroundTransparency = 0.05 }, DD_IN)
                    Tween(ddStroke,    { Transparency = 0              }, DD_IN)
                    Tween(ddScale,     { Scale = 1.0                   }, DD_IN,
                          Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                    for _, o in ipairs(Dropdown.Options) do
                        Tween(o.Label, { TextTransparency = 0 }, DD_IN)
                    end
                    Tween(Arrow, { Rotation = 180 }, DD_IN)
                    if searchEnabled and SearchInput then
                        SearchInput.Text = ""; FilterOptions("")
                    end
                end

                local function CloseDropdown()
                    if not isOpen then return end
                    isOpen = false; closing = true
                    Tween(OptionsList, { BackgroundTransparency = 1 }, DD_OUT)
                    Tween(ddStroke,    { Transparency = 1           }, DD_OUT)
                    Tween(ddScale,     { Scale = 0.96               }, DD_OUT)
                    for _, o in ipairs(Dropdown.Options) do
                        Tween(o.Label, { TextTransparency = 1 }, DD_OUT)
                    end
                    Tween(Arrow, { Rotation = 0 }, DD_OUT)
                    task.delay(DD_OUT + 0.02, function()
                        if closing then OptionsList.Visible = false; closing = false end
                    end)
                end

                if searchEnabled and SearchInput then
                    Window._connStore:Add(SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
                        FilterOptions(SearchInput.Text)
                    end))
                end

                local HeaderBtn = New("TextButton", {
                    BackgroundTransparency = 1, Size = UDim2.new(1,0,0,30),
                    Text = "", AutoButtonColor = false, ZIndex = 4, Parent = Header,
                })
                Window._connStore:Add(HeaderBtn.MouseButton1Click:Connect(function()
                    if isOpen then CloseDropdown() else OpenDropdown() end
                end))
                Window._connStore:Add(UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                    if not isOpen then return end
                    local mp = input.Position
                    local ap = OptionsList.AbsolutePosition
                    local as = OptionsList.AbsoluteSize
                    if not (mp.X >= ap.X and mp.X <= ap.X+as.X and mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y) then
                        CloseDropdown()
                    end
                end))

                local function AddOption(item)
                    local optBtn = New("TextButton", {
                        BorderSizePixel = 0, BackgroundColor3 = T.AccentDark,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1,0,0,26), ZIndex = 101,
                        AutoButtonColor = false, Text = "",
                        Name = tostring(item), Parent = OptionsHolder,
                    })
                    New("UICorner", { CornerRadius = UDim.new(0,6), Parent = optBtn })
                    local optLabel = New("TextLabel", {
                        BorderSizePixel = 0, TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                        BackgroundTransparency = 1, TextColor3 = T.TextSecondary,
                        TextTransparency = 1, ZIndex = 102,
                        Text = tostring(item),
                        Size = UDim2.new(1,-26,1,0), Position = UDim2.new(0,8,0,0),
                        Parent = optBtn,
                    })
                    -- Checkmark for selected
                    local checkIcon = New("ImageLabel", {
                        BorderSizePixel = 0, BackgroundTransparency = 1,
                        ImageColor3 = T.TextPrimary,
                        AnchorPoint = Vector2.new(1,0.5),
                        Image = "rbxassetid://10709790644",
                        Size = UDim2.new(0,13,0,13),
                        Position = UDim2.new(1,-4,0.5,0),
                        ZIndex = 102, Visible = false,
                        Name = "Check", Parent = optBtn,
                    })
                    local optData = { Value = item, Btn = optBtn, Label = optLabel, Check = checkIcon }
                    table.insert(Dropdown.Options, optData)

                    Window._connStore:Add(optBtn.MouseEnter:Connect(function()
                        local sel = multi and table.find(Dropdown.Value, item) or Dropdown.Value == item
                        if not sel then Tween(optBtn, { BackgroundTransparency = 0.75 }) end
                    end))
                    Window._connStore:Add(optBtn.MouseLeave:Connect(function()
                        local sel = multi and table.find(Dropdown.Value, item) or Dropdown.Value == item
                        Tween(optBtn, { BackgroundTransparency = sel and 0 or 1 })
                    end))
                    Window._connStore:Add(optBtn.MouseButton1Click:Connect(function()
                        if multi then
                            local idx = table.find(Dropdown.Value, item)
                            if idx then
                                table.remove(Dropdown.Value, idx)
                                HighlightOption(optData, false)
                            else
                                table.insert(Dropdown.Value, item)
                                HighlightOption(optData, true)
                            end
                            Library.Flags[flag] = Dropdown.Value
                            UpdateValueLabel(); SafeCall(callback, Dropdown.Value)
                        else
                            Dropdown.Value = item; Library.Flags[flag] = item
                            for _, o in ipairs(Dropdown.Options) do
                                HighlightOption(o, o.Value == item)
                            end
                            UpdateValueLabel(); SafeCall(callback, item)
                            CloseDropdown()
                        end
                    end))
                    return optData
                end

                for _, item in ipairs(items) do AddOption(item) end

                if not multi and default ~= "" then
                    for _, o in ipairs(Dropdown.Options) do
                        HighlightOption(o, o.Value == default)
                    end
                    Library.Flags[flag] = default
                end

                function Dropdown:Set(v)
                    if multi then
                        if type(v) ~= "table" then v = {v} end
                        Dropdown.Value = v; Library.Flags[flag] = v
                        for _, o in ipairs(Dropdown.Options) do
                            HighlightOption(o, table.find(v, o.Value) ~= nil)
                        end
                    else
                        Dropdown.Value = v; Library.Flags[flag] = v
                        for _, o in ipairs(Dropdown.Options) do
                            HighlightOption(o, o.Value == v)
                        end
                    end
                    UpdateValueLabel(); SafeCall(callback, Dropdown.Value)
                end
                function Dropdown:Refresh(newItems)
                    for _, o in ipairs(Dropdown.Options) do o.Btn:Destroy() end
                    Dropdown.Options = {}
                    for _, item in ipairs(newItems) do AddOption(item) end
                end
                function Dropdown:Get() return Dropdown.Value end
                return Dropdown
            end

            -- ── Button ────────────────────────────────────────────────────────
            function Section:Button(config)
                config = config or {}
                local name       = config.Name     or "Button"
                local callback   = config.Callback or function() end
                local subElemsFn = config.SubElements

                AddSep()

                local Row = New("Frame", {
                    BorderSizePixel = 0, BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,30), Name = name, Parent = Card,
                })
                local btnW = subElemsFn and UDim2.new(1,-28,1,0) or UDim2.new(1,0,1,0)
                local Btn = New("TextButton", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Accent,
                    BackgroundTransparency = 0.82,
                    Size = btnW, AutoButtonColor = false,
                    Text = "", Name = name, Parent = Row,
                })
                New("UICorner", { CornerRadius = UDim.new(0,6), Parent = Btn })
                New("UIStroke", { Color = T.Accent, Transparency = 0.65, Thickness = 1, Parent = Btn })
                New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 14, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextPrimary,
                    Text = name, Size = UDim2.new(1,0,1,0), Parent = Btn,
                })

                AttachDots(Row, subElemsFn)

                Window._connStore:Add(Btn.MouseEnter:Connect(function()
                    Tween(Btn, { BackgroundTransparency = 0.55 })
                end))
                Window._connStore:Add(Btn.MouseLeave:Connect(function()
                    Tween(Btn, { BackgroundTransparency = 0.82 })
                end))
                Window._connStore:Add(Btn.MouseButton1Click:Connect(function()
                    Tween(Btn, { BackgroundTransparency = 0.25 })
                    task.delay(0.15, function()
                        Tween(Btn, { BackgroundTransparency = 0.82 })
                    end)
                    SafeCall(callback)
                end))
                return { Name = name, Instance = Btn }
            end

            -- ── Label ─────────────────────────────────────────────────────────
            function Section:Label(config)
                config = config or {}
                local text = config.Text or config.Name or "Label"

                AddSep()

                local Lbl = New("TextLabel", {
                    BorderSizePixel = 0, TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left, FontFace = RFont,
                    BackgroundTransparency = 1, TextColor3 = T.TextMuted,
                    Text = text, Size = UDim2.new(1,0,0,22),
                    Name = "Label_"..text, Parent = Card,
                })
                local Label = { Instance = Lbl }
                function Label:SetText(t) Lbl.Text = tostring(t) end
                function Label:SetColor(c) Lbl.TextColor3 = c    end
                return Label
            end

            -- ── Separator (manual, in addition to auto-separators) ─────────────
            function Section:Separator()
                New("Frame", {
                    BorderSizePixel = 0, BackgroundColor3 = T.Stroke,
                    BackgroundTransparency = 0.4,
                    Size = UDim2.new(1,0,0,1), Parent = Card,
                })
                return self
            end

            return Section
        end  -- Page:Section

        return Page
    end  -- Window:Page

    return Window
end  -- Library:Window

-- ─────────────────────────────────────────────────────────────────────────────
return Library

