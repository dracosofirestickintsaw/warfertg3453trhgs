        }):Play()

        task.delay(duration, function()
            local OUT_T = 0.2
            Tween(NotifFrame,  { BackgroundTransparency = 1 }, OUT_T)
            Tween(notifStroke, { Transparency = 1           }, OUT_T)
            Tween(notifScale,  { Scale = 0.92               }, OUT_T)
            Tween(TitleLbl,    { TextTransparency = 1       }, OUT_T)
            Tween(DescLbl,     { TextTransparency = 1       }, OUT_T)
            task.wait(OUT_T + 0.05)
            if NotifFrame and NotifFrame.Parent then NotifFrame:Destroy() end
        end)

        return NotifFrame
    end

