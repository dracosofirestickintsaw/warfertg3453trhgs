    })

    -- ── Content container
    -- FIX: ClipsDescendants removed — dropdown lists must not be clipped.
    local ContentContainer = New("Frame", {
        BorderSizePixel        = 0,
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 228, 0, 66),
        Size                   = UDim2.new(1, -234, 1, -72),
        ClipsDescendants       = false,   -- was true; caused dropdown options to vanish
        Name                   = "ContentContainer",
        Parent                 = Main,
    })

    -- ── Dragging  (clamped to viewport)
    do
        local dragging, dragStart, startPos = false, nil, nil
        local cs = Window._connStore

        cs:Add(Main.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
            local mp = input.Position
            local ap = Main.AbsolutePosition
            if mp.Y <= ap.Y + 62 then
                dragging  = true
                dragStart = mp
                startPos  = Main.Position
            end
        end))

        cs:Add(UserInputService.InputChanged:Connect(function(input)
            if not dragging then return end
            if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end

            local vp    = Camera.ViewportSize
            local delta = input.Position - dragStart
            local hw    = Main.AbsoluteSize.X / 2
            local hh    = Main.AbsoluteSize.Y / 2

            -- Clamp so window stays fully on screen
            local newX = math.clamp(
                startPos.X.Offset + delta.X,
                hw - vp.X / 2,
                vp.X / 2 - hw
            )
            local newY = math.clamp(
                startPos.Y.Offset + delta.Y,
                hh - vp.Y / 2,
                vp.Y / 2 - hh
            )

            Main.Position = UDim2.new(0.5, newX, 0.5, newY)
        end))

        cs:Add(UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end))
    end

    -- ── Keybind toggle
    Window._connStore:Add(UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == toggleKey then
            Window.IsOpen = not Window.IsOpen
            Main.Visible  = Window.IsOpen
        end
    end))

    Window.Main             = Main
    Window.ButtonHolder     = ButtonHolder
    Window.ContentContainer = ContentContainer

    -- ── Notifications
    local NotifHolder = New("Frame", {
