local function Tween(obj, props, duration, style, direction)
    TweenService:Create(
        obj,
        TweenInfo.new(
            duration  or 0.18,
            style     or Enum.EasingStyle.Quad,
            direction or Enum.EasingDirection.Out
        ),
        props
    ):Play()
end

local function New(class, props)
    local inst = Instance.new(class)
    local parent = props.Parent
    props.Parent = nil
    for k, v in pairs(props) do
        inst[k] = v
    end
    if parent then inst.Parent = parent end
    return inst
end

local function SafeCall(fn, ...)
    local ok, err = pcall(fn, ...)
    if not ok then warn("[Da7muLibrary] callback error: " .. tostring(err)) end
end

local function Round(n, decimals)
    local mult = 10 ^ (decimals or 0)
    return math.floor(n * mult + 0.5) / mult
end

-- ─────────────────────────────────────────────────────────────────────────────
--  Blur System  (adapted from Da7mu's BlurController LocalScript)
--  Uses a Glass BlockMesh part positioned over the GUI + DepthOfFieldEffect
-- ─────────────────────────────────────────────────────────────────────────────
local function CreateBlur(frame, intensity)
    intensity = intensity or 0.25
    local BLUR_INSET        = Vector2.new(10, 10)
    local PART_SIZE         = 0.01
    local PART_TRANSPARENCY = 1 - 1e-7
    local bindName          = "Da7muBlur_" .. tostring(math.random(1, 9999999))

    local dof = New("DepthOfFieldEffect", {
        FarIntensity  = 0,
        NearIntensity = intensity,
        FocusDistance = 0.25,
        InFocusRadius = 0,
        Parent        = Lighting,
    })

    local part = New("Part", {
        Size         = Vector3.one * PART_SIZE,
        Anchored     = true,
        CanCollide   = false,
        CanTouch     = false,
        CastShadow   = false,
        Material     = Enum.Material.Glass,
        Transparency = PART_TRANSPARENCY,
        Parent       = Camera,
    })
    local mesh = New("BlockMesh", { Parent = part })

    local function rayPlaneIntersect(pOrig, pNorm, rOrig, rDir)
        local t = -pNorm:Dot(rOrig - pOrig) / pNorm:Dot(rDir)
        return rOrig + t * rDir
    end

    local function update()
        if not frame or not frame.Visible then
            part.Transparency = 1; return
        end
        part.Transparency = PART_TRANSPARENCY

        local c0   = frame.AbsolutePosition + BLUR_INSET
        local c1   = frame.AbsolutePosition + frame.AbsoluteSize - BLUR_INSET
        local ray0 = Camera:ViewportPointToRay(c0.X, c0.Y, 1)
        local ray1 = Camera:ViewportPointToRay(c1.X, c1.Y, 1)

        local pOrig = Camera.CFrame.Position + Camera.CFrame.LookVector * (0.05 - Camera.NearPlaneZ)
        local pNorm = Camera.CFrame.LookVector

        local p0 = Camera.CFrame:PointToObjectSpace(
            rayPlaneIntersect(pOrig, pNorm, ray0.Origin, ray0.Direction))
        local p1 = Camera.CFrame:PointToObjectSpace(
            rayPlaneIntersect(pOrig, pNorm, ray1.Origin, ray1.Direction))

        mesh.Offset           = (p0 + p1) / 2
        mesh.Scale            = (p1 - p0) / PART_SIZE
        dof.FocusDistance     = 0.25 - Camera.NearPlaneZ
    end

    RunService:BindToRenderStep(bindName, Enum.RenderPriority.Camera.Value + 1, function()
        part.CFrame = Camera.CFrame
        update()
    end)

    return function()   -- cleanup
        RunService:UnbindFromRenderStep(bindName)
        pcall(function() part:Destroy()   end)
        pcall(function() dof:Destroy()    end)
    end
end

