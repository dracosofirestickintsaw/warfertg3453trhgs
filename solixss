            PaddingRight  = UDim.new(0, 12),
            Parent        = NotifFrame,
        })

        New("TextLabel", {
            BorderSizePixel        = 0,
            TextSize               = 14,
            FontFace               = RFont,
            BackgroundTransparency = 1,
            TextColor3             = T.TextPrimary,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Text                   = title,
            Size                   = UDim2.new(1, 0, 0, 18),
            Name                   = "Title",
            Parent                 = NotifFrame,
        })
        New("TextLabel", {
            BorderSizePixel        = 0,
            TextSize               = 12,
            FontFace               = RFont,
            BackgroundTransparency = 1,
            TextColor3             = T.TextMuted,
            TextXAlignment         = Enum.TextXAlignment.Left,
            TextWrapped            = true,
            Text                   = desc,
            Size                   = UDim2.new(1, 0, 0, 0),
            AutomaticSize          = Enum.AutomaticSize.Y,
            Position               = UDim2.new(0, 0, 0, 22),
            Name                   = "Description",
            Parent                 = NotifFrame,
        })

        -- Progress bar
        local ProgBg = New("Frame", {
            BorderSizePixel  = 0,
            BackgroundColor3 = T.Track,
            Size             = UDim2.new(1, 0, 0, 3),
            Position         = UDim2.new(0, 0, 1, 6),
            AnchorPoint      = Vector2.new(0, 1),
            Name             = "ProgBg",
            Parent           = NotifFrame,
        })
        local ProgFill = New("Frame", {
            BorderSizePixel  = 0,
            BackgroundColor3 = T.Accent,
            Size             = UDim2.new(1, 0, 1, 0),
            Parent           = ProgBg,
        })
        New("UICorner", { Parent = ProgBg })
        New("UICorner", { Parent = ProgFill })

        -- Animate progress drain
        TweenService:Create(ProgFill, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 1, 0),
        }):Play()

        -- Fade out and destroy
        task.delay(duration, function()
            Tween(NotifFrame, { BackgroundTransparency = 1 })
            task.wait(0.25)
            NotifFrame:Destroy()
        end)

        return NotifFrame
    end

