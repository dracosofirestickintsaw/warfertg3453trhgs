function Library:_AddCheckbox(config, section)
	local name = config.Name or "Checkbox"
	local default = config.Default or false
	local callback = config.Callback or function() end

	section.ElementCount = section.ElementCount + 1

	local holder = Instance.new("Frame")
	holder.Name = "Checkbox_" .. name
	holder.BackgroundTransparency = 1
	holder.Size = UDim2.new(1, 0, 0, 22)
	holder.LayoutOrder = section.ElementCount
	holder.Parent = section.ElementsFrame

	local checkFrame = Instance.new("Frame")
	checkFrame.Name = "CheckFrame"
	checkFrame.BackgroundColor3 = default and ACCENT or ELEMENT_BG
	checkFrame.Size = UDim2.fromOffset(18, 18)
	checkFrame.Position = UDim2.fromOffset(0, 2)
	MakeCorner(checkFrame, UDim.new(0.1, 1))
	checkFrame.Parent = holder

	local checkIcon = Instance.new("ImageLabel")
	checkIcon.Name = "CheckIcon"
	checkIcon.BackgroundTransparency = 1
	checkIcon.Image = "rbxassetid://10709790644"
	checkIcon.ImageColor3 = Color3.new(0, 0, 0)
	checkIcon.Position = UDim2.new(0.045, 1, 0, 2)
	checkIcon.Size = UDim2.fromOffset(15, 15)
	checkIcon.ImageTransparency = default and 0 or 1
	checkIcon.Parent = checkFrame

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "ElementName"
	nameLabel.BackgroundTransparency = 1
	nameLabel.FontFace = FONT
	nameLabel.Position = UDim2.fromOffset(23, 0)
	nameLabel.Size = UDim2.new(1, -23, 1, 0)
	nameLabel.Text = name
	nameLabel.TextColor3 = default and TEXT_ACTIVE or TEXT_MUTED
	nameLabel.TextSize = 17
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Parent = holder

	local toggled = default
	local debounce = false

	local btn = Instance.new("TextButton")
	btn.Name = "HitBox"
	btn.BackgroundTransparency = 1
	btn.Size = UDim2.fromScale(1, 1)
	btn.Text = ""
	btn.Parent = holder

	btn.MouseButton1Click:Connect(function()
		if debounce then return end
		debounce = true
		toggled = not toggled
		Tween(checkFrame, {BackgroundColor3 = toggled and ACCENT or ELEMENT_BG}, 0.12)
		Tween(checkIcon, {ImageTransparency = toggled and 0 or 1}, 0.12)
		nameLabel.TextColor3 = toggled and TEXT_ACTIVE or TEXT_MUTED
		callback(toggled)
		task.wait(0.05)
		debounce = false
	end)

	btn.MouseEnter:Connect(function()
		Tween(checkFrame, {BackgroundColor3 = toggled and lighten(ACCENT, 0.07) or lighten(ELEMENT_BG, 0.07)}, 0.1)
	end)
	btn.MouseLeave:Connect(function()
		Tween(checkFrame, {BackgroundColor3 = toggled and ACCENT or ELEMENT_BG}, 0.1)
	end)

	local obj = {}
	function obj:Set(value)
		toggled = value
		Tween(checkFrame, {BackgroundColor3 = toggled and ACCENT or ELEMENT_BG}, 0.12)
		Tween(checkIcon, {ImageTransparency = toggled and 0 or 1}, 0.12)
		nameLabel.TextColor3 = toggled and TEXT_ACTIVE or TEXT_MUTED
		callback(toggled)
	end
	function obj:Get() return toggled end
	return obj
end

function Library:_AddSlider(config, section)
	local name = config.Name or "Slider"
	local min = config.Min or 0
	local max = config.Max or 100
	local default = config.Default or min
	local suffix = config.Suffix or ""
	local callback = config.Callback or function() end

	section.ElementCount = section.ElementCount + 1

	local holder = Instance.new("Frame")
	holder.Name = "Slider_" .. name
	holder.BackgroundTransparency = 1
	holder.Size = UDim2.new(1, 0, 0, 32)
	holder.LayoutOrder = section.ElementCount
	holder.Parent = section.ElementsFrame

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "ElementName"
	nameLabel.BackgroundTransparency = 1
	nameLabel.FontFace = FONT
	nameLabel.Position = UDim2.fromOffset(0, 0)
	nameLabel.Size = UDim2.new(0.6, 0, 0, 18)
	nameLabel.Text = name
	nameLabel.TextColor3 = TEXT_MUTED
	nameLabel.TextSize = 17
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Parent = holder

	local valueLabel = Instance.new("TextLabel")
	valueLabel.Name = "ValueLabel"
	valueLabel.BackgroundTransparency = 1
	valueLabel.FontFace = FONT
	valueLabel.Position = UDim2.new(0.6, 0, 0, 0)
	valueLabel.Size = UDim2.new(0.4, 0, 0, 18)
	valueLabel.Text = tostring(default) .. suffix
	valueLabel.TextColor3 = ACCENT
	valueLabel.TextSize = 17
	valueLabel.TextXAlignment = Enum.TextXAlignment.Right
	valueLabel.Parent = holder

	local sliderBg = Instance.new("Frame")
	sliderBg.Name = "SliderBackground"
	sliderBg.BackgroundColor3 = ELEMENT_BG
	sliderBg.Position = UDim2.fromOffset(0, 20)
	sliderBg.Size = UDim2.new(1, 0, 0, 4)
	MakeCorner(sliderBg)
	sliderBg.Parent = holder

	local sliderFill = Instance.new("Frame")
	sliderFill.Name = "SliderFill"
	sliderFill.BackgroundColor3 = ACCENT
	sliderFill.Size = UDim2.fromScale((default - min) / (max - min), 1)
	MakeCorner(sliderFill)
	sliderFill.Parent = sliderBg

	local sliderBtn = Instance.new("TextButton")
	sliderBtn.Name = "HitBox"
	sliderBtn.BackgroundTransparency = 1
	sliderBtn.Size = UDim2.new(1, 0, 0, 18)
	sliderBtn.Position = UDim2.fromOffset(0, 16)
	sliderBtn.Text = ""
	sliderBtn.Parent = holder

	local currentValue = default
	local sliding = false

	local function updateSlider(inputX)
		local relX = math.clamp(inputX - sliderBg.AbsolutePosition.X, 0, sliderBg.AbsoluteSize.X)
		local pct = relX / sliderBg.AbsoluteSize.X
		local val = math.floor(min + (max - min) * pct)
		currentValue = val
		sliderFill.Size = UDim2.fromScale(pct, 1)
		valueLabel.Text = tostring(val) .. suffix
		nameLabel.TextColor3 = TEXT_ACTIVE
		callback(val)
	end

	sliderBtn.MouseButton1Down:Connect(function()
		sliding = true
		updateSlider(UserInputService:GetMouseLocation().X)
	end)

	UserInputService.InputChanged:Connect(function(input)
		if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateSlider(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			sliding = false
		end
	end)

	sliderBg.MouseEnter:Connect(function()
		Tween(sliderBg, {BackgroundColor3 = lighten(ELEMENT_BG, 0.07)}, 0.1)
	end)
	sliderBg.MouseLeave:Connect(function()
		Tween(sliderBg, {BackgroundColor3 = ELEMENT_BG}, 0.1)
	end)

	local obj = {}
	function obj:Set(value)
		value = math.clamp(value, min, max)
		currentValue = value
		local pct = (value - min) / (max - min)
		sliderFill.Size = UDim2.fromScale(pct, 1)
		valueLabel.Text = tostring(value) .. suffix
		callback(value)
	end
	function obj:Get() return currentValue end
	return obj
end

