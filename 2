function Library:_SelectTab(tab, subPage)
	if subPage.ActiveTab then
		subPage.ActiveTab.ContentFrame.Visible = false
		subPage.ActiveTab.SectionTopBar.Visible = false
		subPage.ActiveTab.TabButton.TextColor3 = TEXT_INACTIVE
	end

	subPage.ActiveTab = tab
	tab.ContentFrame.Visible = true
	tab.SectionTopBar.Visible = true
	tab.TabButton.TextColor3 = ACCENT

	local tabBtn = tab.TabButton
	local yPos = tabBtn.AbsolutePosition.Y - self.TabsHolder.AbsolutePosition.Y
	Tween(self.TabSelectedFrame, {
		Position = UDim2.new(1, -7, 0, yPos + 6)
	}, 0.15)

	tab.SectionTopBar.Size = UDim2.fromOffset(462, 43)
	tab.SectionTopBar.Position = UDim2.fromOffset(0, 0)
	tab.SectionTopBar.Visible = true
end

