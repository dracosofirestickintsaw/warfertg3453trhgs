local function Tween(instance, properties, duration, style, direction)
	local info = TweenInfo.new(duration or 0.15, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out)
	local t = TweenService:Create(instance, info, properties)
	t:Play()
	return t
end

local function MakeCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = radius or UDim.new(0, 5)
	c.Parent = parent
	return c
end

local function HoverEffect(frame, normal, hovered)
	frame.MouseEnter:Connect(function()
		Tween(frame, {BackgroundColor3 = hovered}, 0.1)
	end)
	frame.MouseLeave:Connect(function()
		Tween(frame, {BackgroundColor3 = normal}, 0.1)
	end)
end

local function lighten(color, amount)
	local h, s, v = Color3.toHSV(color)
	return Color3.fromHSV(h, s, math.min(1, v + (amount or 0.07)))
end

