function Library:_InitDrag(dragSource, mainFrame, topBar)
	local dragging = false
	local dragStart, startMainPos, startTopPos

	dragSource.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startMainPos = mainFrame.Position
			startTopPos = topBar.Position
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			mainFrame.Position = UDim2.new(
				startMainPos.X.Scale,
				startMainPos.X.Offset + delta.X,
				startMainPos.Y.Scale,
				startMainPos.Y.Offset + delta.Y
			)
			topBar.Position = UDim2.new(
				startTopPos.X.Scale,
				startTopPos.X.Offset + delta.X,
				startTopPos.Y.Scale,
				startTopPos.Y.Offset + delta.Y
			)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
end

function Library:SubPage(config)
	local name = config.Name or "SubPage"
	local index = #self.SubPageButtons + 1

	local xOffset = 297 - (index - 1) * 53
	if index == 1 then xOffset = 297 end

	local btn = Instance.new("TextLabel")
	btn.Name = "SubPage_" .. name
	btn.BackgroundTransparency = 1
	btn.FontFace = FONT
	btn.Position = UDim2.fromOffset(xOffset, 9)
	btn.Size = UDim2.fromOffset(math.max(string.len(name) * 10, 42), 37)
	btn.Text = name
	btn.TextColor3 = TEXT_INACTIVE
	btn.TextSize = 20
	btn.Parent = self.TopBar

	local subPage = {
		Name = name,
		Button = btn,
		Tabs = {},
		ActiveTab = nil,
		TabButtons = {},
		TabSelectedFrame = self.TabSelectedFrame,
	}

	table.insert(self.SubPageButtons, {btn = btn, subPage = subPage})

	local function reposition()
		local totalWidth = 0
		local widths = {}
		for i, v in ipairs(self.SubPageButtons) do
			local w = math.max(string.len(v.subPage.Name) * 10 + 8, 42)
			widths[i] = w
			totalWidth = totalWidth + w
		end
		local startX = 579 - 15 - totalWidth
		for i, v in ipairs(self.SubPageButtons) do
			v.btn.Position = UDim2.fromOffset(startX, 9)
			v.btn.Size = UDim2.fromOffset(widths[i], 37)
			startX = startX + widths[i] + 8
		end
	end
	reposition()

	local function selectSubPage(sp, btnRef)
		if self.ActiveSubPage then
			for _, v in ipairs(self.SubPageButtons) do
				v.btn.TextColor3 = TEXT_INACTIVE
			end
			for _, tab in ipairs(self.ActiveSubPage.Tabs) do
				if tab.ContentFrame then
					tab.ContentFrame.Visible = false
				end
				if tab.TabButton then
					tab.TabButton.TextColor3 = TEXT_INACTIVE
				end
			end
		end

		self.ActiveSubPage = sp
		btnRef.TextColor3 = ACCENT

		Tween(self.SubSelectedFrame, {
			Position = UDim2.new(0, btnRef.Position.X.Offset + btnRef.AbsoluteSize.X / 2 - 17, 1, -4),
			Size = UDim2.fromOffset(btnRef.AbsoluteSize.X, 4)
		}, 0.15)

		if #sp.Tabs > 0 then
			local firstTab = sp.Tabs[1]
			self:_SelectTab(firstTab, sp)
		end
	end

	btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			selectSubPage(subPage, btn)
		end
	end)
	btn.MouseEnter:Connect(function()
		if self.ActiveSubPage ~= subPage then
			btn.TextColor3 = lighten(TEXT_INACTIVE, 0.1)
		end
	end)
	btn.MouseLeave:Connect(function()
		if self.ActiveSubPage ~= subPage then
			btn.TextColor3 = TEXT_INACTIVE
		end
	end)

	if #self.SubPageButtons == 1 then
		task.defer(function()
			selectSubPage(subPage, btn)
		end)
	end

	local subPageObj = {}

	function subPageObj:Tab(tabConfig)
		return Library._AddTab(Library, tabConfig, subPage, self)
	end

	self.SubPages[name] = subPage
	return subPageObj
end

