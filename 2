	local name = config.Name or "Dropdown"
	local options = config.Options or {}
	local default = config.Default or nil
	local multiSelect = config.MultiSelect or false
	local callback = config.Callback or function() end

	section.ElementCount = section.ElementCount + 1

	local holder = Instance.new("Frame")
	holder.Name = "Dropdown_" .. name
	holder.BackgroundTransparency = 1
	holder.Size = UDim2.new(1, 0, 0, 48)
	holder.ClipsDescendants = false
	holder.LayoutOrder = section.ElementCount
	holder.Parent = section.ElementsFrame

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "ElementName"
	nameLabel.BackgroundTransparency = 1
	nameLabel.FontFace = FONT
	nameLabel.Position = UDim2.fromOffset(0, 0)
	nameLabel.Size = UDim2.new(1, 0, 0, 18)
	nameLabel.Text = name
	nameLabel.TextColor3 = TEXT_MUTED
	nameLabel.TextSize = 17
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Parent = holder

	local dropFrame = Instance.new("Frame")
	dropFrame.Name = "DropdownFrame"
	dropFrame.BackgroundColor3 = ELEMENT_BG
	dropFrame.Position = UDim2.fromOffset(0, 22)
	dropFrame.Size = UDim2.new(1, 0, 0, 26)
	MakeCorner(dropFrame, UDim.new(0.1, 1))
	dropFrame.Parent = holder

	local selectedLabel = Instance.new("TextLabel")
	selectedLabel.Name = "SelectedLabel"
	selectedLabel.BackgroundTransparency = 1
	selectedLabel.FontFace = FONT
	selectedLabel.Position = UDim2.fromOffset(10, 0)
	selectedLabel.Size = UDim2.new(1, -35, 1, 0)
	selectedLabel.Text = (default and (type(default) == "table" and table.concat(default, ", ") or tostring(default))) or "Select..."
	selectedLabel.TextColor3 = default and TEXT_ACTIVE or TEXT_MUTED
	selectedLabel.TextSize = 17
	selectedLabel.TextXAlignment = Enum.TextXAlignment.Left
	selectedLabel.Parent = dropFrame

	local arrowIcon = Instance.new("ImageLabel")
	arrowIcon.Name = "Arrow"
	arrowIcon.BackgroundTransparency = 1
	arrowIcon.Image = "rbxassetid://108899987138167"
	arrowIcon.ImageColor3 = ACCENT
	arrowIcon.Position = UDim2.new(1, -22, 0.5, -7)
	arrowIcon.Size = UDim2.fromOffset(15, 15)
	arrowIcon.Parent = dropFrame

	local openFrame = Instance.new("Frame")
	openFrame.Name = "OpenedDropdown"
	openFrame.BackgroundColor3 = ELEMENT_BG
	openFrame.Position = UDim2.new(0, 0, 0, 50)
	openFrame.Size = UDim2.new(1, 0, 0, 0)
	openFrame.ClipsDescendants = true
	openFrame.ZIndex = 10
	MakeCorner(openFrame, UDim.new(0.05, 1))
	openFrame.Visible = false
	openFrame.Parent = holder

	local optionList = Instance.new("UIListLayout")
	optionList.SortOrder = Enum.SortOrder.LayoutOrder
	optionList.Parent = openFrame

	local isOpen = false
	local selectedValues = {}

	if default then
		if type(default) == "table" then
			for _, v in ipairs(default) do selectedValues[v] = true end
		else
			selectedValues[default] = true
		end
	end

	local function getSelectedText()
		local t = {}
		for k, v in pairs(selectedValues) do
			if v then table.insert(t, k) end
		end
		return #t > 0 and table.concat(t, ", ") or "Select..."
	end

	local function refreshDisplay()
		local txt = getSelectedText()
		selectedLabel.Text = txt
		selectedLabel.TextColor3 = txt ~= "Select..." and TEXT_ACTIVE or TEXT_MUTED
	end

	local optionFrames = {}

	local function buildOptions()
		for _, child in ipairs(openFrame:GetChildren()) do
			if child:IsA("Frame") then child:Destroy() end
		end
		optionFrames = {}
		for i, opt in ipairs(options) do
			local isSelected = selectedValues[opt] == true
			local optFrame = Instance.new("Frame")
			optFrame.Name = "Option_" .. opt
			optFrame.BackgroundColor3 = isSelected and lighten(ELEMENT_BG, 0.08) or ELEMENT_BG
			optFrame.Size = UDim2.new(1, 0, 0, 26)
			optFrame.LayoutOrder = i
			optFrame.ZIndex = 10
			optFrame.Parent = openFrame

			local optLabel = Instance.new("TextLabel")
			optLabel.BackgroundTransparency = 1
			optLabel.FontFace = FONT
			optLabel.Position = UDim2.fromOffset(12, 0)
			optLabel.Size = UDim2.new(1, -12, 1, 0)
			optLabel.Text = opt
			optLabel.TextColor3 = isSelected and TEXT_ACTIVE or TEXT_MUTED
			optLabel.TextSize = 17
			optLabel.TextXAlignment = Enum.TextXAlignment.Left
			optLabel.ZIndex = 11
			optLabel.Parent = optFrame

			local optBtn = Instance.new("TextButton")
			optBtn.BackgroundTransparency = 1
			optBtn.Size = UDim2.fromScale(1, 1)
			optBtn.Text = ""
			optBtn.ZIndex = 12
			optBtn.Parent = optFrame

			optBtn.MouseButton1Click:Connect(function()
				if multiSelect then
					selectedValues[opt] = not selectedValues[opt]
				else
					for k in pairs(selectedValues) do selectedValues[k] = false end
					selectedValues[opt] = true
					isOpen = false
					Tween(openFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.15)
					Tween(arrowIcon, {Rotation = 0}, 0.15)
					task.delay(0.15, function() openFrame.Visible = false end)
				end
				refreshDisplay()
				buildOptions()
				local res = multiSelect and selectedValues or opt
				callback(res)
			end)

			optBtn.MouseEnter:Connect(function()
				Tween(optFrame, {BackgroundColor3 = lighten(optFrame.BackgroundColor3, 0.07)}, 0.1)
			end)
			optBtn.MouseLeave:Connect(function()
				Tween(optFrame, {BackgroundColor3 = selectedValues[opt] and lighten(ELEMENT_BG, 0.08) or ELEMENT_BG}, 0.1)
			end)

			table.insert(optionFrames, optFrame)
		end
		openFrame.Size = UDim2.new(1, 0, 0, #options * 26)
	end

	buildOptions()

	local dropBtn = Instance.new("TextButton")
	dropBtn.BackgroundTransparency = 1
	dropBtn.Size = UDim2.fromScale(1, 1)
	dropBtn.Text = ""
	dropBtn.Parent = dropFrame

	dropBtn.MouseButton1Click:Connect(function()
		isOpen = not isOpen
		if isOpen then
			openFrame.Visible = true
			openFrame.Size = UDim2.new(1, 0, 0, 0)
			Tween(openFrame, {Size = UDim2.new(1, 0, 0, #options * 26)}, 0.15)
			Tween(arrowIcon, {Rotation = 180}, 0.15)
			holder.Size = UDim2.new(1, 0, 0, 48 + #options * 26 + 4)
		else
			Tween(openFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.15)
			Tween(arrowIcon, {Rotation = 0}, 0.15)
			task.delay(0.15, function() openFrame.Visible = false end)
			holder.Size = UDim2.new(1, 0, 0, 48)
		end
	end)

	dropBtn.MouseEnter:Connect(function()
		Tween(dropFrame, {BackgroundColor3 = lighten(ELEMENT_BG, 0.07)}, 0.1)
	end)
	dropBtn.MouseLeave:Connect(function()
		Tween(dropFrame, {BackgroundColor3 = ELEMENT_BG}, 0.1)
	end)

	local obj = {}
	function obj:Set(value)
		if multiSelect and type(value) == "table" then
			selectedValues = {}
			for _, v in ipairs(value) do selectedValues[v] = true end
		elseif type(value) == "string" then
			selectedValues = {}
			selectedValues[value] = true
		end
		refreshDisplay()
		buildOptions()
		callback(multiSelect and selectedValues or value)
	end
	function obj:Get()
		if multiSelect then return selectedValues end
		for k, v in pairs(selectedValues) do if v then return k end end
		return nil
	end
	return obj
end

return Library
