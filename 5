if getgenv().Neptune then getgenv().Neptune:Unload() end

local Neptune
do

local Players         = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService      = game:GetService("RunService")
local TweenService    = game:GetService("TweenService")
local CoreGui         = cloneref and cloneref(game:GetService("CoreGui")) or game:GetService("CoreGui")
gethui = gethui or function() return CoreGui end
local LocalPlayer     = Players.LocalPlayer

local FromRGB         = Color3.fromRGB
local UDim2New        = UDim2.new
local UDimNew         = UDim.new
local Vector2New      = Vector2.new
local InstanceNew     = Instance.new
local TableInsert     = table.insert

Neptune = {
    Connections  = {},
    Threads      = {},
    Pages        = {},
    SubPages     = {},
    Accent       = FromRGB(164, 139, 242),
    TextActive   = FromRGB(164, 139, 242),
    TextInactive = FromRGB(115, 115, 115),
    Gui          = nil,
    Window       = nil,
}
Neptune.__index = Neptune

Neptune.Connect = function(self, Event, Callback)
    local Conn = Event:Connect(Callback)
    TableInsert(self.Connections, Conn)
    return Conn
end

Neptune.Unload = function(self)
    for _, C in self.Connections do C:Disconnect() end
    for _, T in self.Threads    do coroutine.close(T) end
    if self.Gui then self.Gui:Destroy() end
    Neptune = nil
    getgenv().Neptune = nil
end

Neptune.Window = function(self, Data)
    Data = Data or {}
    local Window = {
        Title         = Data.Title  or Data.title  or "neptune",
        ActivePage    = nil,
        ActiveSubPage = nil,
        Pages         = {},
        SubPages      = {},
        Tabs          = {},
        SubTabs       = {},
    }

    local ScreenGui = InstanceNew("ScreenGui")
    ScreenGui.Name          = "Neptune"
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.ResetOnSpawn  = false
    ScreenGui.Parent        = gethui()
    Neptune.Gui = ScreenGui

    local TopBar = InstanceNew("Frame")
    TopBar.Name              = "TopBar"
    TopBar.BackgroundColor3  = FromRGB(15, 15, 15)
    TopBar.ClipsDescendants  = true
    TopBar.Size              = UDim2New(0, 579, 0, 57)
    TopBar.Position          = UDim2New(0.5, -289, 0.5, -217)
    do
        local c = InstanceNew("UICorner")
        c.CornerRadius = UDimNew(0, 5)
        c.Parent = TopBar
    end
    TopBar.Parent = ScreenGui
    Window.TopBar = TopBar

    local TitleLabel = InstanceNew("TextBox")
    TitleLabel.Name               = "Title"
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.CursorPosition     = -1
    TitleLabel.Editable           = false
    TitleLabel.FontFace           = Font.new("rbxasset://fonts/families/SourceSansPro.json")
    TitleLabel.Position           = UDim2New(0, 15, 0, 2)
    TitleLabel.Size               = UDim2New(0, 200, 0, 50)
    TitleLabel.Text               = Window.Title
    TitleLabel.TextColor3         = FromRGB(255, 255, 255)
    TitleLabel.TextSize           = 23
    TitleLabel.TextXAlignment     = Enum.TextXAlignment.Left
    TitleLabel.Parent             = TopBar

    local TopBarLine = InstanceNew("Frame")
    TopBarLine.Name             = "TopBarLine"
    TopBarLine.BackgroundColor3 = FromRGB(15, 15, 15)
    TopBarLine.BorderSizePixel  = 0
    TopBarLine.Position         = UDim2New(0, 0, 0, 53)
    TopBarLine.Size             = UDim2New(0, 579, 0, 4)
    TopBarLine.Parent           = TopBar

    local SubPageHolder = InstanceNew("Frame")
    SubPageHolder.Name             = "SubPageHolder"
    SubPageHolder.BackgroundTransparency = 1
    SubPageHolder.Position         = UDim2New(0, 297, 0, 0)
    SubPageHolder.Size             = UDim2New(0, 282, 0, 57)
    SubPageHolder.Parent           = TopBar
    Window.SubPageHolder = SubPageHolder

    local SubSelectedFrame = InstanceNew("Frame")
    SubSelectedFrame.Name             = "SubSelectedFrame"
    SubSelectedFrame.BackgroundColor3 = FromRGB(164, 139, 242)
    SubSelectedFrame.Size             = UDim2New(0, 35, 0, 4)
    SubSelectedFrame.Visible          = false
    do
        local c = InstanceNew("UICorner")
        c.CornerRadius = UDimNew(0.1, 1)
        c.Parent = SubSelectedFrame
    end
    SubSelectedFrame.Parent = TopBar
    Window.SubSelectedFrame = SubSelectedFrame

    local MainFrame = InstanceNew("Frame")
    MainFrame.Name             = "MainFrame"
    MainFrame.BackgroundColor3 = FromRGB(30, 30, 30)
    MainFrame.Size             = UDim2New(0, 579, 0, 379)
    MainFrame.Position         = UDim2New(0.5, -289, 0.5, -160)
    do
        local c = InstanceNew("UICorner")
        c.CornerRadius = UDimNew(0, 5)
        c.Parent = MainFrame
    end
    MainFrame.Parent = ScreenGui
    Window.MainFrame = MainFrame

    local TabsHolder = InstanceNew("Frame")
    TabsHolder.Name              = "TabsHolder"
    TabsHolder.BackgroundColor3  = FromRGB(20, 20, 20)
    TabsHolder.ClipsDescendants  = true
    TabsHolder.Size              = UDim2New(0, 94, 0, 379)
    do
        local c = InstanceNew("UICorner")
        c.CornerRadius = UDimNew(0, 5)
        c.Parent = TabsHolder
    end
    local TabLineL = InstanceNew("Frame")
    TabLineL.Name             = "TabLine"
    TabLineL.BackgroundColor3 = FromRGB(20, 20, 20)
    TabLineL.BorderSizePixel  = 0
    TabLineL.Position         = UDim2New(0, -2, 0, 0)
    TabLineL.Rotation         = 90
    TabLineL.Size             = UDim2New(0, 10, 0, 5)
    TabLineL.Parent           = TabsHolder
    local TabLineR = InstanceNew("Frame")
    TabLineR.Name             = "TabLine"
    TabLineR.BackgroundColor3 = FromRGB(20, 20, 20)
    TabLineR.BorderSizePixel  = 0
    TabLineR.Position         = UDim2New(0, 87, 0, 0)
    TabLineR.Size             = UDim2New(0, 10, 0, 379)
    TabLineR.Parent           = TabsHolder

    local TabSelectedFrame = InstanceNew("Frame")
    TabSelectedFrame.Name             = "TabSelectedFrame"
    TabSelectedFrame.BackgroundColor3 = FromRGB(164, 139, 242)
    TabSelectedFrame.Size             = UDim2New(0, 5, 0, 17)
    TabSelectedFrame.Visible          = false
    do
        local c = InstanceNew("UICorner")
        c.CornerRadius = UDimNew(0.1, 1)
        c.Parent = TabSelectedFrame
    end
    TabSelectedFrame.Parent  = TabsHolder
    Window.TabSelectedFrame  = TabSelectedFrame
    TabsHolder.Parent         = MainFrame
    Window.TabsHolder         = TabsHolder

    local ContentHolder = InstanceNew("Frame")
    ContentHolder.Name             = "ContentHolder"
    ContentHolder.BackgroundColor3 = FromRGB(20, 20, 20)
    ContentHolder.Position         = UDim2New(0, 105, 0, 9)
    ContentHolder.Size             = UDim2New(0, 462, 0, 358)
    do
        local c = InstanceNew("UICorner")
        c.CornerRadius = UDimNew(0, 5)
        c.Parent = ContentHolder
    end
    ContentHolder.Parent  = MainFrame
    Window.ContentHolder  = ContentHolder

    local SectionTopBar = InstanceNew("Frame")
    SectionTopBar.Name             = "SectionTopBar"
    SectionTopBar.BackgroundColor3 = FromRGB(15, 15, 15)
    SectionTopBar.Size             = UDim2New(0, 462, 0, 43)
    do
        local c = InstanceNew("UICorner")
        c.CornerRadius = UDimNew(0, 5)
        c.Parent = SectionTopBar
    end
    local SectionNameLabel = InstanceNew("TextLabel")
    SectionNameLabel.Name               = "SectionName"
    SectionNameLabel.BackgroundTransparency = 1
    SectionNameLabel.FontFace           = Font.new("rbxasset://fonts/families/SourceSansPro.json")
    SectionNameLabel.Position           = UDim2New(0, 13, 0, 5)
    SectionNameLabel.Size               = UDim2New(0, 200, 0, 33)
    SectionNameLabel.Text               = ""
    SectionNameLabel.TextColor3         = FromRGB(255, 255, 255)
    SectionNameLabel.TextSize           = 23
    SectionNameLabel.TextXAlignment     = Enum.TextXAlignment.Left
    SectionNameLabel.Parent             = SectionTopBar
    SectionTopBar.Parent               = ContentHolder
    Window.SectionTopBar               = SectionTopBar
    Window.SectionNameLabel            = SectionNameLabel
    local SectionTopBarLine = InstanceNew("Frame")
    SectionTopBarLine.Name             = "SectionTopBarLine"
    SectionTopBarLine.BackgroundColor3 = FromRGB(15, 15, 15)
    SectionTopBarLine.BorderSizePixel  = 0
    SectionTopBarLine.Position         = UDim2New(0, 0, 0, 40)
    SectionTopBarLine.Size             = UDim2New(0, 462, 0, 5)
    SectionTopBarLine.Parent           = ContentHolder

    local TabYOffset = 5

    function Window:Tab(Data)
        Data = Data or {}
        local Tab = {
            Name     = Data.Name or Data.name or "Tab",
            SubPages = {},
            Window   = Window,
        }

        local TabText = InstanceNew("TextBox")
        TabText.BackgroundTransparency = 1
        TabText.CursorPosition         = -1
        TabText.Editable               = false
        TabText.FontFace               = Font.new("rbxasset://fonts/families/SourceSansPro.json")
        TabText.Position               = UDim2New(0, 15, 0, TabYOffset)
        TabText.Size                   = UDim2New(0, 66, 0, 32)
        TabText.Text                   = Tab.Name
        TabText.TextColor3             = Neptune.TextInactive
        TabText.TextSize               = 18
        TabText.TextXAlignment         = Enum.TextXAlignment.Left
        TabText.Parent                 = TabsHolder
        Tab.TabText                    = TabText
        Tab.YOffset                    = TabYOffset
        TabYOffset                     += 30

        TableInsert(Window.Tabs, Tab)

        local function SelectTab()
            if Window.ActiveTab == Tab then return end
            if Window.ActiveTab then
                Window.ActiveTab.TabText.TextColor3 = Neptune.TextInactive
            end
            Window.ActiveTab      = Tab
            TabText.TextColor3    = Neptune.TextActive
            TabSelectedFrame.Position = UDim2New(0, 83, 0, Tab.YOffset + 8)
            TabSelectedFrame.Visible  = true
            if Tab.SubPages[1] then
                Tab.SubPages[1]:Select()
            end
        end

        TabText.Focused:Connect(function() TabText:ReleaseFocus() SelectTab() end)
        Neptune:Connect(TabText.InputBegan, function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then SelectTab() end
        end)

        if #Window.Tabs == 1 then SelectTab() end

        function Tab:SubPage(SPData)
            SPData = SPData or {}
            local SubPage = {
                Name   = SPData.Name or SPData.name or "SubPage",
                Tab    = Tab,
                Window = Window,
            }

            local SubPageCount = #Tab.SubPages
            local XPositions = {297, 350, 405, 455, 504}
            local XPos = XPositions[SubPageCount + 1] or (297 + SubPageCount * 53)

            local SPText = InstanceNew("TextBox")
            SPText.BackgroundTransparency = 1
            SPText.CursorPosition         = -1
            SPText.Editable               = false
            SPText.FontFace               = Font.new("rbxasset://fonts/families/SourceSansPro.json")
            SPText.Position               = UDim2New(0, XPos, 0, 9)
            SPText.Size                   = UDim2New(0, 60, 0, 37)
            SPText.Text                   = SubPage.Name
            SPText.TextColor3             = Neptune.TextInactive
            SPText.TextSize               = 20
            SPText.Visible                = false
            SPText.Parent                 = SubPageHolder
            SubPage.SPText                = SPText
            SubPage.XPos                  = XPos

            TableInsert(Tab.SubPages, SubPage)

            function SubPage:Select()
                for _, sp in Tab.SubPages do
                    sp.SPText.TextColor3 = Neptune.TextInactive
                    sp.SPText.Visible    = false
                end
                for _, sp in Tab.SubPages do
                    sp.SPText.Visible = true
                end
                Window.ActiveSubPage         = SubPage
                SPText.TextColor3            = Neptune.TextActive
                Window.SectionNameLabel.Text = SubPage.Name
                Window.SubSelectedFrame.Position = UDim2New(0, SubPage.XPos - 297, 0, 53)
                Window.SubSelectedFrame.Visible  = true
            end

            SPText.Focused:Connect(function() SPText:ReleaseFocus() SubPage:Select() end)
            Neptune:Connect(SPText.InputBegan, function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    SubPage:Select()
                end
            end)

            return SubPage
        end

        return Tab
    end

    return Window
end

end

getgenv().Neptune = Neptune
return Neptune
